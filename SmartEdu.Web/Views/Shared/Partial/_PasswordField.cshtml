@*
    Password input with show/hide toggle.
    Usage:
        @await Html.PartialAsync("Partial/_PasswordField", Tuple.Create("NewPassword", "New password", "new-password"))
*@
@using System.Security.Cryptography
@* The view receives ViewData["Name"], ViewData["Label"], ViewData["Autocomplete"] *@
@{
    var name = (ViewData["Name"] as string) ?? "Password";
    var label = (ViewData["Label"] as string) ?? "Password";
    var autocomplete = (ViewData["Autocomplete"] as string) ?? "current-password";
    var required = (ViewData["Required"] as bool?) ?? true;
}
<div class="mb-3">
    <label class="form-label" for="@name">@label</label>
    <div class="input-group">
        <span class="input-group-text"><i class="bi bi-shield-lock"></i></span>
        <input class="form-control" id="@name" name="@name" type="password"
               placeholder="••••••••" autocomplete="@autocomplete"
               @(required ? "required" : null) />
        <button type="button" class="btn btn-light border toggle-pass" data-target="@name" aria-label="Toggle visibility">
            <i class="bi bi-eye"></i>
        </button>
    </div>
</div>