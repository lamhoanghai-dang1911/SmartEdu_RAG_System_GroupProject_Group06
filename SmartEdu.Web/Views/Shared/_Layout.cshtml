@{
    var isAuth = User?.Identity?.IsAuthenticated ?? false;
    var roleName = User?.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value
                   ?? User?.FindFirst("role")?.Value
                   ?? string.Empty;
    var userName = User?.Identity?.Name ?? string.Empty;
    var firstLetter = string.IsNullOrEmpty(userName) ? "?" : userName.Substring(0, 1).ToUpper();
    var currentController = (string?)ViewContext.RouteData.Values["controller"] ?? string.Empty;
    var currentAction = (string?)ViewContext.RouteData.Values["action"] ?? "Index";
    var bodyClass = ViewBag.BodyClass as string ?? string.Empty;
    var isChatPage = string.Equals(currentController, "Chat", StringComparison.OrdinalIgnoreCase)
                     && string.Equals(currentAction, "Index", StringComparison.OrdinalIgnoreCase);
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SmartEdu</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Sora:wght@600;700;800&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/SmartEdu.Web.styles.css" asp-append-version="true" />
</head>
<body class="app-shell @(isChatPage ? "app-shell--chat" : string.Empty) @bodyClass">

    @if (isAuth)
    {
        <button class="app-sidebar-toggle d-lg-none" type="button" aria-label="Toggle navigation" data-app-sidebar-toggle>
            <i class="bi bi-list"></i>
        </button>
        <div class="app-sidebar-backdrop d-lg-none" data-app-sidebar-backdrop></div>

        <aside class="app-sidebar" id="appSidebar" aria-label="Primary navigation">
            <div class="app-sidebar-brand">
                <a asp-controller="Home" asp-action="Index" class="app-sidebar-brand-link">
                    <span class="app-sidebar-brand-mark" aria-hidden="true">
                        <i class="bi bi-mortarboard-fill"></i>
                    </span>
                    <span class="app-sidebar-brand-text">
                        <span class="app-sidebar-brand-name">SmartEdu</span>
                        <span class="app-sidebar-brand-sub">Learning Platform</span>
                    </span>
                </a>
            </div>

            <div class="app-sidebar-body">
                @await Component.InvokeAsync("SidebarNav")
            </div>

            <div class="app-sidebar-foot">
                <div class="app-sidebar-user">
                    <div class="app-sidebar-avatar" aria-hidden="true">@firstLetter</div>
                    <div class="app-sidebar-user-meta">
                        <div class="app-sidebar-user-name">@userName</div>
                        <div class="app-sidebar-user-role">@roleName</div>
                    </div>
                </div>
            </div>
        </aside>
    }

    <div class="app-main @(isAuth ? "app-main--with-sidebar" : "app-main--standalone")">

        @if (isAuth)
        {
            <header class="app-topbar">
                <div class="app-topbar-left">
                    <button class="app-topbar-toggle d-none d-lg-inline-flex" type="button"
                            data-app-sidebar-toggle aria-label="Collapse sidebar">
                        <i class="bi bi-layout-sidebar-inset"></i>
                    </button>
                    <div class="app-topbar-title">@ViewData["Title"]</div>
                </div>
                <div class="app-topbar-right">
                    <a asp-controller="Chat" asp-action="Index" class="app-topbar-icon" title="AI Chatbot" aria-label="AI Chatbot">
                        <i class="bi bi-chat-dots"></i>
                    </a>
                    <div class="app-topbar-dropdown">
                        <button class="app-topbar-account" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                            <span class="app-topbar-avatar" aria-hidden="true">@firstLetter</span>
                            <span class="app-topbar-account-meta d-none d-md-flex">
                                <span class="app-topbar-account-name">@userName</span>
                                <span class="app-topbar-account-role">@roleName</span>
                            </span>
                            <i class="bi bi-chevron-down app-topbar-account-caret"></i>
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end app-topbar-menu">
                            <li>
                                <a class="dropdown-item" asp-controller="Account" asp-action="ChangePassword">
                                    <i class="bi bi-key me-2"></i> Change password
                                </a>
                            </li>
                            <li><hr class="dropdown-divider"></li>
                            <li>
                                <a class="dropdown-item text-danger" asp-controller="Account" asp-action="Logout">
                                    <i class="bi bi-box-arrow-right me-2"></i> Sign out
                                </a>
                            </li>
                        </ul>
                    </div>
                </div>
            </header>
        }

        <main class="app-content" role="main">
            <div class="app-content-inner">
                @RenderBody()
            </div>
        </main>

        @if (!isChatPage && !isAuth)
        {
            <footer class="app-footer">
                <div class="container">
                    <div class="d-flex flex-wrap align-items-center justify-content-between gap-2">
                        <div class="fw-bold">SmartEdu</div>
                        <div class="small">&copy; 2026 - <a asp-controller="Home" asp-action="Privacy">Privacy</a></div>
                    </div>
                </div>
            </footer>
        }
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <!-- Markdown renderer and sanitizer (available globally) -->
    <script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/dompurify/dist/purify.min.js"></script>
    <script>
        marked.setOptions({ gfm: true, breaks: true, smartLists: true, smartypants: false });

        const _mdRenderer = new marked.Renderer();
        _mdRenderer.link = function(href, title, text) {
            const titleAttr = title ? ` title="${title}"` : '';
            return `<a href="${href}"${titleAttr} target="_blank" rel="noopener noreferrer">${text}</a>`;
        };

        function renderChatMarkdown(containerOrSelector, markdownText) {
            const container = (typeof containerOrSelector === 'string')
                ? document.querySelector(containerOrSelector)
                : containerOrSelector;
            if (!container) return;
            container.classList.add('chat-message-content');
            const rawHtml = marked.parse(markdownText || '', { renderer: _mdRenderer });
            const safe = DOMPurify.sanitize(rawHtml);
            container.innerHTML = safe;
        }
        window.renderChatMarkdown = renderChatMarkdown;

        // Sidebar toggle (mobile + desktop collapse)
        (function () {
            const shell = document.body;
            const STORAGE_KEY = 'smartedu-sidebar-collapsed';
            function setCollapsed(collapsed) {
                shell.classList.toggle('app-shell--collapsed', collapsed);
                try { localStorage.setItem(STORAGE_KEY, collapsed ? '1' : '0'); } catch (e) {}
            }
            try {
                if (localStorage.getItem(STORAGE_KEY) === '1') setCollapsed(true);
            } catch (e) {}
            document.querySelectorAll('[data-app-sidebar-toggle]').forEach(function (btn) {
                btn.addEventListener('click', function () {
                    if (window.innerWidth < 992) {
                        shell.classList.toggle('app-shell--open');
                    } else {
                        setCollapsed(!shell.classList.contains('app-shell--collapsed'));
                    }
                });
            });
            const backdrop = document.querySelector('[data-app-sidebar-backdrop]');
            if (backdrop) {
                backdrop.addEventListener('click', function () { shell.classList.remove('app-shell--open'); });
            }
        })();
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>