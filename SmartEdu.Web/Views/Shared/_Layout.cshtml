<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SmartEdu</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/SmartEdu.Web.styles.css" asp-append-version="true" />
    <style>
        /* Layout: make body full-height flex column */
        body.d-flex-root {
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        /* Global font-size tweak (slightly larger for readability) */
        body {
            font-size: 1.1rem;
        }

        /* Header subtle shadow (if not provided by bootstrap) */
        header .box-shadow {
            box-shadow: 0 2px 6px rgba(0,0,0,0.06);
        }

        /* Main area should grow and not cause page scroll (inner regions can scroll) */
        main.flex-fill {
            flex: 1 1 auto;
            overflow: hidden; /* important: prevent footer overlap */
        }

        /* Option A: use mt-auto on footer to keep it at page bottom when content is short */
        .footer.mt-auto {
            /* no extra styles needed; mt-auto on a flex column pushes footer down */
        }

        /* Option B: hide footer entirely on chat pages to maximize space */
        body.chat-page .footer {
            display: none !important;
        }
        /* -----------------
           Header & Footer custom styles
           ----------------- */
        .site-header {
            background: linear-gradient(90deg, #0d6efd 0%, #6610f2 100%);
            color: #fff;
        }

        .site-header .navbar-brand,
        .site-header .nav-link {
            color: rgba(255,255,255,0.95) !important;
        }

        .site-header .navbar-brand {
            font-size: 1.25rem; /* slightly larger */
            font-weight: 700;
            letter-spacing: 0.2px;
        }

        .site-header .nav-link {
            transition: color 0.15s ease, opacity 0.15s ease;
            opacity: 0.95;
        }

        .site-header .nav-link:hover {
            color: rgba(255,255,255,1) !important;
            opacity: 1;
        }

        /* make header taller */
        .site-header .navbar {
            padding-top: 0.8rem;
            padding-bottom: 0.8rem;
        }

        /* Footer styles */
        .site-footer {
            padding: 1.25rem 0;
            background-color: #0d1117; /* dark shade */
            color: rgba(255,255,255,0.85);
        }

        .site-footer a { color: rgba(255,255,255,0.9); }
        .site-footer a:hover { color: #ffffff; text-decoration: underline; }
        /* Markdown chat content styling: preserve newlines and spacing */
        .chat-message-content {
            white-space: pre-wrap; /* preserve newlines and collapse sequences of whitespace */
            word-break: break-word;
            line-height: 1.6;
            color: inherit;
            font-size: 1rem;
            font-family: inherit;
        }

        .chat-message-content p { margin: 0 0 0.75rem; }
        .chat-message-content ul,
        .chat-message-content ol { margin: 0 0 0.75rem 1.25rem; }
        .chat-message-content li { margin: 0.25rem 0; }
        .chat-message-content code { background:#f5f5f5; padding:0.12rem 0.4rem; border-radius:4px; }
        .chat-message-content pre { background:#0f1720; color:#e6eef8; padding:0.75rem; border-radius:6px; overflow:auto; }
    </style>
</head>
<body class="d-flex flex-column min-vh-100 @(ViewBag.BodyClass ?? String.Empty)">
    <header>
        <nav class="navbar navbar-expand-sm navbar-dark site-header py-3 mb-3 align-items-center">
            <div class="container-fluid">
                <a class="navbar-brand d-flex align-items-center" asp-area="" asp-controller="Home" asp-action="Index">
                    <span class="me-3 fs-3" aria-hidden="true" style="line-height:1;">🎓</span>
                    <span class="fs-3 fw-bold">SmartEdu</span>
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex">
                    <ul class="navbar-nav me-auto gap-3 align-items-center">
    <li class="nav-item">
        <a class="nav-link fs-5 px-3" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
    </li>
    @if (User.IsInRole("Admin"))
    {
        <li class="nav-item">
            <a class="nav-link fs-5 px-3 d-flex align-items-center" asp-controller="Account" asp-action="ManageUsers">
                <span class="fs-4 me-2" aria-hidden="true">👥</span> Quản lý tài khoản
            </a>
        </li>
        <li class="nav-item">
            <a class="nav-link fs-5 px-3 d-flex align-items-center" asp-controller="LecturerManagement" asp-action="Index">
                <span class="fs-4 me-2" aria-hidden="true">🧑‍🏫</span> Quản lý giảng viên
            </a>
        </li>
        <li class="nav-item">
            <a class="nav-link fs-5 px-3 d-flex align-items-center" asp-controller="ChunkingConfig" asp-action="Index">
                <span class="fs-4 me-2" aria-hidden="true">⚙️</span> Cấu hình Chunking
            </a>
        </li>
    }









    @if (User.IsInRole("Lecturer") || User.IsInRole("Admin"))
    {
        <li class="nav-item">
            <a class="nav-link fs-5 px-3 d-flex align-items-center" asp-controller="Subject" asp-action="Index">
                <span class="fs-4 me-2" aria-hidden="true">📚</span> Quản lý môn học
            </a>
        </li>
    }

    @if (User.IsInRole("Lecturer") || User.IsInRole("Admin") || User.IsInRole("Student"))
    {
     <li class="nav-item">
            <a class="nav-link fs-5 px-3 d-flex align-items-center" asp-controller="Document" asp-action="Index">
                <span class="fs-4 me-2" aria-hidden="true">📄</span> Tài liệu
            </a>
    </li>                           
     }

    @if (User.IsInRole("Student"))
    {
        <li class="nav-item">
            <a class="nav-link fs-5 px-3 d-flex align-items-center" asp-controller="Chat" asp-action="Index">
                <span class="fs-4 me-2" aria-hidden="true">🤖</span> Chat RAG
            </a>
        </li>
        <li class="nav-item">
             <a class="nav-link fs-5 px-3 d-flex align-items-center" asp-controller="Package" asp-action="List">
                <span class="fs-4 me-2" aria-hidden="true">💳</span> Gói dịch vụ
             </a>
             </li>
                            <li class="nav-item">
                                <a class="nav-link fs-5 px-3 d-flex align-items-center" asp-controller="Package" asp-action="MySubscription">
                                    <span class="fs-4 me-2" aria-hidden="true">📊</span> Gói của tôi
                                </a>
                            </li>
    }
                    </ul>

<ul class="navbar-nav ms-auto align-items-center">
    @if (User.Identity.IsAuthenticated)
    {
        <li class="nav-item dropdown">
            <a class="nav-link dropdown-toggle" href="#" id="navbarDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                @User.Identity.Name (@User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value)
            </a>
            <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="navbarDropdown">
                <li><a class="dropdown-item" asp-controller="Account" asp-action="Logout">Đăng xuất</a></li>
            </ul>
        </li>
    }
    else
    {
        <li class="nav-item">
            <a class="nav-link btn btn-outline-light px-3" asp-controller="Account" asp-action="Login">Đăng nhập</a>
        </li>
    }
</ul>
                </div>
            </div>
        </nav>
    </header>
    <main role="main" class="flex-grow-1">
        <div class="container h-100 d-flex flex-column">
            @RenderBody()
        </div>
    </main>

    <!-- Footer: Option A (sticky at bottom via mt-auto) or Option B (hidden on chat pages). 
         To hide footer on chat page, set ViewBag.BodyClass = "chat-page" in controller or layout. -->
    <footer class="site-footer text-center mt-auto py-4">
        <div class="container">
                <div class="d-flex flex-column align-items-center">
                <div class="mb-1 fs-6 fw-bold">SmartEdu</div>
                <div class="fs-6">&copy; 2026 - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a></div>
            </div>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <!-- Markdown renderer and sanitizer (available globally) -->
    <script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/dompurify/dist/purify.min.js"></script>
    <script>
        // Configure marked: breaks=true turns single newlines into <br>
        marked.setOptions({ gfm: true, breaks: true, smartLists: true, smartypants: false });

        const _mdRenderer = new marked.Renderer();
        _mdRenderer.link = function(href, title, text) {
            const titleAttr = title ? ` title="${title}"` : '';
            return `<a href="${href}"${titleAttr} target="_blank" rel="noopener noreferrer">${text}</a>`;
        };

        // Render markdown string into a container and ensure the container has chat-message-content class
        function renderChatMarkdown(containerOrSelector, markdownText) {
            const container = (typeof containerOrSelector === 'string')
                ? document.querySelector(containerOrSelector)
                : containerOrSelector;
            if (!container) return;
            container.classList.add('chat-message-content');
            const rawHtml = marked.parse(markdownText || '', { renderer: _mdRenderer });
            const safe = DOMPurify.sanitize(rawHtml);
            container.innerHTML = safe;
        }
        // Expose to window for convenience
        window.renderChatMarkdown = renderChatMarkdown;
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
