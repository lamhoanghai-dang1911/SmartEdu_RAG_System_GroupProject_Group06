@{
    ViewData["Title"] = "Báo cáo thống kê";
}

<style>
    :root {
        --brand-blue: #0d6efd;
        --brand-purple: #6610f2;
        --ink-navy: #0b1120;
        --amber: #ffb648;
        --paper: #f7f8fc;
        --slate: #5a6072;
        --slate-light: #9aa0b4;
        --success: #1fae63;
        --danger: #e5484d;
        --warning: #f5a623;
    }

    @@keyframes fadeUp {
        from {
            opacity: 0;
            transform: translateY(12px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .page-head h2 {
        font-family: 'Sora', sans-serif;
        font-weight: 700;
        font-size: 1.5rem;
        color: #12162b;
        margin: 0;
    }

    /* ===== Filter bar ===== */
    .filter-bar {
        background: #fff;
        border-radius: 14px;
        padding: 1rem 1.2rem;
        box-shadow: 0 6px 20px -12px rgba(11, 17, 32, 0.12);
        margin-bottom: 1.25rem;
    }

        .filter-bar .form-label {
            font-size: 0.78rem;
            font-weight: 600;
            color: var(--slate);
            text-transform: uppercase;
            letter-spacing: 0.03em;
            margin-bottom: 0.35rem;
        }

        .filter-bar .form-control {
            border: 1.5px solid #e3e5ef;
            border-radius: 10px;
            transition: border-color 0.2s ease, box-shadow 0.2s ease;
        }

            .filter-bar .form-control:focus {
                border-color: var(--brand-blue);
                box-shadow: 0 0 0 4px rgba(13, 110, 253, 0.12);
            }

    /* ===== KPI cards ===== */
    .kpi-card {
        border: none !important;
        border-radius: 16px !important;
        padding: 1.4rem 1.3rem;
        color: #fff;
        position: relative;
        overflow: hidden;
        opacity: 0;
        animation: fadeUp 0.5s ease forwards;
    }

    .col-md-3:nth-of-type(1) .kpi-card {
        animation-delay: 0.05s;
    }

    .col-md-3:nth-of-type(2) .kpi-card {
        animation-delay: 0.1s;
    }

    .col-md-3:nth-of-type(3) .kpi-card {
        animation-delay: 0.15s;
    }

    .col-md-3:nth-of-type(4) .kpi-card {
        animation-delay: 0.2s;
    }

    .kpi-card::after {
        content: "";
        position: absolute;
        top: -30%;
        right: -20%;
        width: 120px;
        height: 120px;
        border-radius: 50%;
        background: rgba(255, 255, 255, 0.08);
    }

    .kpi-card.kpi-revenue {
        background: linear-gradient(135deg, var(--brand-blue), var(--brand-purple));
    }

    .kpi-card.kpi-orders {
        background: linear-gradient(135deg, var(--success), #17c76f);
    }

    .kpi-card.kpi-tokens {
        background: linear-gradient(135deg, #0dcaf0, #0d8fbd);
    }

    .kpi-card.kpi-users {
        background: linear-gradient(135deg, var(--amber), #f28b1e);
    }

    .kpi-card .kpi-label {
        font-size: 0.82rem;
        opacity: 0.85;
        font-weight: 600;
        margin-bottom: 0.3rem;
        position: relative;
        z-index: 1;
    }

    .kpi-card .kpi-value {
        font-family: 'Sora', sans-serif;
        font-weight: 800;
        font-size: 1.6rem;
        position: relative;
        z-index: 1;
    }

    /* ===== Chart-like table cards ===== */
    .report-card {
        border: none !important;
        border-radius: 16px !important;
        box-shadow: 0 10px 30px -16px rgba(11, 17, 32, 0.16);
        opacity: 0;
        animation: fadeUp 0.5s ease forwards;
        animation-delay: 0.15s;
    }

        .report-card h6 {
            font-family: 'Sora', sans-serif;
            font-weight: 700;
            font-size: 0.98rem;
            color: #12162b;
            margin: 0;
        }

    /* Đảm bảo 2 header card (có/không có nút segmented control) luôn cao bằng nhau */
    .report-header {
        min-height: 38px;
    }

    /* ===== Segmented control (thay cho dropdown) ===== */
    .granularity-group {
        display: inline-flex;
        background: var(--paper);
        border-radius: 999px;
        padding: 3px;
        gap: 2px;
    }

    .granularity-btn {
        border: none;
        background: transparent;
        color: var(--slate);
        font-size: 0.8rem;
        font-weight: 600;
        padding: 0.4rem 0.9rem;
        border-radius: 999px;
        cursor: pointer;
        transition: background 0.18s ease, color 0.18s ease, box-shadow 0.18s ease;
        white-space: nowrap;
    }

        .granularity-btn:hover:not(.active) {
            color: #12162b;
        }

        .granularity-btn.active {
            background: linear-gradient(120deg, var(--brand-blue), var(--brand-purple));
            color: #fff;
            box-shadow: 0 4px 12px -4px rgba(13, 110, 253, 0.5);
        }

    .table {
        margin-bottom: 0;
    }

        .table thead tr {
            background: linear-gradient(120deg, var(--ink-navy), #171d3d) !important;
        }

        .table thead th {
            border: none !important;
            color: #fff !important;
            font-family: 'Sora', sans-serif;
            font-weight: 600;
            font-size: 0.76rem;
            letter-spacing: 0.03em;
            text-transform: uppercase;
            padding: 0.8rem 0.9rem !important;
        }

        .table tbody tr {
            transition: background 0.15s ease;
        }

            .table tbody tr:hover {
                background: rgba(13, 110, 253, 0.045) !important;
            }

        .table tbody td {
            border-color: #eef0f6 !important;
            padding: 0.7rem 0.9rem !important;
            font-size: 0.88rem;
            color: #33384f;
        }

    .table-responsive-wrap {
        max-height: 360px;
        overflow-y: auto;
        border-radius: 0 0 16px 16px;
    }

        .table-responsive-wrap::-webkit-scrollbar {
            width: 8px;
        }

        .table-responsive-wrap::-webkit-scrollbar-thumb {
            background: #d7dbe8;
            border-radius: 8px;
        }

    @@media (prefers-reduced-motion: reduce) {
        *, *::before, *::after {
            animation-duration: 0.01ms !important;
            transition-duration: 0.01ms !important;
        }
    }
</style>

<div class="container mt-4">
    <div class="page-head d-flex justify-content-between align-items-center mb-3">
        <h2>📊 Báo cáo thống kê</h2>
    </div>

    <div class="filter-bar d-flex flex-wrap gap-3 align-items-end">
        <div>
            <label class="form-label d-block">Từ ngày</label>
            <input type="date" id="start" class="form-control" />
        </div>
        <div>
            <label class="form-label d-block">Đến ngày</label>
            <input type="date" id="end" class="form-control" />
        </div>
    </div>

    <!-- KPI Cards -->
    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="card kpi-card kpi-revenue">
                <div class="kpi-label">💰 Tổng doanh thu</div>
                <div class="kpi-value" id="kpiRevenue">0 đ</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card kpi-card kpi-orders">
                <div class="kpi-label">🧾 Số đơn hàng</div>
                <div class="kpi-value" id="kpiOrders">0</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card kpi-card kpi-tokens">
                <div class="kpi-label">🎫 Tổng token dùng</div>
                <div class="kpi-value" id="kpiTokens">0</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card kpi-card kpi-users">
                <div class="kpi-label">👥 User hoạt động</div>
                <div class="kpi-value" id="kpiUsers">0</div>
            </div>
        </div>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-md-6">
            <div class="card report-card">
                <div class="card-body">
                    <div class="report-header d-flex justify-content-between align-items-center mb-3">
                        <h6>💰 Doanh thu theo thời gian</h6>
                        <div class="granularity-group" id="revenueGranularityGroup">
                            <button type="button" class="granularity-btn active" data-value="day">Ngày</button>
                            <button type="button" class="granularity-btn" data-value="week">Tuần</button>
                            <button type="button" class="granularity-btn" data-value="month">Tháng</button>
                        </div>
                    </div>
                    <div class="table-responsive-wrap">
                        <table class="table table-hover" id="revenueTable">
                            <thead>
                                <tr>
                                    <th id="revenueDateHeader">Ngày</th>
                                    <th>Doanh thu</th>
                                    <th>Số đơn</th>
                                </tr>
                            </thead>
                            <tbody></tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card report-card">
                <div class="card-body">
                    <div class="report-header d-flex justify-content-between align-items-center mb-3">
                        <h6>📦 Doanh thu theo gói</h6>
                    </div>
                    <div class="table-responsive-wrap">
                        <table class="table table-hover" id="packageTable">
                            <thead>
                                <tr>
                                    <th>Gói</th>
                                    <th>Doanh thu</th>
                                    <th>Số đơn</th>
                                </tr>
                            </thead>
                            <tbody></tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="card report-card">
        <div class="card-body">
            <h6 class="mb-3">📋 Token theo user</h6>
            <div class="table-responsive-wrap">
                <table class="table table-hover" id="usageTable">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>User</th>
                            <th>Tổng token</th>
                        </tr>
                    </thead>
                    <tbody></tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function fmtCurrency(n) {
            return new Intl.NumberFormat('vi-VN').format(n) + ' đ';
        }
        function fmtNumber(n) {
            return new Intl.NumberFormat('vi-VN').format(n);
        }
        function pad2(n) {
            return String(n).padStart(2, '0');
        }

        let rawRevenueItems = [];
        let currentGranularity = 'day';

        function getMonday(date) {
            const d = new Date(date.getFullYear(), date.getMonth(), date.getDate());
            const day = d.getDay();
            const diff = day === 0 ? -6 : 1 - day;
            d.setDate(d.getDate() + diff);
            return d;
        }

        function bucketDate(date, granularity) {
            const d = new Date(date);
            if (granularity === 'month') {
                return new Date(d.getFullYear(), d.getMonth(), 1);
            }
            if (granularity === 'week') {
                return getMonday(d);
            }
            return new Date(d.getFullYear(), d.getMonth(), d.getDate());
        }

        function formatBucketLabel(bucket, granularity) {
            if (granularity === 'month') {
                return `Tháng ${pad2(bucket.getMonth() + 1)}/${bucket.getFullYear()}`;
            }
            if (granularity === 'week') {
                const sunday = new Date(bucket);
                sunday.setDate(bucket.getDate() + 6);
                const startStr = `${pad2(bucket.getDate())}/${pad2(bucket.getMonth() + 1)}`;
                const endStr = `${pad2(sunday.getDate())}/${pad2(sunday.getMonth() + 1)}/${sunday.getFullYear()}`;
                return `Tuần ${startStr} - ${endStr}`;
            }
            return bucket.toLocaleDateString('vi-VN');
        }

        function renderRevenueTable() {
            const granularity = currentGranularity;
            document.getElementById('revenueDateHeader').textContent =
                granularity === 'month' ? 'Tháng' : (granularity === 'week' ? 'Tuần' : 'Ngày');

            const map = new Map();
            rawRevenueItems.forEach(i => {
                const bucket = bucketDate(i.date, granularity);
                const key = bucket.getTime();
                if (!map.has(key)) {
                    map.set(key, { bucket, amount: 0, orderCount: 0 });
                }
                const entry = map.get(key);
                entry.amount += i.amount;
                entry.orderCount += i.orderCount;
            });

            const items = Array.from(map.values()).sort((a, b) => a.bucket - b.bucket);

            const revTbody = document.querySelector('#revenueTable tbody');
            revTbody.innerHTML = '';
            items.forEach(i => {
                const tr = document.createElement('tr');
                const label = formatBucketLabel(i.bucket, granularity);
                tr.innerHTML = `<td>${label}</td><td>${fmtCurrency(i.amount)}</td><td>${fmtNumber(i.orderCount)}</td>`;
                revTbody.appendChild(tr);
            });
            if (items.length === 0) {
                revTbody.innerHTML = '<tr><td colspan="3" class="text-center text-muted">Không có dữ liệu</td></tr>';
            }
        }

        document.querySelectorAll('.granularity-btn').forEach(btn => {
            btn.addEventListener('click', () => {
                document.querySelectorAll('.granularity-btn').forEach(b => b.classList.remove('active'));
                btn.classList.add('active');
                currentGranularity = btn.getAttribute('data-value');
                renderRevenueTable();
            });
        });

        async function loadReports() {
            try {
                const start = document.getElementById('start').value;
                const end = document.getElementById('end').value;
                const qs = `start=${encodeURIComponent(start)}&end=${encodeURIComponent(end)}`;

                const summaryResp = await fetch(`/Reports/SummaryJson?${qs}`);
                if (!summaryResp.ok) {
                    console.error('SummaryJson failed:', summaryResp.status, await summaryResp.text());
                    return;
                }
                const summary = await summaryResp.json();
                document.getElementById('kpiRevenue').textContent = fmtCurrency(summary.totalRevenue);
                document.getElementById('kpiOrders').textContent = fmtNumber(summary.totalOrders);
                document.getElementById('kpiTokens').textContent = fmtNumber(summary.totalTokensUsed);
                document.getElementById('kpiUsers').textContent = fmtNumber(summary.activeUserCount);

                const revResp = await fetch(`/Reports/RevenueJson?${qs}`);
                if (!revResp.ok) {
                    console.error('RevenueJson failed:', revResp.status, await revResp.text());
                    return;
                }
                const rev = await revResp.json();

                rawRevenueItems = rev.items || [];
                renderRevenueTable();

                const pkgTbody = document.querySelector('#packageTable tbody');
                pkgTbody.innerHTML = '';
                (rev.byPackage || []).forEach(p => {
                    const tr = document.createElement('tr');
                    tr.innerHTML = `<td>${p.packageName}</td><td>${fmtCurrency(p.amount)}</td><td>${fmtNumber(p.orderCount)}</td>`;
                    pkgTbody.appendChild(tr);
                });
                if ((rev.byPackage || []).length === 0) {
                    pkgTbody.innerHTML = '<tr><td colspan="3" class="text-center text-muted">Không có dữ liệu</td></tr>';
                }

                const usageResp = await fetch(`/Reports/UsageJson?${qs}`);
                if (!usageResp.ok) {
                    console.error('UsageJson failed:', usageResp.status, await usageResp.text());
                    return;
                }
                const usage = await usageResp.json();

                const utbody = document.querySelector('#usageTable tbody');
                utbody.innerHTML = '';
                (usage.items || []).forEach((u, idx) => {
                    const tr = document.createElement('tr');
                    tr.innerHTML = `<td>${idx + 1}</td><td>${u.userName}</td><td><strong>${fmtNumber(u.totalTokens)}</strong></td>`;
                    utbody.appendChild(tr);
                });
                if ((usage.items || []).length === 0) {
                    utbody.innerHTML = '<tr><td colspan="3" class="text-center text-muted">Không có dữ liệu</td></tr>';
                }
            } catch (err) {
                console.error('loadReports error:', err);
            }
        }

        document.addEventListener('DOMContentLoaded', function () {
            const today = new Date();
            const weekAgo = new Date();
            weekAgo.setDate(today.getDate() - 6);

            document.getElementById('start').value = weekAgo.toISOString().split('T')[0];
            document.getElementById('end').value = today.toISOString().split('T')[0];

            document.getElementById('start').addEventListener('change', loadReports);
            document.getElementById('end').addEventListener('change', loadReports);

            loadReports();
        });
    </script>
}