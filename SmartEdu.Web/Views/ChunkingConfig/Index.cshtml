@model IEnumerable<SmartEdu.Shared.DTOs.ChunkingConfigDto>
@{
    ViewData["Title"] = "Cấu hình Chunking";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>⚙️ Cấu hình Chunking</h2>
        <a asp-action="Create" class="btn btn-primary">➕ Thêm cấu hình mới</a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show">
            @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <table class="table table-bordered table-hover align-middle">
        <thead class="table-dark">
            <tr>
                <th>#</th>
                <th>Chunk Size</th>
                <th>Overlap</th>
                <th>Phạm vi</th>
                <th>Môn học</th>
                <th>Trạng thái</th>
                <th>Cập nhật bởi</th>
                <th>Ngày tạo</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var c in Model)
            {
                <tr>
                    <td>@c.Id</td>
                    <td>@c.ChunkSize</td>
                    <td>@c.ChunkOverlap</td>
                    <td>
                        @if (c.Scope.ToString() == "Global")
                        {
                            <span class="badge bg-info">🌐 Global</span>
                        }
                        else
                        {
                            <span class="badge bg-primary">📘 PerSubject</span>
                        }
                    </td>
                    <td>@(c.SubjectName ?? "—")</td>
                    <td>
                        @if (c.IsActive)
                        {
                            <span class="badge bg-success">✅ Đang dùng</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">Đã thay thế</span>
                        }
                    </td>
                    <td>@c.UpdatedByUserName</td>
                    <td>@c.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                </tr>
            }
        </tbody>
    </table>
</div>