@model IEnumerable<SmartEdu.Shared.DTOs.ChunkingConfigDto>
@{
    ViewData["Title"] = "Cấu hình Chunking";
}

<style>
    :root {
        --brand-blue: #0d6efd;
        --brand-purple: #6610f2;
        --ink-navy: #0b1120;
        --amber: #ffb648;
        --paper: #f7f8fc;
        --slate: #5a6072;
        --slate-light: #9aa0b4;
        --success: #1fae63;
        --danger: #e5484d;
    }

    .page-head h2 {
        font-family: 'Sora', sans-serif;
        font-weight: 700;
        font-size: 1.5rem;
        color: #12162b;
        margin: 0;
    }

    .page-head .btn-primary {
        border: none;
        border-radius: 999px;
        background: linear-gradient(120deg, var(--brand-blue), var(--brand-purple));
        font-weight: 600;
        font-size: 0.9rem;
        padding: 0.55rem 1.2rem;
        box-shadow: 0 8px 20px -10px rgba(13, 110, 253, 0.5);
        transition: transform 0.15s ease, filter 0.15s ease;
    }

        .page-head .btn-primary:hover {
            transform: translateY(-1px);
            filter: brightness(1.07);
        }

    .alert {
        border: none;
        border-radius: 12px;
        animation: fadeUp 0.35s ease forwards;
    }

    .alert-success {
        background: rgba(31, 174, 99, 0.09);
        color: var(--success);
        border-left: 3px solid var(--success);
    }

    .alert-danger {
        background: rgba(229, 72, 77, 0.08);
        color: var(--danger);
        border-left: 3px solid var(--danger);
    }

    @@keyframes fadeUp {
        from {
            opacity: 0;
            transform: translateY(8px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    /* ===== Filter bar ===== */
    .filter-bar {
        display: flex;
        align-items: center;
        gap: 0.6rem;
        margin-bottom: 1rem;
        flex-wrap: wrap;
    }

    .filter-label {
        font-size: 0.82rem;
        font-weight: 600;
        color: var(--slate);
        text-transform: uppercase;
        letter-spacing: 0.03em;
        margin-right: 0.3rem;
    }

    .filter-chip {
        border: 1.5px solid #e3e5ef;
        background: #fff;
        color: #33384f;
        font-weight: 600;
        font-size: 0.85rem;
        padding: 0.42rem 0.95rem;
        border-radius: 999px;
        cursor: pointer;
        transition: all 0.15s ease;
        user-select: none;
    }

        .filter-chip:hover {
            border-color: var(--brand-blue);
            color: var(--brand-blue);
        }

        .filter-chip.active {
            border-color: transparent;
            color: #fff;
        }

            .filter-chip.active[data-filter="active"] {
                background: linear-gradient(120deg, var(--success), #17a866);
            }

            .filter-chip.active[data-filter="inactive"] {
                background: linear-gradient(120deg, var(--slate), #6b7183);
            }

            .filter-chip.active[data-filter="all"] {
                background: linear-gradient(120deg, var(--brand-blue), var(--brand-purple));
            }

    .filter-count {
        font-size: 0.72rem;
        opacity: 0.85;
        margin-left: 0.3rem;
    }

    .empty-filter-msg {
        text-align: center;
        padding: 2.5rem 1rem;
        color: var(--slate-light);
        font-size: 0.92rem;
    }

    .table-card {
        background: #fff;
        border-radius: 16px;
        box-shadow: 0 10px 32px -12px rgba(11, 17, 32, 0.14);
        overflow: hidden;
        opacity: 0;
        animation: fadeUp 0.45s ease forwards;
    }

    .table {
        margin-bottom: 0;
    }

        .table thead {
            background: transparent !important;
        }

            .table thead tr {
                background: linear-gradient(120deg, var(--ink-navy), #171d3d) !important;
            }

            .table thead th {
                border: none !important;
                color: #fff !important;
                font-family: 'Sora', sans-serif;
                font-weight: 600;
                font-size: 0.82rem;
                letter-spacing: 0.02em;
                text-transform: uppercase;
                padding: 0.9rem 1rem !important;
                vertical-align: middle;
            }

        .table tbody tr {
            transition: background 0.15s ease;
        }

            .table tbody tr:hover {
                background: rgba(13, 110, 253, 0.045) !important;
            }

        .table tbody td {
            border-color: #eef0f6 !important;
            padding: 0.85rem 1rem !important;
            font-size: 0.92rem;
            color: #33384f;
            vertical-align: middle;
        }

    .badge {
        font-weight: 600;
        font-size: 0.76rem;
        padding: 0.4rem 0.7rem;
        border-radius: 999px;
        letter-spacing: 0.01em;
    }

        .badge.bg-info {
            background: rgba(13, 110, 253, 0.1) !important;
            color: var(--brand-blue) !important;
        }

        .badge.bg-primary {
            background: rgba(102, 16, 242, 0.1) !important;
            color: var(--brand-purple) !important;
        }

        .badge.bg-success {
            background: rgba(31, 174, 99, 0.12) !important;
            color: var(--success) !important;
        }

        .badge.bg-secondary {
            background: #eef0f6 !important;
            color: var(--slate) !important;
        }

    #sortStatusHeader {
        cursor: pointer;
        user-select: none;
    }

        #sortStatusHeader:hover {
            background: rgba(255,255,255,0.08);
        }

    @@media (prefers-reduced-motion: reduce) {
        *, *::before, *::after {
            animation-duration: 0.01ms !important;
            transition-duration: 0.01ms !important;
        }
    }
</style>

<div class="container mt-4">
    <div class="page-head d-flex justify-content-between align-items-center mb-3">
        <h2>⚙️ Cấu hình Chunking</h2>
        <a asp-action="Create" class="btn btn-primary">➕ Thêm cấu hình mới</a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show">
            @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="filter-bar">
        <span class="filter-label">Lọc theo trạng thái</span>
        <span class="filter-chip active" data-filter="active">✅ Đang dùng</span>
        <span class="filter-chip" data-filter="inactive">🔁 Đã thay thế</span>
        <span class="filter-chip" data-filter="all">Tất cả</span>
    </div>

    <div class="table-card">
        <table class="table table-hover align-middle mb-0">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Chunk Size</th>
                    <th>Overlap</th>
                    <th>Phạm vi</th>
                    <th>Môn học</th>
                    <th id="sortStatusHeader">
                        TRẠNG THÁI <span id="sortIcon">▾</span>
                    </th>
                    <th>Cập nhật bởi</th>
                    <th>Ngày tạo</th>
                </tr>
            </thead>
            <tbody>
                @{
                    var sortedModel = Model
                        .OrderByDescending(c => c.IsActive)
                        .ThenByDescending(c => c.CreatedAt)
                        .ToList();
                }
                @foreach (var c in sortedModel)
                {
                    <tr data-active="@c.IsActive.ToString().ToLower()">
                        <td>@c.Id</td>
                        <td>@c.ChunkSize</td>
                        <td>@c.ChunkOverlap</td>
                        <td>
                            @if (c.Scope.ToString() == "Global")
                            {
                                <span class="badge bg-info">🌐 Toàn hệ thống</span>
                            }
                            else
                            {
                                <span class="badge bg-primary">📘 Theo môn học</span>
                            }
                        </td>
                        <td>@(c.SubjectName ?? "—")</td>
                        <td>
                            @if (c.IsActive)
                            {
                                <span class="badge bg-success">✅ Đang dùng</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">🔁 Đã thay thế</span>
                            }
                        </td>
                        <td>@c.UpdatedByUserName</td>
                        <td>@c.CreatedAt.ToVietnamTime().ToString("dd/MM/yyyy HH:mm")</td>
                    </tr>
                }
            </tbody>
        </table>
        <div id="emptyFilterMsg" class="empty-filter-msg d-none">
            Không có cấu hình nào khớp với bộ lọc hiện tại.
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const tbody = document.querySelector(".table tbody");
            const rows = Array.from(tbody.querySelectorAll("tr"));
            const emptyMsg = document.getElementById("emptyFilterMsg");
            const filterChips = document.querySelectorAll(".filter-chip");

            let currentFilter = "active"; // mặc định: chỉ hiện "Đang dùng"

            function applyFilter() {
                let visibleCount = 0;

                rows.forEach(row => {
                    const isActive = row.getAttribute("data-active") === "true";
                    let show = true;

                    if (currentFilter === "active") show = isActive;
                    else if (currentFilter === "inactive") show = !isActive;
                    // currentFilter === "all" -> show = true

                    row.style.display = show ? "" : "none";
                    if (show) visibleCount++;
                });

                emptyMsg.classList.toggle("d-none", visibleCount > 0);
            }

            filterChips.forEach(chip => {
                chip.addEventListener("click", function () {
                    filterChips.forEach(c => c.classList.remove("active"));
                    this.classList.add("active");
                    currentFilter = this.getAttribute("data-filter");
                    applyFilter();
                });
            });

            // Áp dụng bộ lọc mặc định ngay khi tải trang
            applyFilter();

            // ===== Sort theo trạng thái (giữ nguyên tính năng cũ) =====
            const header = document.getElementById("sortStatusHeader");
            const icon = document.getElementById("sortIcon");
            let activeFirst = true;

            header.addEventListener("click", function () {
                const currentRows = Array.from(tbody.querySelectorAll("tr"));
                activeFirst = !activeFirst;

                currentRows.sort((a, b) => {
                    const aActive = a.getAttribute("data-active") === "true";
                    const bActive = b.getAttribute("data-active") === "true";
                    if (aActive === bActive) return 0;
                    if (activeFirst) return aActive ? -1 : 1;
                    return aActive ? 1 : -1;
                });

                currentRows.forEach(row => tbody.appendChild(row));
                icon.textContent = activeFirst ? "▾" : "▴";

                // sort xong vẫn phải áp dụng lại filter hiện tại
                applyFilter();
            });
        });
    </script>
}