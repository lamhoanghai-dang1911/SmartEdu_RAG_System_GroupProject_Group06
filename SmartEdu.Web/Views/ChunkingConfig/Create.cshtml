@model SmartEdu.Shared.DTOs.ChunkingConfigSaveDto
@{
    ViewData["Title"] = "Thêm cấu hình Chunking";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>➕ Thêm cấu hình Chunking</h2>
        <a asp-action="Index" class="btn btn-secondary">⬅ Quay lại</a>
    </div>

    @if (!ViewData.ModelState.IsValid)
    {
        <div class="alert alert-danger">
            <ul class="mb-0">
                @foreach (var err in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                {
                    <li>@err.ErrorMessage</li>
                }
            </ul>
        </div>
    }

    <form asp-action="Create" method="post" class="row g-3">
        @Html.AntiForgeryToken()

        <div class="col-md-6">
            <label class="form-label">Chunk Size</label>
            <input asp-for="ChunkSize" type="number" class="form-control" min="200" max="2000" />
            <div class="form-text">Từ 200 đến 2000.</div>
        </div>

        <div class="col-md-6">
            <label class="form-label">Chunk Overlap</label>
            <input asp-for="ChunkOverlap" type="number" class="form-control" min="0" />
            <div class="form-text">Phải nhỏ hơn một nửa Chunk Size.</div>
        </div>

        <div class="col-md-6">
            <label class="form-label">Strategy</label>
            <select class="form-select" disabled>
                <option selected>FixedSize</option>
            </select>
            <input type="hidden" asp-for="Strategy" value="@SmartEdu.Shared.Enums.ChunkingStrategy.FixedSize" />
        </div>

        <div class="col-md-6">
            <label class="form-label">Phạm vi (Scope)</label>
            <select asp-for="Scope" id="scopeSelect" asp-items="Html.GetEnumSelectList<SmartEdu.Shared.Enums.ChunkingScope>()" class="form-select"></select>
        </div>

        <div class="col-md-6" id="subjectGroup">
            <label class="form-label">Môn học (chỉ áp dụng nếu Scope = PerSubject)</label>
            <select asp-for="SubjectId" asp-items="ViewBag.Subjects" class="form-select">
                <option value="">-- Chọn môn học --</option>
            </select>
        </div>

        <div class="col-12">
            <button type="submit" class="btn btn-primary">💾 Lưu cấu hình</button>
        </div>
    </form>
</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const scopeSelect = document.getElementById('scopeSelect');
            const subjectGroup = document.getElementById('subjectGroup');

            function toggleSubjectGroup() {
                // Giá trị enum ChunkingScope: Global = "0", PerSubject = "1"
                subjectGroup.style.display = scopeSelect.value === "1" ? "" : "none";
            }

            scopeSelect.addEventListener('change', toggleSubjectGroup);
            toggleSubjectGroup();
        });
    </script>
}