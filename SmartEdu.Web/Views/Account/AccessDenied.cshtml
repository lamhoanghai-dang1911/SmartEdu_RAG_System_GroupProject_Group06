@{
    ViewData["Title"] = "Access denied";
    var message = ViewBag.Message as string ?? "You don't have permission to view this page.";
}
<div class="app-content-inner">
    <div class="surface-card text-center py-5">
        <div class="kpi-icon bg-pink mx-auto mb-3" style="width:72px;height:72px;font-size:2rem;">
            <i class="bi bi-shield-lock"></i>
        </div>
        <div class="section-eyebrow mb-1">403 · Forbidden</div>
        <h1 class="page-head-title">Access denied</h1>
        <p class="text-muted mb-4">@message</p>
        <div class="d-flex justify-content-center gap-2 flex-wrap">
            <a class="btn btn-primary btn-icon" asp-controller="Home" asp-action="Index">
                <i class="bi bi-house"></i> Back to home
            </a>
            <a class="btn btn-light btn-icon" asp-controller="Account" asp-action="ChangePassword">
                <i class="bi bi-key"></i> Change password
            </a>
        </div>
    </div>
</div>