@model LoginViewModel
@{
    ViewData["Title"] = "Sign in";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] · SmartEdu</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Sora:wght@600;700;800&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="auth-body">
    <div class="auth-shell">
        <div class="auth-card">
            @* LEFT side: brand + features *@
            <div class="auth-card-side d-none d-md-flex">
                <a class="auth-brand-mark" asp-controller="Home" asp-action="Index">
                    <span class="mark"><i class="bi bi-mortarboard-fill"></i></span>
                    <span class="name">SmartEdu</span>
                </a>
                <div class="auth-illustration" aria-hidden="true">
                    <div class="orb orb-a"></div>
                    <div class="orb orb-b"></div>
                    <div class="orb orb-c"></div>
                    <div class="orb orb-d"></div>
                </div>
                <h2>Learn smarter,<br />with answers you can cite.</h2>
                <p>Upload your course materials, ask anything, and get grounded answers from your own documents.</p>
                <ul>
                    <li><i class="bi bi-check2-circle"></i> RAG-powered chatbot with source citations</li>
                    <li><i class="bi bi-check2-circle"></i> Subject-scoped for lecturers and students</li>
                    <li><i class="bi bi-check2-circle"></i> Pay-as-you-go token plans</li>
                </ul>
                <div class="auth-card-side-foot">&copy; 2026 SmartEdu</div>
            </div>

            @* RIGHT side: form *@
            <div class="auth-card-body">
                <a class="auth-mobile-brand d-md-none" asp-controller="Home" asp-action="Index">
                    <span class="mark"><i class="bi bi-mortarboard-fill"></i></span>
                    <span class="name">SmartEdu</span>
                </a>
                <div class="auth-card-title">Welcome back 👋</div>
                <div class="auth-card-sub">Sign in to continue to SmartEdu.</div>

                <form asp-action="Login" method="post" id="loginForm" novalidate>
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger small mb-3" role="alert"></div>

                    <div class="mb-3">
                        <label class="form-label" asp-for="Username">Username</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-person"></i></span>
                            <input class="form-control" asp-for="Username" placeholder="Enter your username" autocomplete="username" required />
                        </div>
                        <span asp-validation-for="Username" class="text-danger small"></span>
                    </div>

                    <div class="mb-2">
                        <label class="form-label" asp-for="Password">Password</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-shield-lock"></i></span>
                            <input class="form-control" asp-for="Password" id="passwordInput" type="password" placeholder="Enter your password" autocomplete="current-password" required />
                            <button type="button" class="btn btn-light border" id="togglePass" aria-label="Toggle password visibility">
                                <i class="bi bi-eye"></i>
                            </button>
                        </div>
                        <span asp-validation-for="Password" class="text-danger small"></span>
                    </div>

                    <button type="submit" class="btn btn-primary w-100 mt-3" id="loginBtn">
                        <i class="bi bi-box-arrow-in-right me-1"></i> Sign in
                    </button>
                </form>

                <div class="auth-hint text-center mt-3 small text-muted">
                    Need help? Contact your <strong>administrator</strong> for an account.
                </div>
            </div>
        </div>
    </div>

    <style>
        .auth-body { background: var(--ink-50); }
        .auth-brand-mark { display: inline-flex; align-items: center; gap: 0.6rem; color: #fff !important; text-decoration: none; }
        .auth-brand-mark .mark { width: 38px; height: 38px; border-radius: 10px; background: rgba(255,255,255,0.18); color: #fff; display: inline-flex; align-items: center; justify-content: center; }
        .auth-brand-mark .name { font-family: var(--font-display); font-weight: 800; font-size: 1.2rem; }
        .auth-mobile-brand { display: inline-flex; align-items: center; gap: 0.6rem; color: var(--ink-900); text-decoration: none; margin-bottom: 1.25rem; }
        .auth-mobile-brand .mark { width: 36px; height: 36px; border-radius: 10px; background: linear-gradient(135deg, var(--brand-blue), var(--brand-purple)); color: #fff; display: inline-flex; align-items: center; justify-content: center; }
        .auth-mobile-brand .name { font-family: var(--font-display); font-weight: 800; font-size: 1.05rem; }
        .auth-card-side-foot { margin-top: auto; font-size: 0.85rem; color: rgba(255,255,255,0.6); }

        .auth-illustration { position: relative; height: 140px; margin: 0.5rem 0 1rem; }
        .auth-illustration .orb { position: absolute; border-radius: 50%; opacity: 0.85; filter: blur(0.5px); }
        .auth-illustration .orb-a { width: 60px; height: 60px; left: 10%; top: 30%; background: rgba(255,255,255,0.5); animation: floatA 6s ease-in-out infinite; }
        .auth-illustration .orb-b { width: 40px; height: 40px; right: 15%; top: 10%; background: rgba(255,182,72,0.85); animation: floatB 7s ease-in-out infinite; }
        .auth-illustration .orb-c { width: 80px; height: 80px; right: 5%; bottom: 0; background: rgba(255,255,255,0.35); animation: floatA 8s ease-in-out -2s infinite; }
        .auth-illustration .orb-d { width: 28px; height: 28px; left: 50%; bottom: 10%; background: rgba(255,106,169,0.85); animation: floatB 5s ease-in-out -1s infinite; }
        @@keyframes floatA { 0%,100% { transform: translateY(0); } 50% { transform: translateY(-12px); } }
        @@keyframes floatB { 0%,100% { transform: translateY(0); } 50% { transform: translateY(-8px); } }
    </style>

    <script>
        (function () {
            var btn = document.getElementById('togglePass');
            var input = document.getElementById('passwordInput');
            if (btn && input) {
                btn.addEventListener('click', function () {
                    var isPass = input.getAttribute('type') === 'password';
                    input.setAttribute('type', isPass ? 'text' : 'password');
                    btn.innerHTML = isPass ? '<i class="bi bi-eye-slash"></i>' : '<i class="bi bi-eye"></i>';
                });
            }
        })();
    </script>
</body>
</html>