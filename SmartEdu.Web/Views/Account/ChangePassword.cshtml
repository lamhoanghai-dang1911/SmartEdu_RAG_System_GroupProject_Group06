@model SmartEdu.Shared.DTOs.ChangePasswordDto
@{
    ViewData["Title"] = "Change password";
}
<div class="app-content-inner">
    <div class="page-head">
        <div>
            <div class="page-head-sub">Account</div>
            <h1 class="page-head-title">Change password</h1>
        </div>
        <a class="btn btn-light btn-icon" asp-controller="Home" asp-action="Index">
            <i class="bi bi-arrow-left"></i> Back
        </a>
    </div>

    <div class="row g-3">
        <div class="col-lg-7">
            <div class="surface-card">
                @if (TempData["Success"] != null)
                {
                    <div class="alert alert-success" data-auto-dismiss="true">@TempData["Success"]</div>
                }
                <form asp-action="ChangePassword" asp-controller="Account" method="post">
                    @Html.AntiForgeryToken()

                    <div class="mb-3">
                        <label class="form-label" asp-for="OldPassword">Current password</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-shield-lock"></i></span>
                            <input class="form-control" asp-for="OldPassword" type="password" autocomplete="current-password" />
                            <button type="button" class="btn btn-light border toggle-pass" data-target="OldPassword" aria-label="Toggle visibility">
                                <i class="bi bi-eye"></i>
                            </button>
                        </div>
                        <span asp-validation-for="OldPassword" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label" asp-for="NewPassword">New password</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-key"></i></span>
                            <input class="form-control" asp-for="NewPassword" type="password" autocomplete="new-password" />
                            <button type="button" class="btn btn-light border toggle-pass" data-target="NewPassword" aria-label="Toggle visibility">
                                <i class="bi bi-eye"></i>
                            </button>
                        </div>
                        <span asp-validation-for="NewPassword" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label" asp-for="ConfirmPassword">Confirm new password</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-check2-square"></i></span>
                            <input class="form-control" asp-for="ConfirmPassword" type="password" autocomplete="new-password" />
                            <button type="button" class="btn btn-light border toggle-pass" data-target="ConfirmPassword" aria-label="Toggle visibility">
                                <i class="bi bi-eye"></i>
                            </button>
                        </div>
                        <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-check2-circle me-1"></i> Update password
                        </button>
                        <a class="btn btn-light" asp-controller="Home" asp-action="Index">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
        <div class="col-lg-5">
            <div class="surface-card">
                <h5 class="mb-2"><i class="bi bi-info-circle me-2 text-info"></i> Password tips</h5>
                <ul class="small text-muted mb-0 ps-3">
                    <li>Use at least 8 characters.</li>
                    <li>Mix uppercase, lowercase and numbers.</li>
                    <li>Avoid using your username or birthday.</li>
                </ul>
            </div>
        </div>
    </div>
</div>

<script>
    document.querySelectorAll('.toggle-pass').forEach(function (btn) {
        btn.addEventListener('click', function () {
            var name = btn.getAttribute('data-target');
            var input = document.querySelector('input[name="' + name + '"]');
            if (!input) return;
            var isPass = input.getAttribute('type') === 'password';
            input.setAttribute('type', isPass ? 'text' : 'password');
            btn.innerHTML = isPass ? '<i class="bi bi-eye-slash"></i>' : '<i class="bi bi-eye"></i>';
        });
    });
</script>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}