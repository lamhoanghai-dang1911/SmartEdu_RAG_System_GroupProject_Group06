@model IEnumerable<SmartEdu.Shared.DTOs.FreeTierConfigDto>
@{
    ViewData["Title"] = "Cấu hình Token miễn phí";
}

<style>
    :root {
        --brand-blue: #0d6efd;
        --brand-purple: #6610f2;
        --ink-navy: #0b1120;
        --slate: #5a6072;
        --success: #1fae63;
        --danger: #e5484d;
    }

    .page-head h2 {
        font-family: 'Sora', sans-serif;
        font-weight: 700;
        font-size: 1.5rem;
        color: #12162b;
        margin: 0;
    }

    .page-head .btn-primary {
        border: none;
        border-radius: 999px;
        background: linear-gradient(120deg, var(--brand-blue), var(--brand-purple));
        font-weight: 600;
        font-size: 0.9rem;
        padding: 0.55rem 1.2rem;
        box-shadow: 0 8px 20px -10px rgba(13, 110, 253, 0.5);
    }

    .alert {
        border: none;
        border-radius: 12px;
    }

    .alert-success {
        background: rgba(31, 174, 99, 0.09);
        color: var(--success);
        border-left: 3px solid var(--success);
    }

    .alert-danger {
        background: rgba(229, 72, 77, 0.08);
        color: var(--danger);
        border-left: 3px solid var(--danger);
    }

    .table-card {
        background: #fff;
        border-radius: 16px;
        box-shadow: 0 10px 32px -12px rgba(11, 17, 32, 0.14);
        overflow: hidden;
    }

    .table thead tr {
        background: linear-gradient(120deg, var(--ink-navy), #171d3d) !important;
    }

    .table thead th {
        border: none !important;
        color: #fff !important;
        font-family: 'Sora', sans-serif;
        font-weight: 600;
        font-size: 0.78rem;
        text-transform: uppercase;
        padding: 0.9rem 1rem !important;
    }

    .table tbody td {
        padding: 0.8rem 1rem !important;
        vertical-align: middle;
    }

    .badge {
        font-weight: 600;
        font-size: 0.74rem;
        padding: 0.4rem 0.65rem;
        border-radius: 999px;
    }

        .badge.bg-success {
            background: rgba(31, 174, 99, 0.12) !important;
            color: var(--success) !important;
        }

        .badge.bg-secondary {
            background: #eef0f6 !important;
            color: var(--slate) !important;
        }
</style>

<div class="container mt-4">
    <div class="page-head d-flex justify-content-between align-items-center mb-3">
        <h2>🎁 Cấu hình Token miễn phí</h2>
        <a asp-action="Create" class="btn btn-primary">➕ Thêm cấu hình mới</a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show">
            @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="table-card">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Token / cửa sổ</th>
                        <th>Độ dài cửa sổ</th>
                        <th>Trạng thái</th>
                        <th>Cập nhật bởi</th>
                        <th>Ngày tạo</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var c in Model.OrderByDescending(c => c.IsActive).ThenByDescending(c => c.CreatedAt))
                    {
                        <tr>
                            <td>@c.Id</td>
                            <td>@c.TokensPerWindow.ToString("N0")</td>
                            <td>@c.WindowHours giờ</td>
                            <td>
                                @if (c.IsActive)
                                {
                                    <span class="badge bg-success">✅ Đang dùng</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">🔁 Đã thay thế</span>
                                }
                            </td>
                            <td>@c.UpdatedByUserName</td>
                            <td>@c.CreatedAt.ToVietnamTime().ToString("dd/MM/yyyy HH:mm")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>