@model (IEnumerable<SmartEdu.Shared.DTOs.UserDto> Enrolled, IEnumerable<SmartEdu.Shared.DTOs.UserDto> NotEnrolled)
@{
    var subject = ViewBag.Subject as SmartEdu.Shared.DTOs.SubjectDto;
    ViewData["Title"] = $"Quản lý lớp: {subject?.Name}";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>👥 Quản lý Sinh viên môn: <span class="text-primary">@subject?.Name</span></h2>
        <a asp-action="Index" class="btn btn-secondary">Quay lại danh sách môn</a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card shadow-sm border-info mb-4">
        <div class="card-header bg-info text-white d-flex justify-content-between align-items-center">
            <h5 class="mb-0">📥 Import danh sách sinh viên (Excel)</h5>
            <a href="~/templates/StudentImportTemplate.xlsx" class="btn btn-sm btn-light" download>Tải file mẫu</a>
        </div>
        <div class="card-body">
            <form asp-action="ImportStudents" method="post" enctype="multipart/form-data" class="row g-3 align-items-center">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" value="@subject?.Id" />
                <div class="col-auto">
                    <input type="file" name="file" class="form-control" accept=".xlsx" required />
                </div>
                <div class="col-auto">
                    <button type="submit" class="btn btn-info text-white">Bắt đầu Import</button>
                </div>
                <div class="col-auto">
                    <small class="text-muted">Chỉ hỗ trợ file .xlsx theo mẫu.</small>
                </div>
            </form>
        </div>
    </div>

    <div class="row">
        <div class="col-md-6">
            <div class="card shadow-sm border-success">
                <div class="card-header bg-success text-white">
                    <h5 class="mb-0">✅ Đang học (@Model.Enrolled.Count())</h5>
                </div>
                <div class="card-body p-0" style="max-height: 500px; overflow-y: auto;">
                    <table class="table table-hover mb-0">
                        <tbody>
                            @if (!Model.Enrolled.Any())
                            {
                                <tr><td class="text-center text-muted py-3">Chưa có sinh viên nào.</td></tr>
                            }
                            @foreach (var student in Model.Enrolled)
                            {
                                <tr>
                                    <td class="align-middle fw-semibold">
                                        @student.FullName <br />
                                        <small class="text-muted">@student.Username</small>
                                    </td>
                                    <td class="table-action-column align-middle px-3">
                                        <div class="dropdown row-actions"><button type="button" class="row-actions-toggle" data-bs-toggle="dropdown" data-bs-auto-close="outside" aria-expanded="false" aria-label="Mở menu thao tác"><i class="bi bi-three-dots"></i></button><ul class="dropdown-menu dropdown-menu-end row-actions-menu"><li>
                                        <form asp-action="RemoveStudent" method="post" onsubmit="return confirm('Xóa sinh viên này khỏi môn học?');">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="subjectId" value="@subject?.Id" />
                                            <input type="hidden" name="studentId" value="@student.Id" />
                                            <button type="submit" class="dropdown-item dropdown-item-danger"><i class="bi bi-person-dash"></i>Xóa khỏi môn học</button>
                                        </form></li></ul></div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card shadow-sm border-secondary">
                <div class="card-header bg-light text-dark">
                    <h5 class="mb-0">➕ Thêm vào lớp (@Model.NotEnrolled.Count())</h5>
                </div>
                <div class="card-body p-0" style="max-height: 500px; overflow-y: auto;">
                    <table class="table table-hover mb-0">
                        <tbody>
                            @if (!Model.NotEnrolled.Any())
                            {
                                <tr><td class="text-center text-muted py-3">Tất cả sinh viên đã được thêm vào môn này.</td></tr>
                            }
                            @foreach (var student in Model.NotEnrolled)
                            {
                                <tr>
                                    <td class="align-middle fw-semibold">
                                        @student.FullName <br />
                                        <small class="text-muted">@student.Username</small>
                                    </td>
                                    <td class="table-action-column align-middle px-3">
                                        <div class="dropdown row-actions"><button type="button" class="row-actions-toggle" data-bs-toggle="dropdown" data-bs-auto-close="outside" aria-expanded="false" aria-label="Mở menu thao tác"><i class="bi bi-three-dots"></i></button><ul class="dropdown-menu dropdown-menu-end row-actions-menu"><li>
                                        <form asp-action="AssignStudent" method="post">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="subjectId" value="@subject?.Id" />
                                            <input type="hidden" name="studentId" value="@student.Id" />
                                            <button type="submit" class="dropdown-item"><i class="bi bi-person-plus"></i>Thêm vào môn học</button>
                                        </form></li></ul></div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
