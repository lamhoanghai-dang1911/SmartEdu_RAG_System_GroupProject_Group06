@model SmartEdu.Shared.DTOs.SubjectCreateDto
@{
    ViewData["Title"] = "New subject";
}
<div class="app-content-inner">
    <div class="page-head">
        <div>
            <div class="page-head-sub">Catalog</div>
            <h1 class="page-head-title"><i class="bi bi-plus-circle me-2"></i>New subject</h1>
            <div class="page-head-sub mt-1">Create a subject that lecturers and students can join.</div>
        </div>
        <a class="btn btn-light btn-icon" asp-action="Index">
            <i class="bi bi-arrow-left"></i> Back
        </a>
    </div>

    <div class="row g-3">
        <div class="col-lg-7">
            <div class="surface-card">
                <form asp-action="Create" method="post">
                    @Html.AntiForgeryToken()

                    <div class="mb-3">
                        <label asp-for="Name" class="form-label">Subject name</label>
                        <input asp-for="Name" class="form-control" placeholder="e.g. .NET Programming" />
                        <span asp-validation-for="Name" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Description" class="form-label">Description</label>
                        <textarea asp-for="Description" class="form-control" rows="4" placeholder="What is this subject about?"></textarea>
                        <span asp-validation-for="Description" class="text-danger small"></span>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-check2-circle me-1"></i> Save
                        </button>
                        <a class="btn btn-light" asp-action="Index">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
        <div class="col-lg-5">
            <div class="surface-card">
                <h5 class="mb-2"><i class="bi bi-info-circle me-2 text-info"></i> Tips</h5>
                <ul class="small text-muted ps-3 mb-0">
                    <li>Give the subject a clear, searchable name.</li>
                    <li>Use the description to set expectations for students.</li>
                    <li>You can assign lecturers and enroll students from the subject's detail page.</li>
                </ul>
            </div>
        </div>
    </div>
</div>