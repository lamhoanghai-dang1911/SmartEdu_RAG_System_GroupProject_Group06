@{
    ViewData["Title"] = "Báo cáo của tôi";
}

<style>
    :root {
        --brand-blue: #0d6efd;
        --brand-purple: #6610f2;
        --ink-navy: #0b1120;
        --amber: #ffb648;
        --paper: #f7f8fc;
        --slate: #5a6072;
        --slate-light: #9aa0b4;
        --success: #1fae63;
        --danger: #e5484d;
        --warning: #f5a623;
    }

    @@keyframes fadeUp {
        from {
            opacity: 0;
            transform: translateY(12px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .page-head h2 {
        font-family: 'Sora', sans-serif;
        font-weight: 700;
        font-size: 1.5rem;
        color: #12162b;
        margin: 0;
    }

    /* ===== Filter bar ===== */
    .filter-bar {
        background: #fff;
        border-radius: 14px;
        padding: 1rem 1.2rem;
        box-shadow: 0 6px 20px -12px rgba(11, 17, 32, 0.12);
        margin-bottom: 1.25rem;
        opacity: 0;
        animation: fadeUp 0.45s ease forwards;
    }

        .filter-bar .form-label {
            font-size: 0.78rem;
            font-weight: 600;
            color: var(--slate);
            text-transform: uppercase;
            letter-spacing: 0.03em;
            margin-bottom: 0.35rem;
        }

        .filter-bar .form-control {
            border: 1.5px solid #e3e5ef;
            border-radius: 10px;
            transition: border-color 0.2s ease, box-shadow 0.2s ease;
        }

            .filter-bar .form-control:focus {
                border-color: var(--brand-blue);
                box-shadow: 0 0 0 4px rgba(13, 110, 253, 0.12);
            }

    /* ===== Quick range segmented control ===== */
    #quickRangeGroup {
        display: inline-flex;
        background: var(--paper);
        border-radius: 999px;
        padding: 3px;
        gap: 2px;
    }

        #quickRangeGroup .btn {
            border: none !important;
            background: transparent !important;
            color: var(--slate) !important;
            font-size: 0.85rem;
            font-weight: 600;
            padding: 0.5rem 1rem;
            border-radius: 999px !important;
            box-shadow: none !important;
            transition: background 0.18s ease, color 0.18s ease, box-shadow 0.18s ease;
        }

            #quickRangeGroup .btn:hover:not(.active) {
                color: #12162b !important;
            }

            #quickRangeGroup .btn.active,
            #quickRangeGroup .btn.btn-primary {
                background: linear-gradient(120deg, var(--brand-blue), var(--brand-purple)) !important;
                color: #fff !important;
                box-shadow: 0 4px 12px -4px rgba(13, 110, 253, 0.5) !important;
            }

    /* ===== KPI chip (gọn, nằm chung hàng filter) ===== */
    .kpi-chip {
        display: flex;
        align-items: center;
        gap: 0.7rem;
        background: linear-gradient(135deg, var(--brand-blue), var(--brand-purple));
        border-radius: 12px;
        padding: 0.55rem 1.1rem;
        color: #fff;
        white-space: nowrap;
    }

        .kpi-chip .kpi-chip-icon {
            font-size: 1.2rem;
            line-height: 1;
        }

        .kpi-chip .kpi-chip-label {
            font-size: 0.72rem;
            opacity: 0.85;
            font-weight: 600;
            line-height: 1.1;
        }

        .kpi-chip .kpi-chip-value {
            font-family: 'Sora', sans-serif;
            font-weight: 800;
            font-size: 1.15rem;
            line-height: 1.1;
        }

    /* ===== Report cards ===== */
    .report-card {
        border: none !important;
        border-radius: 16px !important;
        box-shadow: 0 10px 30px -16px rgba(11, 17, 32, 0.16);
        opacity: 0;
        animation: fadeUp 0.5s ease forwards;
        animation-delay: 0.1s;
    }

        .report-card h6 {
            font-family: 'Sora', sans-serif;
            font-weight: 700;
            font-size: 0.98rem;
            color: #12162b;
            margin: 0;
        }

    .report-header {
        min-height: 32px;
    }

    .total-spent-tag {
        font-size: 0.9rem;
        color: #33384f;
    }

        .total-spent-tag .amount {
            font-family: 'Sora', sans-serif;
            font-weight: 800;
            color: var(--brand-blue);
            font-size: 1.05rem;
        }

    .table {
        margin-bottom: 0;
    }

        .table thead tr {
            background: linear-gradient(120deg, var(--ink-navy), #171d3d) !important;
        }

        .table thead th {
            border: none !important;
            color: #fff !important;
            font-family: 'Sora', sans-serif;
            font-weight: 600;
            font-size: 0.76rem;
            letter-spacing: 0.03em;
            text-transform: uppercase;
            padding: 0.8rem 0.9rem !important;
        }

        .table tbody tr {
            transition: background 0.15s ease;
        }

            .table tbody tr:hover {
                background: rgba(13, 110, 253, 0.045) !important;
            }

        .table tbody td {
            border-color: #eef0f6 !important;
            padding: 0.7rem 0.9rem !important;
            font-size: 0.88rem;
            color: #33384f;
        }

    .badge {
        font-weight: 600;
        font-size: 0.74rem;
        padding: 0.4rem 0.7rem;
        border-radius: 999px;
    }

        .badge.bg-success {
            background: rgba(31, 174, 99, 0.12) !important;
            color: var(--success) !important;
        }

        .badge.bg-warning {
            background: rgba(245, 166, 35, 0.14) !important;
            color: #b8790a !important;
        }

        .badge.bg-danger {
            background: rgba(229, 72, 77, 0.1) !important;
            color: var(--danger) !important;
        }

        .badge.bg-secondary {
            background: #eef0f6 !important;
            color: var(--slate) !important;
        }

    @@media (prefers-reduced-motion: reduce) {
        *, *::before, *::after {
            animation-duration: 0.01ms !important;
            transition-duration: 0.01ms !important;
        }
    }
</style>

<div class="container mt-4">
    <div class="page-head d-flex justify-content-between align-items-center mb-3">
        <h2>📊 Báo cáo sử dụng của tôi</h2>
    </div>

    <div class="filter-bar d-flex flex-wrap gap-3 align-items-end justify-content-between">
        <div class="d-flex flex-wrap gap-3 align-items-end">
            <div class="btn-group" role="group" id="quickRangeGroup">
                <button id="btnToday" class="btn btn-outline-primary" data-range="today">Hôm nay</button>
                <button id="btnWeek" class="btn btn-outline-primary" data-range="week">Tuần này</button>
                <button id="btnMonth" class="btn btn-outline-primary" data-range="month">Tháng này</button>
            </div>
            <div>
                <label class="form-label d-block">Từ ngày</label>
                <input type="date" id="start" class="form-control" />
            </div>
            <div>
                <label class="form-label d-block">Đến ngày</label>
                <input type="date" id="end" class="form-control" />
            </div>
        </div>

        <div class="kpi-chip">
            <span class="kpi-chip-icon">🎫</span>
            <div>
                <div class="kpi-chip-label">Tổng token đã sử dụng</div>
                <div class="kpi-chip-value" id="kpiTotal">0</div>
            </div>
        </div>
    </div>

    <div class="card report-card mb-4">
        <div class="card-body">
            <div class="report-header mb-3">
                <h6>📋 Chi tiết token đã sử dụng</h6>
            </div>
            <table class="table table-hover" id="usageTable">
                <thead>
                    <tr><th>Prompt tokens</th><th>Completion tokens</th><th>Tổng</th></tr>
                </thead>
                <tbody></tbody>
            </table>
        </div>
    </div>

    <!-- Lịch sử đơn hàng / gói đã mua -->
    <div class="card report-card">
        <div class="card-body">
            <div class="report-header d-flex justify-content-between align-items-center mb-3">
                <h6>🧾 Lịch sử mua gói</h6>
                <div class="total-spent-tag">Tổng chi tiêu: <span class="amount" id="kpiTotalSpent">0 đ</span></div>
            </div>
            <table class="table table-hover" id="ordersTable">
                <thead>
                    <tr>
                        <th>Mã đơn</th>
                        <th>Gói</th>
                        <th>Số tiền</th>
                        <th>Trạng thái</th>
                        <th>Ngày tạo</th>
                        <th>Ngày thanh toán</th>
                    </tr>
                </thead>
                <tbody></tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const fmt = n => new Intl.NumberFormat('vi-VN').format(n);
        const fmtCurrency = n => fmt(n) + ' đ';

        const statusLabels = {
            'Success': '<span class="badge bg-success">Thành công</span>',
            'Pending': '<span class="badge bg-warning">Chờ xử lý</span>',
            'Failed': '<span class="badge bg-danger">Thất bại</span>',
            'Cancelled': '<span class="badge bg-secondary">Đã huỷ</span>'
        };

        // Format ngày theo giờ LOCAL (không dùng toISOString vì nó convert sang UTC,
        // ở VN (UTC+7) sẽ bị lùi mất 1 ngày khi giờ local là nửa đêm).
        function toLocalDateStr(date) {
            const y = date.getFullYear();
            const m = String(date.getMonth() + 1).padStart(2, '0');
            const d = String(date.getDate()).padStart(2, '0');
            return `${y}-${m}-${d}`;
        }

        function setRange(startDate, endDate) {
            document.getElementById('start').value = toLocalDateStr(startDate);
            document.getElementById('end').value = toLocalDateStr(endDate);
        }

        function setActiveQuickButton(activeBtn) {
            document.querySelectorAll('#quickRangeGroup button').forEach(btn => {
                btn.classList.remove('active', 'btn-primary');
                btn.classList.add('btn-outline-primary');
            });
            if (activeBtn) {
                activeBtn.classList.remove('btn-outline-primary');
                activeBtn.classList.add('active', 'btn-primary');
            }
        }

        function clearActiveQuickButton() {
            setActiveQuickButton(null);
        }

        // Trả về ngày Thứ Hai của tuần chứa `date`
        function getMonday(date) {
            const d = new Date(date.getFullYear(), date.getMonth(), date.getDate());
            const day = d.getDay(); // 0 = Chủ Nhật, 1 = Thứ Hai, ... 6 = Thứ Bảy
            const diff = day === 0 ? -6 : 1 - day;
            d.setDate(d.getDate() + diff);
            return d;
        }

        document.getElementById('btnToday').addEventListener('click', e => {
            e.preventDefault();
            const t = new Date();
            const today = new Date(t.getFullYear(), t.getMonth(), t.getDate());
            setRange(today, today);
            setActiveQuickButton(e.currentTarget);
            loadUsage();
        });
        document.getElementById('btnWeek').addEventListener('click', e => {
            e.preventDefault();
            const monday = getMonday(new Date());
            const sunday = new Date(monday);
            sunday.setDate(monday.getDate() + 6);
            setRange(monday, sunday);
            setActiveQuickButton(e.currentTarget);
            loadUsage();
        });
        document.getElementById('btnMonth').addEventListener('click', e => {
            e.preventDefault();
            const now = new Date();
            const first = new Date(now.getFullYear(), now.getMonth(), 1);
            const last = new Date(now.getFullYear(), now.getMonth() + 1, 0);
            setRange(first, last);
            setActiveQuickButton(e.currentTarget);
            loadUsage();
        });

        // Nếu người dùng tự chỉnh ngày thủ công thì bỏ trạng thái active của các nút nhanh
        document.getElementById('start').addEventListener('change', () => {
            clearActiveQuickButton();
            loadUsage();
        });
        document.getElementById('end').addEventListener('change', () => {
            clearActiveQuickButton();
            loadUsage();
        });

        async function loadUsage() {
            try {
                const start = document.getElementById('start').value;
                const end = document.getElementById('end').value;
                const qs = `start=${encodeURIComponent(start)}&end=${encodeURIComponent(end)}`;

                const usageResp = await fetch(`/StudentReports/UsageJson?${qs}`);
                if (!usageResp.ok) {
                    console.error('UsageJson failed:', usageResp.status, await usageResp.text());
                    return;
                }
                const usage = await usageResp.json();
                const item = (usage.items || [])[0] || { totalTokens: 0, promptTokens: 0, completionTokens: 0 };

                document.getElementById('kpiTotal').textContent = fmt(item.totalTokens);

                document.querySelector('#usageTable tbody').innerHTML =
                    `<tr><td>${fmt(item.promptTokens)}</td><td>${fmt(item.completionTokens)}</td><td><strong>${fmt(item.totalTokens)}</strong></td></tr>`;
            } catch (err) {
                console.error('loadUsage error:', err);
            }
        }

        async function loadOrders() {
            try {
                const resp = await fetch('/StudentReports/OrdersJson');
                if (!resp.ok) {
                    console.error('OrdersJson failed:', resp.status, await resp.text());
                    return;
                }
                const data = await resp.json();

                document.getElementById('kpiTotalSpent').textContent = fmtCurrency(data.totalSpent || 0);

                const tbody = document.querySelector('#ordersTable tbody');
                tbody.innerHTML = '';
                (data.items || []).forEach(o => {
                    const tr = document.createElement('tr');
                    const paidAt = o.paidAt ? new Date(o.paidAt).toLocaleString('vi-VN') : '—';
                    const createdAt = new Date(o.createdAt).toLocaleString('vi-VN');
                    const statusHtml = statusLabels[o.status] || o.status;
                    tr.innerHTML = `<td>#${o.orderId}</td><td>${o.packageName}</td><td>${fmtCurrency(o.amount)}</td><td>${statusHtml}</td><td>${createdAt}</td><td>${paidAt}</td>`;
                    tbody.appendChild(tr);
                });

                if ((data.items || []).length === 0) {
                    tbody.innerHTML = '<tr><td colspan="6" class="text-center text-muted">Chưa có đơn hàng nào</td></tr>';
                }
            } catch (err) {
                console.error('loadOrders error:', err);
            }
        }

        document.addEventListener('DOMContentLoaded', () => {
            const today = new Date();
            const localToday = new Date(today.getFullYear(), today.getMonth(), today.getDate());
            setRange(localToday, localToday);
            setActiveQuickButton(document.getElementById('btnToday'));

            loadUsage();
            loadOrders();
        });
    </script>
}