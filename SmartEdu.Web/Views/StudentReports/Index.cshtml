@{ ViewData["Title"] = "Báo cáo của tôi"; }
<style>
    .student-report{max-width:1250px;margin:0 auto;padding:18px 8px 50px}.sr-head{display:flex;justify-content:space-between;align-items:end;gap:18px;margin-bottom:18px}.sr-head h1{margin:0 0 5px;font-size:27px}.sr-head p{margin:0;color:#67736b;font-size:14px}.sr-filter{display:flex;align-items:end;gap:8px;padding:7px;border:1px solid #dde5df;border-radius:12px;background:#fff}.sr-quick{display:flex;gap:3px;padding:3px;border-radius:8px;background:#f1f5f2}.sr-quick button{height:31px;padding:0 10px;color:#67736b;font-size:11px;font-weight:700;border:0;border-radius:6px;background:transparent}.sr-quick button.active{color:#fff;background:#246b4b}.sr-date label{display:block;margin:0 0 3px 2px;color:#7b867f;font-size:9px;font-weight:750;text-transform:uppercase}.sr-date input{width:136px;height:37px;padding:6px 9px;border:1px solid #d4ddd7;border-radius:8px;background:#fafcfa}.sr-summary{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:12px;margin-bottom:14px}.sr-kpi{padding:17px 18px;border:1px solid #dde5df;border-radius:13px;background:#fff;box-shadow:0 6px 20px rgba(26,57,40,.045)}.sr-kpi-label{margin-bottom:7px;color:#748078;font-size:10px;font-weight:750;letter-spacing:.045em;text-transform:uppercase}.sr-kpi-value{font-size:26px;font-weight:780}.sr-grid{display:grid;grid-template-columns:minmax(290px,.7fr) minmax(0,1.3fr);gap:14px;margin-bottom:14px}.sr-panel{border:1px solid #dde5df;border-radius:14px;background:#fff;overflow:hidden;box-shadow:0 7px 24px rgba(26,57,40,.045)}.sr-panel-head{padding:14px 16px;border-bottom:1px solid #e5ebe7}.sr-panel-head h2{margin:0 0 3px;font-size:14px}.sr-panel-head p{margin:0;color:#87928b;font-size:11px}.token-split{min-height:240px;display:grid;grid-template-columns:140px 1fr;align-items:center;gap:20px;padding:20px}.token-donut{position:relative;width:136px;height:136px;border-radius:50%;background:conic-gradient(#246b4b 0 var(--prompt),#5a7ea8 var(--prompt) 100%)}.token-donut::after{content:"";position:absolute;inset:27px;border-radius:50%;background:#fff}.token-donut-center{position:absolute;inset:0;z-index:1;display:grid;place-content:center;text-align:center}.token-donut-center strong{font-size:18px}.token-donut-center span{color:#87928b;font-size:9px}.split-legend{display:grid;gap:13px}.split-item{display:grid;grid-template-columns:8px 1fr;gap:9px}.split-dot{width:8px;height:8px;margin-top:4px;border-radius:3px;background:var(--dot)}.split-item small{display:block;color:#87928b}.split-item strong{font-size:15px}.table-scroll{overflow:auto}.sr-panel table{margin:0}.sr-panel th{padding:11px 14px!important;background:#f7f9f7!important}.sr-panel td{padding:11px 14px!important;font-size:12px}.empty-chart{min-height:240px;display:grid;place-items:center;color:#87928b;font-size:12px}@@media(max-width:950px){.sr-head{align-items:flex-start;flex-direction:column}.sr-filter{width:100%;flex-wrap:wrap}.sr-grid{grid-template-columns:1fr}}@@media(max-width:650px){.sr-summary{grid-template-columns:1fr}.sr-date{flex:1}.sr-date input{width:100%}.sr-quick{width:100%}.sr-quick button{flex:1}.token-split{grid-template-columns:1fr;justify-items:center}.split-legend{width:100%}}
</style>
<main class="student-report">
    <header class="sr-head"><div><h1>Báo cáo sử dụng</h1><p>Theo dõi token và lịch sử mua gói của tài khoản.</p></div><div class="sr-filter"><div class="sr-quick"><button id="btnToday" class="active">Hôm nay</button><button id="btnWeek">Tuần này</button><button id="btnMonth">Tháng này</button></div><div class="sr-date"><label for="start">Từ ngày</label><input type="date" id="start"/></div><div class="sr-date"><label for="end">Đến ngày</label><input type="date" id="end"/></div></div></header>
    <section class="sr-summary"><article class="sr-kpi"><div class="sr-kpi-label">Tổng token</div><div class="sr-kpi-value" id="kpiTotal">0</div></article><article class="sr-kpi"><div class="sr-kpi-label">Tổng chi tiêu</div><div class="sr-kpi-value" id="kpiTotalSpent">0 đ</div></article><article class="sr-kpi"><div class="sr-kpi-label">Số đơn hàng</div><div class="sr-kpi-value" id="kpiOrderCount">0</div></article></section>
    <section class="sr-grid"><article class="sr-panel"><header class="sr-panel-head"><h2>Cơ cấu token</h2><p>Tỷ lệ prompt và completion token</p></header><div id="tokenChart"></div></article><article class="sr-panel"><header class="sr-panel-head"><h2>Chi tiết token</h2><p>Số liệu trong khoảng thời gian đã chọn</p></header><div class="table-scroll"><table class="table table-hover" id="usageTable"><thead><tr><th>Prompt token</th><th>Completion token</th><th>Tổng</th></tr></thead><tbody></tbody></table></div></article></section>
    <section class="sr-panel"><header class="sr-panel-head"><h2>Lịch sử mua gói</h2><p>Các giao dịch đã phát sinh trên tài khoản</p></header><div class="table-scroll"><table class="table table-hover" id="ordersTable"><thead><tr><th>Mã đơn</th><th>Gói</th><th>Số tiền</th><th>Trạng thái</th><th>Ngày tạo</th><th>Ngày thanh toán</th></tr></thead><tbody></tbody></table></div></section>
</main>
@section Scripts{
<script>
const fmt=n=>new Intl.NumberFormat('vi-VN').format(Number(n)||0),fmtCurrency=n=>`${fmt(n)} đ`;const statusLabels={Success:'<span class="badge bg-success">Thành công</span>',Pending:'<span class="badge bg-warning">Chờ xử lý</span>',Failed:'<span class="badge bg-danger">Thất bại</span>',Cancelled:'<span class="badge bg-secondary">Đã hủy</span>'};
function localDate(date){return `${date.getFullYear()}-${String(date.getMonth()+1).padStart(2,'0')}-${String(date.getDate()).padStart(2,'0')}`}function setRange(start,end){document.getElementById('start').value=localDate(start);document.getElementById('end').value=localDate(end)}function activate(button){document.querySelectorAll('.sr-quick button').forEach(x=>x.classList.remove('active'));button?.classList.add('active')}function escapeHtml(v){return String(v??'').replaceAll('&','&amp;').replaceAll('<','&lt;').replaceAll('>','&gt;').replaceAll('"','&quot;').replaceAll("'",'&#039;')}
function renderToken(item){const total=Number(item.totalTokens)||0,prompt=Number(item.promptTokens)||0,completion=Number(item.completionTokens)||0,promptPercent=total?prompt/total*100:50;document.getElementById('kpiTotal').textContent=fmt(total);document.querySelector('#usageTable tbody').innerHTML=`<tr><td>${fmt(prompt)}</td><td>${fmt(completion)}</td><td><strong>${fmt(total)}</strong></td></tr>`;document.getElementById('tokenChart').innerHTML=total?`<div class="token-split"><div class="token-donut" style="--prompt:${promptPercent}%"><div class="token-donut-center"><strong>${fmt(total)}</strong><span>token</span></div></div><div class="split-legend"><div class="split-item"><span class="split-dot" style="--dot:#246b4b"></span><div><small>Prompt token</small><strong>${fmt(prompt)}</strong></div></div><div class="split-item"><span class="split-dot" style="--dot:#5a7ea8"></span><div><small>Completion token</small><strong>${fmt(completion)}</strong></div></div></div></div>`:'<div class="empty-chart">Chưa có dữ liệu sử dụng token.</div>'}
async function loadUsage(){try{const startDate=document.getElementById('start').value,endDate=document.getElementById('end').value,qs=`start=${encodeURIComponent(startDate)}&end=${encodeURIComponent(endDate)}`,response=await fetch(`/StudentReports/UsageJson?${qs}`);if(!response.ok)throw new Error();const data=await response.json();renderToken((data.items||[])[0]||{totalTokens:0,promptTokens:0,completionTokens:0})}catch{document.getElementById('tokenChart').innerHTML='<div class="empty-chart">Không thể tải dữ liệu.</div>'}}
async function loadOrders(){const response=await fetch('/StudentReports/OrdersJson'),data=await response.json(),items=data.items||[];document.getElementById('kpiTotalSpent').textContent=fmtCurrency(data.totalSpent);document.getElementById('kpiOrderCount').textContent=fmt(items.length);document.querySelector('#ordersTable tbody').innerHTML=items.length?items.map(o=>`<tr><td>#${o.orderId}</td><td>${escapeHtml(o.packageName)}</td><td>${fmtCurrency(o.amount)}</td><td>${statusLabels[o.status]||escapeHtml(o.status)}</td><td>${new Date(o.createdAt).toLocaleString('vi-VN')}</td><td>${o.paidAt?new Date(o.paidAt).toLocaleString('vi-VN'):'—'}</td></tr>`).join(''):'<tr><td colspan="6" class="text-center text-muted">Chưa có đơn hàng</td></tr>'}
document.addEventListener('DOMContentLoaded',()=>{const todayButton=document.getElementById('btnToday'),weekButton=document.getElementById('btnWeek'),monthButton=document.getElementById('btnMonth'),today=new Date();setRange(today,today);todayButton.onclick=()=>{const d=new Date();setRange(d,d);activate(todayButton);loadUsage()};weekButton.onclick=()=>{const end=new Date(),start=new Date();start.setDate(end.getDate()-6);setRange(start,end);activate(weekButton);loadUsage()};monthButton.onclick=()=>{const now=new Date();setRange(new Date(now.getFullYear(),now.getMonth(),1),new Date(now.getFullYear(),now.getMonth()+1,0));activate(monthButton);loadUsage()};document.getElementById('start').onchange=document.getElementById('end').onchange=()=>{activate(null);loadUsage()};loadUsage();loadOrders()});
</script>}
