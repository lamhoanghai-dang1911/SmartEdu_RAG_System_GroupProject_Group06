@{
    ViewData["Title"] = "Thanh toán thành công";
}
<div class="container mt-5" style="max-width:520px;">
    <div class="text-center p-5 rounded-4 bg-white" style="box-shadow:0 10px 30px rgba(0,0,0,.08);">
        <div style="width:72px;height:72px;margin:0 auto 20px;border-radius:50%;background:#e8f5e9;display:flex;align-items:center;justify-content:center;">
            <i class="bi bi-check-lg" style="font-size:2.2rem;color:#2e7d32;"></i>
        </div>
        <h2 style="font-weight:800;color:#1b5e20;">Thanh toán thành công!</h2>
        <p class="text-muted mb-4">Gói dịch vụ đã được kích hoạt.<br>Vui lòng đăng nhập lại để sử dụng.</p>
        <a href="/Account/Login" class="btn btn-success btn-lg rounded-pill w-100 mb-2">
            <i class="bi bi-box-arrow-in-right me-2"></i>Đăng nhập
        </a>
    </div>
</div>