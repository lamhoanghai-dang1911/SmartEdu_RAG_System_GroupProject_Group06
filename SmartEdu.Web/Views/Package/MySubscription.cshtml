@model IEnumerable<SmartEdu.Shared.DTOs.UserSubscriptionDto>
@{
    ViewData["Title"] = "Gói dịch vụ của tôi";
    var subscriptions = Model?.OrderByDescending(x => x.StartDate).ToList() ?? new List<SmartEdu.Shared.DTOs.UserSubscriptionDto>();
    var activeSubscriptions = subscriptions.Where(x => x.Status == SmartEdu.Shared.Enums.SubscriptionStatus.Active).ToList();
    var totalRemainingTokens = activeSubscriptions.Sum(x => x.RemainingTokenQuota);
}
<style>
    .subscription-page{max-width:1180px;margin:0 auto;padding:18px 8px 52px}.subscription-head{display:flex;align-items:end;justify-content:space-between;gap:18px;margin-bottom:18px}.subscription-head h1{margin:0 0 5px;font-size:27px}.subscription-head p{margin:0;color:#67736b;font-size:14px}.subscription-summary{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:12px;margin-bottom:18px}.subscription-stat{padding:17px 18px;border:1px solid #dde5df;border-radius:13px;background:#fff}.subscription-stat span{display:block;margin-bottom:7px;color:#748078;font-size:10px;font-weight:750;text-transform:uppercase;letter-spacing:.045em}.subscription-stat strong{font-size:24px}.subscription-list{display:grid;gap:11px}.subscription-row{display:grid;grid-template-columns:minmax(180px,1fr) repeat(3,minmax(130px,.72fr)) auto;align-items:center;gap:18px;padding:17px 18px;border:1px solid #dde5df;border-radius:14px;background:#fff;box-shadow:0 6px 20px rgba(26,57,40,.04);transition:transform .18s ease,box-shadow .18s ease}.subscription-row:hover{transform:translateY(-2px);box-shadow:0 10px 26px rgba(26,57,40,.075)}.subscription-name{min-width:0}.subscription-name h2{margin:0 0 6px;font-size:16px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}.subscription-meta-label{display:block;margin-bottom:3px;color:#87928b;font-size:10px;text-transform:uppercase;letter-spacing:.035em}.subscription-meta-value{font-size:13px;font-weight:680}.subscription-token{color:#194d37;font-size:18px;font-weight:780}.subscription-status{justify-self:end}.empty-subscription{padding:60px 24px;text-align:center;border:1px solid #dde5df;border-radius:15px;background:#fff}.empty-subscription h2{margin:0 0 7px;font-size:18px}.empty-subscription p{margin:0 0 18px;color:#67736b}.subscription-alerts{margin-bottom:14px}@@media(max-width:900px){.subscription-row{grid-template-columns:1fr 1fr}.subscription-status{justify-self:start}.subscription-name{grid-column:1/-1}}@@media(max-width:600px){.subscription-head{align-items:flex-start;flex-direction:column}.subscription-summary{grid-template-columns:1fr}.subscription-row{grid-template-columns:1fr}.subscription-name{grid-column:auto}}
</style>
<main class="subscription-page">
    <header class="subscription-head"><div><h1>Gói dịch vụ của tôi</h1><p>Theo dõi thời hạn và số token còn lại của từng gói.</p></div><a asp-action="List" class="btn btn-primary">Xem các gói dịch vụ</a></header>
    <div class="subscription-alerts">@if(TempData["Success"]!=null){<div class="alert alert-success alert-dismissible fade show">@TempData["Success"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>}@if(TempData["Error"]!=null){<div class="alert alert-danger alert-dismissible fade show">@TempData["Error"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>}</div>
    @if(!subscriptions.Any()){
        <section class="empty-subscription"><h2>Chưa có gói dịch vụ</h2><p>Chọn một gói phù hợp để bắt đầu sử dụng các tính năng của SmartEdu.</p><a asp-action="List" class="btn btn-primary">Xem gói dịch vụ</a></section>
    }else{
        <section class="subscription-summary"><article class="subscription-stat"><span>Gói đang hoạt động</span><strong>@activeSubscriptions.Count</strong></article><article class="subscription-stat"><span>Tổng token còn lại</span><strong>@totalRemainingTokens.ToString("N0")</strong></article><article class="subscription-stat"><span>Tổng số gói đã mua</span><strong>@subscriptions.Count</strong></article></section>
        <section class="subscription-list" aria-label="Danh sách gói dịch vụ">
        @foreach(var sub in subscriptions){
            var daysRemaining=(sub.EndDate-DateTime.UtcNow).Days;
            var statusText=sub.Status==SmartEdu.Shared.Enums.SubscriptionStatus.Active?"Đang hoạt động":sub.Status==SmartEdu.Shared.Enums.SubscriptionStatus.Expired?"Hết hạn":"Đã hủy";
            var statusClass=sub.Status==SmartEdu.Shared.Enums.SubscriptionStatus.Active?"success":sub.Status==SmartEdu.Shared.Enums.SubscriptionStatus.Expired?"secondary":"danger";
            <article class="subscription-row"><div class="subscription-name"><h2>@sub.PackageName</h2><span class="badge bg-@statusClass">@statusText</span></div><div><span class="subscription-meta-label">Token còn lại</span><strong class="subscription-token">@sub.RemainingTokenQuota.ToString("N0")</strong></div><div><span class="subscription-meta-label">Ngày bắt đầu</span><span class="subscription-meta-value">@sub.StartDate.ToVietnamTime().ToString("dd/MM/yyyy")</span></div><div><span class="subscription-meta-label">Ngày kết thúc</span><span class="subscription-meta-value">@sub.EndDate.ToVietnamTime().ToString("dd/MM/yyyy")</span></div><div class="subscription-status">@if(sub.Status==SmartEdu.Shared.Enums.SubscriptionStatus.Expired&&daysRemaining<=0){<a asp-action="List" class="btn btn-outline-primary btn-sm">Gia hạn</a>}else if(daysRemaining>0){<span class="text-muted small">Còn @daysRemaining ngày</span>}</div></article>
        }
        </section>
    }
</main>
@section Scripts{
<script src="https://cdn.jsdelivr.net/npm/@@microsoft/signalr@8.0.0/dist/browser/signalr.min.js"></script>
<script>document.addEventListener('DOMContentLoaded',async()=>{const connection=new signalR.HubConnectionBuilder().withUrl('/hubs/notifications').withAutomaticReconnect().build();connection.on('PaymentCompleted',()=>location.reload());try{await connection.start()}catch(error){console.error('Không thể kết nối thông báo realtime:',error)}});</script>
}
