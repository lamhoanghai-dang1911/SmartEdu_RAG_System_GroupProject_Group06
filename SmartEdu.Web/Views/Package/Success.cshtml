@model SmartEdu.Shared.DTOs.UserSubscriptionDto
@{
    ViewData["Title"] = "Thanh toán thành công";
}

<style>
    :root {
        --brand-blue: #0d6efd;
        --brand-purple: #6610f2;
        --ink-navy: #0b1120;
        --amber: #ffb648;
        --paper: #f7f8fc;
        --slate: #5a6072;
        --slate-light: #9aa0b4;
        --success: #1fae63;
    }

    @@keyframes fadeUp {
        from {
            opacity: 0;
            transform: translateY(14px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @@keyframes popIn {
        0% {
            opacity: 0;
            transform: scale(0.4);
        }

        60% {
            opacity: 1;
            transform: scale(1.12);
        }

        100% {
            opacity: 1;
            transform: scale(1);
        }
    }

    @@keyframes ringPulse {
        0% {
            box-shadow: 0 0 0 0 rgba(31, 174, 99, 0.35);
        }

        100% {
            box-shadow: 0 0 0 22px rgba(31, 174, 99, 0);
        }
    }

    @@keyframes confettiFall {
        0% {
            transform: translateY(-20px) rotate(0deg);
            opacity: 1;
        }

        100% {
            transform: translateY(160px) rotate(360deg);
            opacity: 0;
        }
    }

    .success-card {
        position: relative;
        background: #fff;
        border-radius: 20px;
        box-shadow: 0 16px 44px -16px rgba(11, 17, 32, 0.2);
        padding: 2.5rem 2rem;
        text-align: center;
        overflow: hidden;
        opacity: 0;
        animation: fadeUp 0.45s ease forwards;
    }

    .confetti-piece {
        position: absolute;
        top: 0;
        width: 8px;
        height: 8px;
        border-radius: 2px;
        animation: confettiFall 1.8s ease-in forwards;
    }

    .success-icon-wrap {
        position: relative;
        width: 90px;
        height: 90px;
        margin: 0 auto 1.25rem;
        border-radius: 50%;
        background: rgba(31, 174, 99, 0.1);
        display: flex;
        align-items: center;
        justify-content: center;
        animation: popIn 0.55s cubic-bezier(0.34, 1.56, 0.64, 1) forwards, ringPulse 1.8s ease-out 0.5s;
    }

        .success-icon-wrap .icon {
            font-size: 2.6rem;
            line-height: 1;
        }

    .success-card h2 {
        font-family: 'Sora', sans-serif;
        font-weight: 800;
        font-size: 1.65rem;
        color: #12162b;
        margin-bottom: 0.6rem;
        opacity: 0;
        animation: fadeUp 0.5s ease forwards;
        animation-delay: 0.15s;
    }

    .success-card .subtext {
        color: var(--slate);
        font-size: 0.95rem;
        margin-bottom: 1.75rem;
        opacity: 0;
        animation: fadeUp 0.5s ease forwards;
        animation-delay: 0.2s;
    }

    .package-info-panel {
        text-align: left;
        background: var(--paper);
        border-radius: 14px;
        padding: 1.3rem 1.4rem;
        margin-bottom: 1.5rem;
        opacity: 0;
        animation: fadeUp 0.5s ease forwards;
        animation-delay: 0.25s;
    }

        .package-info-panel h5 {
            font-family: 'Sora', sans-serif;
            font-weight: 700;
            font-size: 1rem;
            color: #12162b;
            margin-bottom: 0.9rem;
        }

    .info-row {
        display: flex;
        align-items: center;
        gap: 0.65rem;
        padding: 0.5rem 0;
        font-size: 0.9rem;
        color: #33384f;
        border-bottom: 1px dashed #e3e5ef;
    }

        .info-row:last-child {
            border-bottom: none;
        }

        .info-row .info-icon {
            width: 32px;
            height: 32px;
            border-radius: 8px;
            background: rgba(13, 110, 253, 0.08);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 0.9rem;
            flex: 0 0 auto;
        }

        .info-row strong {
            color: #12162b;
            font-weight: 700;
        }

    .token-highlight {
        font-family: 'Sora', sans-serif;
        font-weight: 700;
        color: var(--success);
    }

    .celebrate-banner {
        border: none;
        border-radius: 14px;
        background: rgba(31, 174, 99, 0.09);
        color: var(--success);
        border-left: 3px solid var(--success);
        padding: 0.9rem 1.1rem;
        font-size: 0.9rem;
        margin-bottom: 1.75rem;
        text-align: left;
        opacity: 0;
        animation: fadeUp 0.5s ease forwards;
        animation-delay: 0.32s;
    }

    .action-buttons {
        display: grid;
        gap: 0.7rem;
        opacity: 0;
        animation: fadeUp 0.5s ease forwards;
        animation-delay: 0.4s;
    }

    .btn-home {
        border: none;
        border-radius: 12px;
        padding: 0.8rem 1rem;
        font-weight: 700;
        color: #fff;
        background: linear-gradient(120deg, var(--brand-blue), var(--brand-purple), var(--brand-blue));
        background-size: 220% 220%;
        box-shadow: 0 10px 24px -10px rgba(13, 110, 253, 0.5);
        transition: background-position 0.5s ease, transform 0.15s ease;
    }

        .btn-home:hover {
            background-position: 100% 50%;
            transform: translateY(-2px);
            color: #fff;
        }

    .btn-view-sub {
        border-radius: 12px;
        border: 1.5px solid #d7dbe8;
        background: #fff;
        color: #33384f;
        font-weight: 600;
        padding: 0.75rem 1rem;
        transition: transform 0.15s ease, border-color 0.15s ease, background 0.15s ease;
    }

        .btn-view-sub:hover {
            transform: translateY(-1px);
            border-color: var(--brand-blue);
            background: rgba(13, 110, 253, 0.04);
            color: var(--brand-blue);
        }

    @@media (prefers-reduced-motion: reduce) {
        *, *::before, *::after {
            animation-duration: 0.01ms !important;
            transition-duration: 0.01ms !important;
        }
    }
</style>

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="success-card" id="successCard">
                <div class="success-icon-wrap">
                    <span class="icon">✅</span>
                </div>

                <h2>Thanh toán thành công!</h2>
                <p class="subtext">Gói dịch vụ của bạn đã được kích hoạt.</p>

                <div class="package-info-panel">
                    <h5>📦 Thông tin gói</h5>
                    <div class="info-row">
                        <span class="info-icon">🏷️</span>
                        <span>Gói <strong>@Model.PackageName</strong></span>
                    </div>
                    <div class="info-row">
                        <span class="info-icon">🎫</span>
                        <span>Token còn lại <span class="token-highlight">@Model.RemainingTokenQuota.ToString("N0")</span></span>
                    </div>
                    <div class="info-row">
                        <span class="info-icon">⏱️</span>
                        <span>Bắt đầu <strong>@Model.StartDate.ToVietnamTime().ToString("dd/MM/yyyy HH:mm")</strong></span>
                    </div>
                    <div class="info-row">
                        <span class="info-icon">⏰</span>
                        <span>Hết hạn <strong>@Model.EndDate.ToVietnamTime().ToString("dd/MM/yyyy HH:mm")</strong></span>
                    </div>
                </div>

                <div class="celebrate-banner">
                    <strong>🎉 Chúc mừng!</strong> Bạn có thể bắt đầu sử dụng dịch vụ ngay bây giờ.
                </div>

                <div class="action-buttons">
                    <a href="/" class="btn-home text-center">
                        🏠 Về trang chủ
                    </a>
                    <a asp-action="MySubscription" class="btn-view-sub text-center">
                        📊 Xem gói của tôi
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Hiệu ứng confetti nhẹ khi trang load — chỉ chạy nếu người dùng không bật giảm animation
        document.addEventListener('DOMContentLoaded', function () {
            const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
            if (prefersReducedMotion) return;

            const card = document.getElementById('successCard');
            const colors = ['#0d6efd', '#6610f2', '#ffb648', '#1fae63'];
            const pieceCount = 24;

            for (let i = 0; i < pieceCount; i++) {
                const piece = document.createElement('span');
                piece.className = 'confetti-piece';
                piece.style.left = Math.random() * 100 + '%';
                piece.style.background = colors[Math.floor(Math.random() * colors.length)];
                piece.style.animationDelay = (Math.random() * 0.4) + 's';
                piece.style.animationDuration = (1.4 + Math.random() * 0.8) + 's';
                card.appendChild(piece);

                // Tự dọn dẹp sau khi animation kết thúc để không tồn đọng DOM
                piece.addEventListener('animationend', () => piece.remove());
            }
        });
    </script>
    <script src="https://cdn.jsdelivr.net/npm/@@microsoft/signalr@8.0.0/dist/browser/signalr.min.js"></script>
    <script>
        document.addEventListener("DOMContentLoaded", async function () {
        const connection = new signalR.HubConnectionBuilder()
        .withUrl("/hubs/notifications")
        .withAutomaticReconnect()
        .build();

        connection.on("PaymentCompleted", () => {
        location.reload();
        });

        try {
        await connection.start();
        } catch (err) {
        console.error("Không thể kết nối realtime thông báo:", err);
        }
        });
    </script>
}