@model SmartEdu.Shared.DTOs.PackageDto
@{
    ViewData["Title"] = "Mua gói - " + Model.Name;
}

<style>
    :root {
        --brand-blue: #0d6efd;
        --brand-purple: #6610f2;
        --ink-navy: #0b1120;
        --amber: #ffb648;
        --paper: #f7f8fc;
        --slate: #5a6072;
        --slate-light: #9aa0b4;
        --success: #1fae63;
        --danger: #e5484d;
    }

    @@keyframes fadeUp {
        from {
            opacity: 0;
            transform: translateY(12px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .checkout-card {
        background: #fff;
        border-radius: 18px;
        box-shadow: 0 14px 40px -16px rgba(11, 17, 32, 0.18);
        padding: 2rem;
        opacity: 0;
        animation: fadeUp 0.45s ease forwards;
    }

        .checkout-card .card-title {
            font-family: 'Sora', sans-serif;
            font-weight: 700;
            font-size: 1.4rem;
            color: #12162b;
        }

    .alert-danger {
        border: none;
        border-radius: 10px;
        background: rgba(229, 72, 77, 0.08);
        color: var(--danger);
        border-left: 3px solid var(--danger);
        font-size: 0.88rem;
    }

    .package-summary {
        background: var(--paper);
        border-radius: 14px;
        padding: 1.3rem 1.4rem;
        margin-bottom: 1.25rem;
        opacity: 0;
        animation: fadeUp 0.5s ease forwards;
        animation-delay: 0.08s;
    }

        .package-summary h5 {
            font-family: 'Sora', sans-serif;
            font-weight: 700;
            font-size: 1.1rem;
            color: #12162b;
            margin-bottom: 0.3rem;
        }

        .package-summary p.text-muted {
            color: var(--slate) !important;
            font-size: 0.9rem;
        }

        .package-summary hr {
            border-color: #e3e5ef;
            margin: 1rem 0;
        }

    .spec-item {
        display: flex;
        align-items: flex-start;
        gap: 0.6rem;
    }

        .spec-item .spec-icon {
            width: 38px;
            height: 38px;
            border-radius: 10px;
            background: rgba(13, 110, 253, 0.08);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.05rem;
            flex: 0 0 auto;
        }

        .spec-item .spec-label {
            font-size: 0.76rem;
            font-weight: 600;
            color: var(--slate-light);
            text-transform: uppercase;
            letter-spacing: 0.02em;
            margin-bottom: 0.1rem;
        }

        .spec-item .spec-value {
            font-family: 'Sora', sans-serif;
            font-weight: 700;
            font-size: 1rem;
            color: #12162b;
        }

    .price-panel {
        position: relative;
        overflow: hidden;
        border-radius: 16px;
        padding: 1.4rem 1.5rem;
        margin-bottom: 1.4rem;
        background: linear-gradient(120deg, var(--ink-navy), #171d3d);
        color: #fff;
        opacity: 0;
        animation: fadeUp 0.5s ease forwards;
        animation-delay: 0.14s;
    }

        .price-panel::before {
            content: "";
            position: absolute;
            inset: -40%;
            background: radial-gradient(circle at 80% 20%, rgba(255, 182, 72, 0.25), transparent 55%);
            pointer-events: none;
        }

        .price-panel .price-label {
            position: relative;
            z-index: 1;
            font-size: 0.85rem;
            color: rgba(255, 255, 255, 0.65);
            font-weight: 600;
            margin-bottom: 0.3rem;
        }

        .price-panel .price-value {
            position: relative;
            z-index: 1;
            font-family: 'Sora', sans-serif;
            font-weight: 800;
            font-size: 2.1rem;
            background: linear-gradient(120deg, #fff, var(--amber));
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
        }

    .btn-pay {
        width: 100%;
        border: none;
        border-radius: 12px;
        padding: 0.9rem 1rem;
        font-weight: 700;
        font-size: 1.02rem;
        color: #fff;
        background: linear-gradient(120deg, var(--success), #17c76f, var(--success));
        background-size: 220% 220%;
        box-shadow: 0 12px 26px -10px rgba(31, 174, 99, 0.5);
        transition: background-position 0.5s ease, transform 0.15s ease;
        opacity: 0;
        animation: fadeUp 0.5s ease forwards;
        animation-delay: 0.2s;
    }

        .btn-pay:hover {
            background-position: 100% 50%;
            transform: translateY(-2px);
            color: #fff;
        }

        .btn-pay:active {
            transform: scale(0.98);
        }

    .btn-back-list {
        width: 100%;
        border-radius: 12px;
        border: none;
        background: #eef0f6;
        color: #33384f;
        font-weight: 600;
        padding: 0.75rem 1rem;
        transition: background 0.15s ease, transform 0.15s ease;
        opacity: 0;
        animation: fadeUp 0.5s ease forwards;
        animation-delay: 0.26s;
    }

        .btn-back-list:hover {
            background: #e2e5f0;
            color: #12162b;
            transform: translateY(-1px);
        }

    .secure-note {
        border: none;
        border-radius: 12px;
        background: rgba(13, 110, 253, 0.06);
        color: var(--brand-blue);
        text-align: center;
        padding: 0.85rem 1rem;
        margin-top: 1.25rem;
        font-size: 0.85rem;
        opacity: 0;
        animation: fadeUp 0.5s ease forwards;
        animation-delay: 0.32s;
    }

        .secure-note .lock-icon {
            display: inline-block;
            margin-right: 0.3rem;
        }

    @@media (prefers-reduced-motion: reduce) {
        *, *::before, *::after {
            animation-duration: 0.01ms !important;
            transition-duration: 0.01ms !important;
        }
    }
</style>

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="checkout-card">
                <h2 class="card-title mb-4">🛒 Xác nhận mua gói</h2>

                @if (TempData["Error"] != null)
                {
                    <div class="alert alert-danger alert-dismissible fade show">
                        @TempData["Error"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                }

                <div class="package-summary">
                    <h5>@Model.Name</h5>
                    <p class="text-muted mb-2">@Model.Description</p>
                    <hr />
                    <div class="row g-3">
                        <div class="col-6">
                            <div class="spec-item">
                                <div class="spec-icon">⏱️</div>
                                <div>
                                    <div class="spec-label">Thời hạn</div>
                                    <div class="spec-value">@Model.DurationDays ngày</div>
                                </div>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="spec-item">
                                <div class="spec-icon"><i class="bi bi-ticket-perforated"></i></div>
                                <div>
                                    <div class="spec-label">Token</div>
                                    <div class="spec-value">@Model.TokenQuota.ToString("N0")</div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="price-panel">
                    <div class="price-label">💰 TỔNG TIỀN THANH TOÁN</div>
                    <div class="price-value">@Model.Price.ToString("N0") đ</div>
                </div>

                <form asp-action="ConfirmPayment" asp-route-packageId="@Model.Id" method="post" class="mb-3">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn-pay">
                        ✅ Tiếp tục thanh toán
                    </button>
                </form>

                <a asp-action="List" class="btn-back-list d-inline-block text-center">
                    ⬅️ Quay lại danh sách
                </a>
            </div>

            <div class="secure-note">
                <span class="lock-icon">🔒</span>Thanh toán an toàn qua PayOS. Bạn sẽ được chuyển hướng sang cổng thanh toán để hoàn tất giao dịch.
            </div>
        </div>
    </div>
</div>
