@{
    ViewData["Title"] = "Chat RAG";
    var currentSessionId = ViewBag.CurrentSessionId as string;
    var history = ViewBag.History as IEnumerable<SmartEdu.Shared.DTOs.ChatMessageDto>
                  ?? Enumerable.Empty<SmartEdu.Shared.DTOs.ChatMessageDto>();
    var sessions = ViewBag.Sessions as IEnumerable<SmartEdu.Shared.DTOs.ChatSessionDto>
                   ?? Enumerable.Empty<SmartEdu.Shared.DTOs.ChatSessionDto>();
}

<style>
    :root {
        --brand-blue: #246b4b;
        --brand-purple: #547864;
        --brand-gradient: #246b4b;
        --ink-navy: #17211b;
        --amber: #e5a43b;
        --paper: #f4f7f4;
        --panel: #ffffff;
        --line: #dde5df;
        --slate: #67736b;
        --slate-light: #929d96;
        --soft-blue: #e5efe9;
        --shadow: 0 10px 30px rgba(26, 57, 40, 0.07);
    }

    html, body {
        overflow-x: hidden;
    }

    .chat-page {
        min-height: calc(100vh - 72px);
        padding: 12px 14px 18px;
        background: var(--paper);
    }

    .chat-shell {
        max-width: 1680px;
        margin: 0 auto;
    }

    .panel-tabs {
        display: none;
        gap: 8px;
        margin-bottom: 12px;
        padding: 6px;
        background: rgba(255,255,255,.88);
        border: 1px solid var(--line);
        border-radius: 16px;
        box-shadow: 0 10px 28px -20px rgba(11,17,32,.35);
        backdrop-filter: blur(12px);
    }

    .panel-tab-btn {
        flex: 1;
        border: 0;
        background: transparent;
        color: #596075;
        font-weight: 700;
        font-size: .84rem;
        padding: .72rem .8rem;
        border-radius: 11px;
        transition: .18s ease;
    }

        .panel-tab-btn.active {
            background: var(--brand-gradient);
            color: #fff;
            box-shadow: none;
        }

    .workspace-row {
        height: calc(100vh - 115px);
    }

    .chat-panel, .sidebar-panel, .source-panel {
        height: 100%;
        display: flex;
        flex-direction: column;
        background: rgba(255,255,255,.96);
        border: 1px solid rgba(231,234,242,.95) !important;
        border-radius: 15px;
        box-shadow: var(--shadow);
        overflow: hidden;
    }

    .sidebar-header, .source-header, .chat-topbar {
        flex: 0 0 auto;
        background: rgba(255,255,255,.96);
        border-bottom: 1px solid var(--line);
    }

    .sidebar-header, .source-header {
        padding: 18px !important;
    }

    .panel-title {
        display: flex;
        align-items: center;
        gap: 10px;
        font-family: inherit;
        font-size: .98rem;
        font-weight: 800;
        color: #161b2f;
        margin: 0;
    }

    .panel-title-icon, .chat-avatar {
        width: 36px;
        height: 36px;
        border-radius: 9px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        background: var(--soft-blue);
        color: var(--brand-blue);
        flex: 0 0 auto;
    }

    .new-chat-btn {
        border: 0;
        border-radius: 12px;
        background: var(--brand-blue);
        color: #fff;
        font-weight: 700;
        padding: .58rem .86rem;
        box-shadow: none;
        transition: .18s ease;
    }

        .new-chat-btn:hover {
            color: #fff;
            transform: translateY(-1px);
            filter: brightness(1.05);
        }

    .sidebar-list {
        flex: 1 1 auto;
        overflow-y: auto;
        padding: 12px !important;
        background: #fafcfa;
    }

        .sidebar-list .card {
            border: 1px solid transparent !important;
            border-radius: 10px !important;
            background: transparent;
            box-shadow: none !important;
            margin-bottom: 6px !important;
            transition: .18s ease;
        }

            .sidebar-list .card:hover {
                background: #fff;
                border-color: var(--line) !important;
                transform: translateX(2px);
                box-shadow: 0 10px 22px -18px rgba(11,17,32,.4) !important;
            }

            .sidebar-list .card.border-primary {
                background: #e8f1eb;
                border-color: #c8d8ce !important;
            }

    .session-link {
        color: #22283b !important;
        font-size: .89rem;
        font-weight: 750 !important;
        max-width: 175px;
    }

    .session-meta {
        font-size: .75rem;
        color: #8b92a6;
    }

    .session-delete {
        width: 30px;
        height: 30px;
        border-radius: 9px !important;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        opacity: .35;
        transition: .15s ease;
    }

    .sidebar-list .card:hover .session-delete {
        opacity: 1;
        background: rgba(220,53,69,.08);
    }

    .chat-topbar {
        padding: 15px 18px;
        display: flex;
        align-items: center;
        gap: 12px;
        flex-wrap: wrap;
    }

    .chat-identity {
        display: flex;
        align-items: center;
        gap: 11px;
        min-width: 180px;
    }

    .chat-avatar {
        background: var(--brand-blue);
        color: #fff;
        border-radius: 10px;
        box-shadow: none;
    }

    #chatTitle {
        font-family: inherit;
        font-weight: 800;
        font-size: 1rem;
        color: #151a2e;
        margin: 0;
        max-width: 220px;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .chat-subtitle {
        display: block;
        color: #9299ac;
        font-size: .72rem;
        margin-top: 2px;
    }

    .chat-toolbar {
        margin-left: auto;
        display: flex;
        align-items: center;
        gap: 8px;
        flex-wrap: wrap;
    }

    #subjectSelect {
        min-width: 165px;
        border-radius: 11px;
        border: 1px solid var(--line);
        background-color: #f8faf8;
        color: #343a50;
        font-size: .82rem;
        font-weight: 600;
        padding: .52rem 2rem .52rem .75rem;
        box-shadow: none;
    }

        #subjectSelect:focus {
            border-color: var(--brand-blue);
            box-shadow: 0 0 0 3px rgba(36,107,75,.09);
        }

    #tokenBadge {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        background: #e5efe9 !important;
        color: var(--brand-blue);
        border: 1px solid #c8d8ce;
        border-radius: 11px;
        font-weight: 750;
        font-size: .77rem;
        padding: .55rem .72rem;
    }

    .package-btn {
        border: 0;
        border-radius: 11px;
        background: #f4dfad;
        color: #2f2108;
        font-weight: 800;
        font-size: .78rem;
        padding: .55rem .78rem;
        box-shadow: none;
    }

    .chat-messages {
        flex: 1 1 auto;
        overflow-y: auto;
        padding: 26px clamp(18px, 4vw, 48px) !important;
        margin: 0 !important;
        background: #f7f9f7 !important;
    }

        .chat-messages::-webkit-scrollbar, .sidebar-list::-webkit-scrollbar, .source-body::-webkit-scrollbar {
            width: 7px;
        }

        .chat-messages::-webkit-scrollbar-thumb, .sidebar-list::-webkit-scrollbar-thumb, .source-body::-webkit-scrollbar-thumb {
            background: #d8dce8;
            border-radius: 8px;
        }

    #emptyMsg {
        max-width: 420px;
        margin: 12vh auto 0 !important;
        padding: 28px;
        border: 1px dashed #d9deea;
        border-radius: 14px;
        background: #fff;
    }

        #emptyMsg::before {
            content: "\F268";
            font-family: "bootstrap-icons";
            width: 58px;
            height: 58px;
            margin: 0 auto 14px;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 18px;
            background: #e5efe9;
            color: var(--brand-blue);
            font-size: 1.55rem;
            box-shadow: none;
        }

        #emptyMsg h4 {
            font-family: inherit;
            color: #252b3f;
            font-weight: 800;
            font-size: 1.05rem;
        }

        #emptyMsg p {
            margin: 0;
            font-size: .86rem;
            line-height: 1.6;
        }

    .chat-messages > .d-flex {
        margin-bottom: 14px !important;
        animation: msgIn .25s ease;
    }

    .chat-messages > .d-flex > .chat-message-content,
    .chat-messages > .d-flex > [data-role="assistant-bubble"] {
        width: fit-content;
        max-width: min(82%, 780px) !important;
    }
    @@keyframes msgIn {
        from {
            opacity: 0;
            transform: translateY(7px);
        }

        to {
            opacity: 1;
            transform: none;
        }
    }

    .chat-messages .bg-primary {
        background: var(--brand-blue) !important;
        border-radius: 18px 18px 5px 18px !important;
        padding: 11px 15px !important;
        box-shadow: none;
        line-height: 1.58;
    }

    .chat-messages .bg-white.border {
        background: #fff !important;
        border: 1px solid #e9ebf2 !important;
        border-radius: 18px 18px 18px 5px !important;
        padding: 13px 16px !important;
        box-shadow: 0 3px 12px rgba(26,57,40,.04);
        line-height: 1.62;
    }

    .chat-message-content {
        white-space: pre-wrap;
        overflow-wrap: anywhere;
        font-size: .92rem;
    }

        .chat-message-content small.text-muted {
            font-family: inherit;
            font-weight: 800;
            font-size: .7rem;
            color: var(--brand-blue) !important;
        }

    .citation-block {
        margin-top: .8rem;
        padding-top: .72rem;
        border-top: 1px dashed #dfe3ed;
    }

    .citation-block-label {
        display: flex;
        align-items: center;
        gap: 5px;
        font-size: .7rem;
        font-weight: 800;
        color: #9aa0b4;
        text-transform: uppercase;
        margin-bottom: .5rem;
    }

    .citation-chips {
        display: flex;
        flex-wrap: wrap;
        gap: 6px;
    }

    .citation-link {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        max-width: 220px;
        padding: 5px 9px 5px 5px;
        border: 1px solid #c8d8ce;
        border-radius: 8px;
        background: #edf3ef;
        text-decoration: none !important;
        transition: .15s ease;
    }

        .citation-link:hover {
            background: #e1ece5;
            transform: translateY(-1px);
        }

        .citation-link .chip-num {
            width: 20px;
            height: 20px;
            border-radius: 6px;
            background: var(--brand-blue);
            color: #fff;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-size: .65rem;
            font-weight: 800;
            flex: 0 0 auto;
        }

        .citation-link .chip-title {
            color: #343a50;
            font-size: .75rem;
            font-weight: 650;
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
        }

    .chat-input-area {
        flex: 0 0 auto;
        padding: 12px 16px 15px !important;
        background: #fff !important;
        border-top: 1px solid var(--line) !important;
    }

    #typingIndicator {
        width: fit-content;
        margin: 0 0 8px 4px !important;
        padding: 6px 10px;
        border-radius: 999px;
        background: #f1f4fb;
        color: #6b7285 !important;
        font-size: .76rem;
    }

        #typingIndicator::before {
            content: "";
            display: inline-block;
            width: 7px;
            height: 7px;
            margin-right: 7px;
            border-radius: 50%;
            background: var(--brand-blue);
            animation: pulseDot 1s infinite;
        }
    @@keyframes pulseDot {
        0%, 100% {
            opacity: .3;
            transform: scale(.8)
        }

        50% {
            opacity: 1;
            transform: scale(1.1)
        }
    }

    .composer {
        display: flex;
        align-items: flex-end;
        gap: 8px;
        padding: 7px;
        border: 1px solid #dfe3ec;
        border-radius: 17px;
        background: #f8f9fc;
        transition: .18s ease;
    }

        .composer:focus-within {
            background: #fff;
            border-color: var(--brand-blue);
            box-shadow: 0 0 0 4px rgba(36,107,75,.09);
        }

    #questionInput {
        min-height: 42px;
        max-height: 180px;
        border: 0 !important;
        background: transparent !important;
        box-shadow: none !important;
        resize: none;
        padding: 10px 11px !important;
        font-size: .92rem;
        line-height: 1.45;
    }

    #sendBtn {
        width: 43px;
        height: 43px;
        min-width: 43px;
        border: 0;
        border-radius: 13px !important;
        background: var(--brand-blue);
        display: inline-flex;
        align-items: center;
        justify-content: center;
        box-shadow: none;
        transition: .16s ease;
    }

        #sendBtn:hover:not(:disabled) {
            transform: translateY(-1px) scale(1.02);
            filter: brightness(1.06);
        }

        #sendBtn:disabled {
            opacity: .55;
        }

        #sendBtn span {
            display: none;
        }

    .composer-hint {
        display: block;
        margin: 7px 5px 0;
        color: #a0a6b7;
        font-size: .7rem;
    }

    .source-header {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 10px;
    }

    #sourceDocSubtitle {
        font-size: .74rem;
    }

    .source-body {
        flex: 1 1 auto;
        overflow-y: auto;
        background: #f8f9fc;
        padding: 12px;
    }

    .source-empty {
        margin-top: 15vh;
        text-align: center;
        color: #9aa0b4;
    }

        .source-empty > div {
            width: 54px;
            height: 54px;
            margin: 0 auto 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 17px;
            background: #fff;
            border: 1px solid var(--line);
            box-shadow: 0 10px 20px -18px rgba(11,17,32,.4);
        }

    .source-chunk {
        background: #fff;
        border: 1px solid #e8eaf1;
        border-radius: 15px;
        padding: 13px 14px;
        margin-bottom: 9px;
        box-shadow: 0 7px 18px -18px rgba(11,17,32,.45);
        transition: .25s ease;
    }

        .source-chunk.highlight {
            background: #e8f1eb;
            border-color: #8eaa99;
            box-shadow: 0 0 0 3px rgba(36,107,75,.07);
        }

    .source-chunk-location {
        display: flex;
        align-items: center;
        gap: 5px;
        color: var(--brand-blue);
        font-size: .69rem;
        font-weight: 800;
        text-transform: uppercase;
        margin-bottom: 7px;
    }

    .source-chunk-content {
        color: #3b4155;
        font-size: .83rem;
        line-height: 1.6;
        white-space: pre-wrap;
    }

    .source-close-btn {
        border: 0;
        background: #f2f4f8;
        color: #81889d;
        width: 32px;
        height: 32px;
        border-radius: 10px;
    }

    @@media (max-width:1199.98px) {
        .chat-page {
            padding: 12px;
        }

        .panel-tabs {
            display: flex;
        }

        .workspace-row {
            height: auto !important;
        }

        .panel-col {
            display: none;
        }

            .panel-col.active {
                display: block;
            }

        .chat-panel, .sidebar-panel, .source-panel {
            height: calc(100vh - 165px);
            min-height: 500px;
        }
    }

    @@media (min-width:1200px) {
        .panel-col {
            display: block !important;
        }

        .source-close-btn {
            display: none;
        }
    }

    @@media (max-width:575.98px) {
        .chat-page {
            padding: 8px;
        }

        .chat-panel, .sidebar-panel, .source-panel {
            border-radius: 17px;
            height: calc(100vh - 150px);
        }

        .chat-topbar {
            padding: 12px;
        }

        .chat-toolbar {
            width: 100%;
            margin-left: 0;
        }

        #subjectSelect {
            flex: 1;
            min-width: 0;
        }

        #tokenBadge {
            order: 3;
        }

        .package-btn {
            order: 4;
        }

        .chat-messages {
            padding: 17px 12px !important;
        }

            .chat-messages .bg-primary, .chat-messages .bg-white.border {
                max-width: 88% !important;
            }

        .citation-link {
            max-width: 150px;
        }

        .chat-input-area {
            padding: 10px !important;
        }

        .composer-hint {
            display: none;
        }
    }

    @@media (prefers-reduced-motion:reduce) {
        *, *::before, *::after {
            animation-duration: .01ms !important;
            animation-iteration-count: 1 !important;
            transition-duration: .01ms !important;
        }
    }
</style>


<div class="chat-page">
    <div class="chat-shell">
        <div class="panel-tabs">
            <button type="button" class="panel-tab-btn active" data-target="sessions"><i class="bi bi-chat-left-text me-1"></i>Phiên chat</button>
            <button type="button" class="panel-tab-btn" data-target="chat"><i class="bi bi-chat-square-text me-1"></i>Trò chuyện</button>
            <button type="button" class="panel-tab-btn" data-target="source"><i class="bi bi-journal-text me-1"></i>Nguồn</button>
        </div>

        <div class="row g-3 workspace-row">
            <div class="col-12 col-xl-3 panel-col active" data-panel="sessions">
                <div class="sidebar-panel">
                    <div class="sidebar-header d-flex justify-content-between align-items-center">
                        <h6 class="panel-title"><span class="panel-title-icon"><i class="bi bi-chat-left-text"></i></span>Phiên chat</h6>
                        <a href="@Url.Action("Index", "Chat")" class="new-chat-btn text-decoration-none"><i class="bi bi-plus-lg me-1"></i>Mới</a>
                    </div>

                    <div class="sidebar-list">
                        @foreach (var s in sessions)
                        {
                            <div class="card @(s.SessionId == currentSessionId ? "border-primary" : "")" data-session-card="@s.SessionId">
                                <div class="card-body p-2">
                                    <div class="d-flex justify-content-between align-items-start gap-2">
                                        <div class="min-w-0">
                                            <a href="@Url.Action("Index", "Chat", new { sessionId = s.SessionId })"
                                               class="session-link text-decoration-none text-truncate d-block">
                                                @(s.Title ?? "Phiên mới")
                                            </a>
                                            <small class="session-meta"><i class="bi bi-book me-1"></i>@s.SubjectName · @s.MessageCount tin</small>
                                        </div>
                                        <form asp-action="DeleteSession" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="sessionId" value="@s.SessionId" />
                                            <button type="submit" class="session-delete btn btn-sm btn-link text-danger p-0" aria-label="Xóa phiên" onclick="return confirm('Xóa phiên này?')"><i class="bi bi-trash"></i></button>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <div class="col-12 col-xl-6 panel-col" data-panel="chat">
                <div class="chat-panel">
                    <div class="chat-topbar">
                        <div class="chat-identity">
                            <div class="chat-avatar"><i class="bi bi-chat-square-text"></i></div>
                            <div class="min-w-0">
                                <h5 id="chatTitle">@ViewBag.CurrentSessionTitle</h5>
                                <small class="chat-subtitle">Trợ lý học tập SmartEdu</small>
                            </div>
                        </div>

                        <div class="chat-toolbar">
                            <select id="subjectSelect" asp-items="ViewBag.Subjects" class="form-select form-select-sm">
                                <option value="">Tất cả môn học</option>
                            </select>

                            @if (ViewBag.HasActiveSubscription == true)
                            {
                                <span class="badge" id="tokenBadge"><i class="bi bi-ticket-perforated"></i>Token: <span id="remainingTokens">@(((int)ViewBag.RemainingTokens).ToString("N0"))</span></span>
                            }
                            else
                            {
                                <span class="badge" id="tokenBadge" title="Token miễn phí, tự động cấp lại theo chu kỳ"><i class="bi bi-ticket-perforated"></i>Miễn phí: <span id="remainingTokens">@(((int)ViewBag.RemainingTokens).ToString("N0"))</span></span>
                                <a asp-controller="Package" asp-action="List" class="package-btn text-decoration-none"><i class="bi bi-credit-card me-1"></i>Mua gói</a>
                            }
                        </div>
                    </div>

                    <div id="chatBox" class="chat-messages">
                        @if (!history.Any())
                        {
                            <div id="emptyMsg" class="text-center text-muted">
                                <h4>Bắt đầu cuộc trò chuyện</h4>
                                <p>Đặt câu hỏi về tài liệu học tập. SmartEdu sẽ trả lời và đính kèm nguồn tham khảo khi có.</p>
                            </div>
                        }

                        @foreach (var msg in history)
                        {
                            if (msg.Role == "user")
                            {
                                <div class="d-flex justify-content-end mb-2">
                                    <div class="bg-primary text-white rounded p-2 px-3 chat-message-content" style="max-width:75%">@msg.Content</div>
                                </div>
                            }
                            else
                            {
                                var histBubbleId = "hist_" + msg.Id;
                                <div class="d-flex justify-content-start mb-2">
                                    <div class="bg-white border rounded p-2 px-3" style="max-width:75%" data-role="assistant-bubble">
                                        <small class="text-muted d-block mb-1">SmartEdu</small>
                                        <div id="@histBubbleId"></div>
                                        @if (msg.Citations != null && msg.Citations.Any())
                                        {
                                            <div class="citation-block">
                                                <div class="citation-block-label"><i class="bi bi-journal-text"></i>Nguồn tham khảo</div>
                                                <div class="citation-chips">
                                                    @Html.Raw(string.Join("", msg.Citations.Select(c =>
                                                        $"<a href='#' class='citation-link' data-chunkid='{c.ChunkId}' data-documentid='{c.DocumentId}' data-number='{c.Number}' title='{System.Net.WebUtility.HtmlEncode(c.DocumentTitle)}'>" +
                                                        $"<span class='chip-num'>{c.Number}</span>" +
                                                        $"<span class='chip-title'>{System.Net.WebUtility.HtmlEncode(c.DocumentTitle)}</span></a>")))
                                                </div>
                                            </div>
                                        }
                                    </div>
                                </div>
                                <script>
                                                            document.addEventListener("DOMContentLoaded", function() {
                                                                renderChatMarkdown("@histBubbleId", @Html.Raw(System.Text.Json.JsonSerializer.Serialize(msg.Content)));
                                                            });
                                </script>
                            }
                        }
                    </div>

                    <div class="chat-input-area">
                        <div id="typingIndicator" class="text-muted small d-none"><span id="typingText">Đang chuẩn bị câu trả lời...</span></div>
                        <div class="composer">
                            <textarea id="questionInput" class="form-control" rows="1" placeholder="Nhập câu hỏi của bạn..." autocomplete="off"></textarea>
                            <button id="sendBtn" class="btn btn-primary" type="button" aria-label="Gửi câu hỏi"><i class="bi bi-arrow-up"></i><span>Gửi</span></button>
                        </div>
                        <small class="composer-hint">Enter để gửi · Shift + Enter để xuống dòng</small>
                    </div>
                </div>
            </div>

            <div class="col-12 col-xl-3 panel-col" data-panel="source">
                <div class="source-panel">
                    <div class="source-header">
                        <div>
                            <h6 class="panel-title mb-1" id="sourceDocTitle"><span class="panel-title-icon"><i class="bi bi-journal-text"></i></span>Nguồn tham khảo</h6>
                            <small class="text-muted" id="sourceDocSubtitle">Bấm vào trích dẫn trong câu trả lời để xem nội dung gốc</small>
                        </div>
                        <button type="button" class="source-close-btn" id="sourceCloseBtn" title="Đóng"><i class="bi bi-x-lg"></i></button>
                    </div>
                    <div class="source-body" id="sourceBody">
                        <div class="source-empty" id="sourceEmptyMsg">
                            <div><i class="bi bi-file-earmark-text fs-4"></i></div>
                            <p>Chưa có nguồn nào được chọn</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>


@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/@@microsoft/signalr@8.0.0/dist/browser/signalr.min.js"></script>
    <script>
        const sessionId = "@currentSessionId";
        const chatBox = document.getElementById("chatBox");
        const input = document.getElementById("questionInput");
        const sendBtn = document.getElementById("sendBtn");
        const typing = document.getElementById("typingIndicator");
        const emptyMsg = document.getElementById("emptyMsg");
        const typingText = document.getElementById("typingText");

        function setTypingStatus(message) {
            if (typingText) typingText.textContent = message || "Đang chuẩn bị câu trả lời...";
            typing.classList.remove("d-none");
        }

        function hideTyping() {
            typing.classList.add("d-none");
            if (typingText) typingText.textContent = "Đang chuẩn bị câu trả lời...";
        }

        function scrollBottom() {
            chatBox.scrollTop = chatBox.scrollHeight;
        }
        scrollBottom();

        function autosizeTextarea(el, maxHeight = 400) {
            if (!el) return;
            el.style.height = 'auto';
            const newH = Math.min(el.scrollHeight, maxHeight);
            el.style.height = newH + 'px';
        }

        function renderChatMarkdown(containerId, markdownText) {
            const container = document.getElementById(containerId);
            if (!container) return;
            if (typeof marked !== 'undefined' && typeof DOMPurify !== 'undefined') {
                marked.setOptions({ gfm: true, breaks: true, smartLists: true, smartypants: false });
                const raw = marked.parse(markdownText ?? '');
                const safe = DOMPurify.sanitize(raw);
                container.classList.add('chat-message-content');
                container.innerHTML = safe;
            } else {
                container.classList.add('chat-message-content');
                container.textContent = (markdownText ?? '').replace(/\\n/g, '\n');
            }
        }

        function appendMessage(role, content) {
            if (emptyMsg) emptyMsg.remove();

            const wrapper = document.createElement("div");
            wrapper.className = `d-flex mb-2 ${role === "user" ? "justify-content-end" : "justify-content-start"}`;

            const bubble = document.createElement("div");
            bubble.style.maxWidth = "75%";

            if (role === "user") {
                bubble.className = "bg-primary text-white rounded p-2 px-3";
                bubble.classList.add('chat-message-content');
                bubble.textContent = content.replace(/\\n/g, '\n');
            } else {
                bubble.className = "bg-white border rounded p-2 px-3";
                const tmpId = 'tmp_' + Date.now() + '_' + Math.random().toString(36).slice(2, 6);
                const header = `<small class="text-muted d-block mb-1">SmartEdu</small>`;
                bubble.innerHTML = header + `<div id="${tmpId}"></div>`;
                setTimeout(() => renderChatMarkdown(tmpId, content), 0);
                bubble.dataset.role = 'assistant-bubble';
            }

            wrapper.appendChild(bubble);
            chatBox.appendChild(wrapper);
            scrollBottom();
            return bubble;
        }

        function buildCitationChipsHtml(citations) {
            return citations.map(c =>
                `<a href="#" class="citation-link" data-chunkid="${c.chunkId}" data-documentid="${c.documentId}" data-number="${c.number}" title="${escapeHtml(c.documentTitle)}">` +
                `<span class="chip-num">${c.number}</span>` +
                `<span class="chip-title">${escapeHtml(c.documentTitle)}</span>` +
                `</a>`
            ).join("");
        }

        function appendCitationBlock(bubble, citations) {
            if (!citations || citations.length === 0) return;
            setTimeout(() => {
                const block = document.createElement("div");
                block.className = "citation-block";
                const label = document.createElement("div");
                label.className = "citation-block-label";
                label.innerHTML = '<i class="bi bi-journal-text me-1"></i>Nguồn tham khảo';
                const chips = document.createElement("div");
                chips.className = "citation-chips";
                chips.innerHTML = buildCitationChipsHtml(citations);
                block.appendChild(label);
                block.appendChild(chips);
                bubble.appendChild(block);
                scrollBottom();
            }, 10);
        }

        async function sendMessage() {
            const questionRaw = input.value;
            const question = questionRaw.trim();
            if (!question) return;

            const subjectId = document.getElementById("subjectSelect").value;

            input.value = "";
            autosizeTextarea(input);
            sendBtn.disabled = true;
            appendMessage("user", questionRaw);
            setTypingStatus("Đang chuẩn bị câu trả lời...");

            try {
                await chatHubReady;

                const res = await fetch("/Chat/Ask", {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify({
                        sessionId,
                        question,
                        subjectId: subjectId ? parseInt(subjectId) : null,
                        connectionId: chatHubConnection.connectionId
                    })
                });

                const data = await res.json();
                hideTyping();   // <-- chỗ 1

                if (res.ok) {
                    const assistantBubble = appendMessage("assistant", data.answer);
                    appendCitationBlock(assistantBubble, data.citations);

                    if (data.remainingTokenQuota !== undefined && data.remainingTokenQuota !== null) {
                        const tokenSpan = document.getElementById("remainingTokens");
                        if (tokenSpan) tokenSpan.textContent = data.remainingTokenQuota.toLocaleString();
                    }
                } else {
                    appendMessage("assistant", "❌ Lỗi: " + data.error);
                    if (data.error && (data.error.includes("token") || data.error.includes("gói"))) {
                        const btnDiv = document.createElement("div");
                        btnDiv.className = "text-center my-2";
                        btnDiv.innerHTML = '<a href="/Package/List" class="btn btn-sm btn-warning"><i class="bi bi-credit-card me-1"></i>Mua gói dịch vụ</a>';
                        chatBox.appendChild(btnDiv);
                        scrollBottom();
                    }
                }
            } catch (err) {
                hideTyping();   // <-- chỗ 2
                console.error("Chat request failed:", err);
            } finally {
                sendBtn.disabled = false;
                input.focus();
            }
        }

        sendBtn.addEventListener("click", sendMessage);
        autosizeTextarea(input);
        input.addEventListener('input', () => autosizeTextarea(input));
        input.addEventListener("keydown", e => {
            if (e.key === "Enter" && !e.shiftKey) {
                e.preventDefault();
                sendMessage();
            }
        });

        document.addEventListener("DOMContentLoaded", function() {
            const selectEl = document.getElementById("subjectSelect");
            const selectedValue = "@(ViewBag.Subjects?.SelectedValue ?? "")";
            if (selectedValue) selectEl.value = selectedValue;
        });

        function escapeHtml(unsafe) {
            if (!unsafe) return '';
            return String(unsafe)
                .replace(/&/g, "&amp;")
                .replace(/</g, "&lt;")
                .replace(/>/g, "&gt;")
                .replace(/\"/g, "&quot;")
                .replace(/'/g, "&#039;");
        }

        // =====================================================================
        // ===== PANEL TAB SWITCHER (dùng cho <1200px) ============================
        // =====================================================================
        const panelTabBtns = document.querySelectorAll(".panel-tab-btn");
        const panelCols = document.querySelectorAll(".panel-col");

        function switchPanel(target) {
            panelTabBtns.forEach(b => b.classList.toggle("active", b.getAttribute("data-target") === target));
            panelCols.forEach(c => c.classList.toggle("active", c.getAttribute("data-panel") === target));
        }

        panelTabBtns.forEach(btn => {
            btn.addEventListener("click", () => switchPanel(btn.getAttribute("data-target")));
        });

        document.getElementById("sourceCloseBtn")?.addEventListener("click", () => switchPanel("chat"));

        // =====================================================================
        // ===== SOURCE PANEL (click citation -> load + scroll + highlight) =====
        // =====================================================================
        const sourceBody = document.getElementById("sourceBody");
        const sourceDocTitle = document.getElementById("sourceDocTitle");
        const sourceDocSubtitle = document.getElementById("sourceDocSubtitle");

        let currentSourceDocumentId = null;
        let currentLoadedMin = null;
        let currentLoadedMax = null;
        let currentTotalChunks = null;
        let isLoadingMore = false;

        // Ghi thêm data-chunkid vào mỗi block để highlight đúng theo ChunkId (không chỉ ChunkIndex)
        function buildChunkHtmlWithId(documentId, chunk) {
            const loc = chunk.sourceLocation ? escapeHtml(chunk.sourceLocation) : "Không xác định";
            return `<div class="source-chunk" id="chunk-${documentId}-${chunk.chunkIndex}" data-chunk-index="${chunk.chunkIndex}" data-chunk-id="${chunk.chunkId}">
                <div class="source-chunk-location">📍 ${loc}</div>
                <div class="source-chunk-content">${escapeHtml(chunk.content)}</div>
                </div>`;
        }

        function renderSourcePanelFinal(data, highlightChunkId) {
            currentSourceDocumentId = data.documentId;
            currentTotalChunks = data.totalChunks;

            if (data.chunks.length > 0) {
                currentLoadedMin = data.chunks[0].chunkIndex;
                currentLoadedMax = data.chunks[data.chunks.length - 1].chunkIndex;
            } else {
                currentLoadedMin = 0;
                currentLoadedMax = -1;
            }

            sourceDocTitle.textContent = data.documentTitle;
            sourceDocSubtitle.textContent = `${data.totalChunks} đoạn nội dung`;

            sourceBody.innerHTML = data.chunks.map(c => buildChunkHtmlWithId(data.documentId, c)).join("");

            if (highlightChunkId) {
                setTimeout(() => doHighlight(highlightChunkId), 60);
            }
        }

        function doHighlight(chunkId) {
            const el = sourceBody.querySelector(`.source-chunk[data-chunk-id="${chunkId}"]`);
            if (!el) return;
            el.scrollIntoView({ behavior: "smooth", block: "center" });
            el.classList.add("highlight");
            setTimeout(() => el.classList.remove("highlight"), 2500);
        }

        async function openSourcePanel(documentId, chunkId, range = 15) {
            if (window.innerWidth < 1200) switchPanel("source");

            sourceBody.innerHTML = `<div class="source-empty"><div style="font-size:2rem;">⏳</div><p>Đang tải nguồn...</p></div>`;

            try {
                const resp = await fetch(`/Document/GetChunksAroundCitation?documentId=${documentId}&chunkId=${chunkId}&range=${range}`);
                if (!resp.ok) {
                    sourceBody.innerHTML = `<div class="source-empty"><div style="font-size:2rem;">⚠️</div><p>Không thể tải nguồn (bạn có thể không có quyền truy cập).</p></div>`;
                    return;
                }
                const data = await resp.json();
                renderSourcePanelFinal(data, chunkId);
            } catch (err) {
                console.error(err);
                sourceBody.innerHTML = `<div class="source-empty"><div style="font-size:2rem;">⚠️</div><p>Lỗi kết nối khi tải nguồn.</p></div>`;
            }
        }

        // Infinite scroll: load thêm khi cuộn gần đầu/cuối panel nguồn
        sourceBody.addEventListener("scroll", async function() {
            if (isLoadingMore || currentSourceDocumentId == null) return;

            const nearTop = sourceBody.scrollTop < 60;
            const nearBottom = sourceBody.scrollHeight - sourceBody.scrollTop - sourceBody.clientHeight < 60;

            if (nearTop && currentLoadedMin > 0) {
                isLoadingMore = true;
                const oldScrollHeight = sourceBody.scrollHeight;
                const fromIdx = Math.max(0, currentLoadedMin - 15);
                const toIdx = currentLoadedMin - 1;

                try {
                    const resp = await fetch(`/Document/GetChunksRange?documentId=${currentSourceDocumentId}&fromIndex=${fromIdx}&toIndex=${toIdx}`);
                    if (resp.ok) {
                        const data = await resp.json();
                        if (data.chunks.length > 0) {
                            const html = data.chunks.map(c => buildChunkHtmlWithId(currentSourceDocumentId, c)).join("");
                            sourceBody.insertAdjacentHTML("afterbegin", html);
                            currentLoadedMin = data.chunks[0].chunkIndex;
                            sourceBody.scrollTop += (sourceBody.scrollHeight - oldScrollHeight);
                        } else {
                            currentLoadedMin = 0;
                        }
                    }
                } catch (err) {
                    console.error("Lỗi load thêm (top):", err);
                } finally {
                    isLoadingMore = false;
                }
            } else if (nearBottom && currentLoadedMax < currentTotalChunks - 1) {
                isLoadingMore = true;
                const fromIdx = currentLoadedMax + 1;
                const toIdx = Math.min(currentTotalChunks - 1, currentLoadedMax + 15);

                try {
                    const resp = await fetch(`/Document/GetChunksRange?documentId=${currentSourceDocumentId}&fromIndex=${fromIdx}&toIndex=${toIdx}`);
                    if (resp.ok) {
                        const data = await resp.json();
                        if (data.chunks.length > 0) {
                            const html = data.chunks.map(c => buildChunkHtmlWithId(currentSourceDocumentId, c)).join("");
                            sourceBody.insertAdjacentHTML("beforeend", html);
                            currentLoadedMax = data.chunks[data.chunks.length - 1].chunkIndex;
                        } else {
                            currentLoadedMax = currentTotalChunks - 1;
                        }
                    }
                } catch (err) {
                    console.error("Lỗi load thêm (bottom):", err);
                } finally {
                    isLoadingMore = false;
                }
            }
        });

        // Click handler cho citation-link: mở/scroll panel nguồn (thay hoàn toàn modal cũ)
        document.addEventListener('click', function(e) {
            const el = e.target.closest('.citation-link');
            if (!el) return;
            e.preventDefault();

            const chunkId = parseInt(el.getAttribute('data-chunkid'), 10);
            const documentId = parseInt(el.getAttribute('data-documentid'), 10);
            if (!chunkId || !documentId) return;

            if (currentSourceDocumentId === documentId) {
                const existing = sourceBody.querySelector(`.source-chunk[data-chunk-id="${chunkId}"]`);
                if (existing) {
                    if (window.innerWidth < 1200) switchPanel("source");
                    doHighlight(chunkId);
                    return;
                }
            }

            openSourcePanel(documentId, chunkId);
        });

        // === SignalR: đồng bộ đa tab cùng session + cập nhật token quota real-time ===
        const chatHubConnection = new signalR.HubConnectionBuilder()
            .withUrl("/hubs/chat")
            .withAutomaticReconnect()
            .build();

        chatHubConnection.on("ReceiveProgress", (data) => {
            setTypingStatus(data.message);
        });

        chatHubConnection.on("ReceiveMessage", (msg) => {
            if (msg.role === "assistant") {
                hideTyping();
                const bubble = appendMessage("assistant", msg.content);
                appendCitationBlock(bubble, msg.citations);
            } else {
                appendMessage(msg.role, msg.content);
            }
        });

        const chatHubReady = chatHubConnection.start()
            .then(() => chatHubConnection.invoke("JoinSession", sessionId))
            .catch(err => console.error("ChatHub connect failed:", err));

        const notifyHubConnection = new signalR.HubConnectionBuilder()
            .withUrl("/hubs/notifications")
            .withAutomaticReconnect()
            .build();

        notifyHubConnection.on("TokenQuotaUpdated", (data) => {
            const tokenSpan = document.getElementById("remainingTokens");
            if (tokenSpan) tokenSpan.textContent = data.remainingTokenQuota.toLocaleString();
        });

        notifyHubConnection.on("PaymentCompleted", (data) => {
            const tokenSpan = document.getElementById("remainingTokens");
            if (tokenSpan && data.remainingTokenQuota !== undefined) {
                tokenSpan.textContent = data.remainingTokenQuota.toLocaleString();
            }
        });

        function buildSessionCardHtml(s) {
            const isActive = s.sessionId === sessionId;
            return `
                <div class="card ${isActive ? 'border-primary' : ''}" data-session-card="${s.sessionId}">
                    <div class="card-body p-2">
                        <div class="d-flex justify-content-between align-items-start gap-2">
                            <div class="min-w-0">
                                <a href="/Chat?sessionId=${encodeURIComponent(s.sessionId)}"
                                   class="session-link text-decoration-none text-truncate d-block">
                                    ${escapeHtml(s.title || 'Phiên mới')}
                                </a>
                                <small class="session-meta"><i class="bi bi-book me-1"></i>${escapeHtml(s.subjectName || '')} · ${s.messageCount} tin</small>
                            </div>
                            <form action="/Chat/DeleteSession" method="post" class="d-inline">
                                <input type="hidden" name="__RequestVerificationToken" value="${getAntiForgeryToken()}" />
                                <input type="hidden" name="sessionId" value="${s.sessionId}" />
                                <button type="submit" class="session-delete btn btn-sm btn-link text-danger p-0" aria-label="Xóa phiên" onclick="return confirm('Xóa phiên này?')"><i class="bi bi-trash"></i></button>
                            </form>
                        </div>
                    </div>
                </div>`;
        }

        function getAntiForgeryToken() {
            const el = document.querySelector('input[name="__RequestVerificationToken"]');
            return el ? el.value : '';
        }

        const sidebarList = document.querySelector('.sidebar-list');

        function upsertSessionCard(s) {
            if (!sidebarList) return;
            const existing = sidebarList.querySelector(`[data-session-card="${s.sessionId}"]`);
            const html = buildSessionCardHtml(s);

            if (existing) {
                existing.outerHTML = html;
                const updated = sidebarList.querySelector(`[data-session-card="${s.sessionId}"]`);
                if (updated) sidebarList.prepend(updated);
            } else {
                sidebarList.insertAdjacentHTML('afterbegin', html);
            }
        }

        function removeSessionCard(sid) {
            if (!sidebarList) return;
            const el = sidebarList.querySelector(`[data-session-card="${sid}"]`);
            if (el) el.remove();

            if (sid === sessionId) {
                window.location.href = '/Chat';
            }
        }

        notifyHubConnection.on("SessionUpsert", (s) => {
            upsertSessionCard(s);
        });

        notifyHubConnection.on("SessionDeleted", (data) => {
            removeSessionCard(data.sessionId);
        });

        notifyHubConnection.start().catch(err => console.error("NotificationHub connect failed:", err));
    </script>
}
