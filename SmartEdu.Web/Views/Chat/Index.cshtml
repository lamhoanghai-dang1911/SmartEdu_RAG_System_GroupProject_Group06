@{
    ViewData["Title"] = "Chat RAG";
    var currentSessionId = ViewBag.CurrentSessionId as string;
    var history = ViewBag.History as IEnumerable<SmartEdu.Shared.DTOs.ChatMessageDto>
                  ?? Enumerable.Empty<SmartEdu.Shared.DTOs.ChatMessageDto>();
    var sessions = ViewBag.Sessions as IEnumerable<SmartEdu.Shared.DTOs.ChatSessionDto>
                   ?? Enumerable.Empty<SmartEdu.Shared.DTOs.ChatSessionDto>();
}

<style>
    :root {
        --brand-blue: #0d6efd;
        --brand-purple: #6610f2;
        --ink-navy: #0b1120;
        --amber: #ffb648;
        --paper: #f7f8fc;
        --slate: #5a6072;
        --slate-light: #9aa0b4;
    }

    /* ===== Panel tabs (mobile/tablet switcher) ===== */
    .panel-tabs {
        display: flex;
        gap: 0.5rem;
        margin-bottom: 0.75rem;
    }

    .panel-tab-btn {
        flex: 1;
        border: 1.5px solid #e3e5ef;
        background: #fff;
        color: #33384f;
        font-weight: 600;
        font-size: 0.85rem;
        padding: 0.55rem 0.6rem;
        border-radius: 12px;
        transition: all 0.15s ease;
    }

        .panel-tab-btn.active {
            border-color: transparent;
            background: linear-gradient(120deg, var(--brand-blue), var(--brand-purple));
            color: #fff;
        }

    /* ===== Panels ===== */
    .chat-panel,
    .sidebar-panel,
    .source-panel {
        height: calc(100vh - 120px);
        display: flex;
        flex-direction: column;
        border: none !important;
        background: #fff;
        border-radius: 16px;
        box-shadow: 0 10px 32px -12px rgba(11, 17, 32, 0.14);
        overflow: hidden;
    }

    .chat-messages {
        flex: 1 1 auto;
        overflow-y: auto;
        -webkit-overflow-scrolling: touch;
        background: var(--paper) !important;
    }

        .chat-messages::-webkit-scrollbar,
        .sidebar-list::-webkit-scrollbar,
        .source-body::-webkit-scrollbar {
            width: 8px;
        }

        .chat-messages::-webkit-scrollbar-thumb,
        .sidebar-list::-webkit-scrollbar-thumb,
        .source-body::-webkit-scrollbar-thumb {
            background: #d7dbe8;
            border-radius: 8px;
        }

            .chat-messages::-webkit-scrollbar-thumb:hover,
            .sidebar-list::-webkit-scrollbar-thumb:hover,
            .source-body::-webkit-scrollbar-thumb:hover {
                background: #b9bfd4;
            }

    .chat-input-area {
        flex: 0 0 auto;
        background: #fff !important;
        border-top: 1px solid #ecedf4 !important;
    }

    .sidebar-header,
    .source-header {
        flex: 0 0 auto;
        background: #fff;
        z-index: 2;
        border-bottom: 1px solid #ecedf4;
        padding: 1rem !important;
    }

        .sidebar-header h6,
        .source-header h6 {
            font-family: 'Sora', sans-serif;
            font-weight: 700;
            font-size: 0.95rem;
            color: #12162b;
            margin: 0;
        }

        .sidebar-header .btn-primary {
            background: linear-gradient(120deg, var(--brand-blue), var(--brand-purple));
            border: none;
            border-radius: 999px;
            font-weight: 600;
            font-size: 0.82rem;
            padding: 0.35rem 0.9rem;
            transition: transform 0.15s ease, filter 0.15s ease;
        }

            .sidebar-header .btn-primary:hover {
                transform: translateY(-1px);
                filter: brightness(1.08);
            }

    .sidebar-list {
        flex: 1 1 auto;
        overflow-y: auto;
        -webkit-overflow-scrolling: touch;
        background: transparent;
        padding: 0.75rem !important;
    }

        .sidebar-list .card {
            border: 1px solid #edeef5 !important;
            border-radius: 12px !important;
            border-left: 3px solid transparent !important;
            transition: border-color 0.18s ease, transform 0.15s ease, box-shadow 0.18s ease;
            box-shadow: none !important;
        }

            .sidebar-list .card:hover {
                transform: translateX(2px);
                box-shadow: 0 6px 16px -8px rgba(11, 17, 32, 0.18) !important;
            }

            .sidebar-list .card.border-primary {
                border-left-color: var(--brand-blue) !important;
                border-color: #edeef5 !important;
                background: linear-gradient(90deg, rgba(13, 110, 253, 0.05), transparent 60%);
            }

            .sidebar-list .card a.fw-bold {
                font-family: 'Sora', sans-serif;
                font-size: 0.9rem;
                color: #1c2033 !important;
            }

            .sidebar-list .card small.text-muted {
                font-size: 0.76rem;
            }

        .sidebar-list .btn-link.text-danger {
            opacity: 0.5;
            transition: opacity 0.15s ease;
        }

        .sidebar-list .card:hover .btn-link.text-danger {
            opacity: 1;
        }

    /* ===== Chat header ===== */
    .chat-panel > .d-flex.align-items-center {
        padding: 1rem !important;
        border-bottom: 1px solid #ecedf4;
        background: #fff;
    }

    #chatTitle {
        font-family: 'Sora', sans-serif;
        font-weight: 700;
        font-size: 1.05rem;
        color: #12162b;
    }

    #subjectSelect {
        border-radius: 999px;
        border: 1.5px solid #e3e5ef;
        font-size: 0.85rem;
        padding-top: 0.35rem;
        padding-bottom: 0.35rem;
    }

        #subjectSelect:focus {
            border-color: var(--brand-blue);
            box-shadow: 0 0 0 3px rgba(13, 110, 253, 0.12);
        }

    #tokenBadge {
        background: linear-gradient(120deg, var(--brand-blue), var(--brand-purple)) !important;
        border-radius: 999px;
        font-weight: 600;
        font-size: 0.8rem;
        padding: 0.45rem 0.9rem;
    }

    .chat-panel > .d-flex.align-items-center .btn-warning {
        border-radius: 999px;
        font-weight: 600;
        border: none;
        background: linear-gradient(120deg, var(--amber), #f5a52c);
        transition: transform 0.15s ease;
    }

        .chat-panel > .d-flex.align-items-center .btn-warning:hover {
            transform: translateY(-1px);
        }

    /* ===== Empty state ===== */
    #emptyMsg {
        animation: floatIcon 3s ease-in-out infinite;
    }

        #emptyMsg h4 {
            font-family: 'Sora', sans-serif;
            font-weight: 700;
            color: #33384f;
        }

    @@keyframes floatIcon {
        0%, 100% {
            transform: translateY(0);
        }

        50% {
            transform: translateY(-6px);
        }
    }

    /* ===== Message bubbles ===== */
    .chat-messages .bg-primary {
        background: linear-gradient(120deg, var(--brand-blue), var(--brand-purple)) !important;
        border: none !important;
        border-radius: 16px 16px 4px 16px !important;
        box-shadow: 0 6px 18px -8px rgba(13, 110, 253, 0.45);
    }

    .chat-messages .bg-white.border {
        border: 1px solid #ecedf4 !important;
        border-radius: 16px 16px 16px 4px !important;
        box-shadow: 0 4px 14px -8px rgba(11, 17, 32, 0.15);
    }

    .chat-messages .d-flex.mb-2,
    .chat-messages > .d-flex {
        animation: msgIn 0.3s ease;
    }

    @@keyframes msgIn {
        from {
            opacity: 0;
            transform: translateY(8px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .chat-message-content small.text-muted {
        font-family: 'Sora', sans-serif;
        font-weight: 600;
        font-size: 0.72rem;
        letter-spacing: 0.02em;
    }

    /* ===== Citations ===== */
    .citation-block {
        margin-top: 0.7rem;
        padding-top: 0.65rem;
        border-top: 1px dashed #e3e5ef;
    }

    .citation-block-label {
        font-size: 0.74rem;
        font-weight: 700;
        color: var(--slate-light);
        text-transform: uppercase;
        letter-spacing: 0.03em;
        margin-bottom: 0.5rem;
        display: flex;
        align-items: center;
        gap: 0.35rem;
    }

    .citation-chips {
        display: flex;
        flex-wrap: wrap;
        gap: 0.4rem;
    }

    .citation-link {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        background: rgba(13, 110, 253, 0.07);
        border: 1px solid rgba(13, 110, 253, 0.15);
        border-radius: 999px;
        padding: 0.28rem 0.7rem 0.28rem 0.32rem;
        text-decoration: none !important;
        max-width: 220px;
        cursor: pointer;
        transition: background 0.15s ease, border-color 0.15s ease, transform 0.12s ease;
    }

        .citation-link:hover {
            background: rgba(13, 110, 253, 0.14);
            border-color: rgba(13, 110, 253, 0.3);
            transform: translateY(-1px);
        }

        .citation-link .chip-num {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 18px;
            height: 18px;
            border-radius: 50%;
            background: var(--brand-blue);
            color: #fff;
            font-size: 0.66rem;
            font-weight: 700;
            flex: 0 0 auto;
        }

        .citation-link .chip-title {
            color: #1c2033;
            font-size: 0.78rem;
            font-weight: 600;
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
        }

    /* ===== Typing indicator ===== */
    #typingIndicator {
        font-size: 0.85rem;
        color: var(--slate);
    }

        #typingIndicator::before {
            content: "";
            display: inline-block;
            width: 6px;
            height: 6px;
            border-radius: 50%;
            background: var(--brand-blue);
            margin-right: 6px;
            animation: pulseDot 1s ease-in-out infinite;
        }

    @@keyframes pulseDot {
        0%, 100% {
            opacity: 0.3;
            transform: scale(0.8);
        }

        50% {
            opacity: 1;
            transform: scale(1.1);
        }
    }

    /* ===== Input area ===== */
    .chat-input-area .input-group {
        background: var(--paper);
        border-radius: 14px;
        padding: 0.35rem;
        border: 1.5px solid #e3e5ef;
        transition: border-color 0.2s ease, box-shadow 0.2s ease;
    }

        .chat-input-area .input-group:focus-within {
            border-color: var(--brand-blue);
            box-shadow: 0 0 0 4px rgba(13, 110, 253, 0.1);
        }

    #questionInput {
        border: none !important;
        background: transparent !important;
        box-shadow: none !important;
        resize: none;
        font-size: 0.95rem;
        padding: 0.5rem 0.75rem !important;
    }

        #questionInput:focus {
            box-shadow: none !important;
        }

    #sendBtn {
        border: none;
        border-radius: 10px !important;
        background: linear-gradient(120deg, var(--brand-blue), var(--brand-purple));
        font-weight: 600;
        padding: 0 1.1rem;
        transition: transform 0.15s ease, filter 0.15s ease;
    }

        #sendBtn:hover:not(:disabled) {
            transform: translateY(-1px);
            filter: brightness(1.08);
        }

        #sendBtn:disabled {
            opacity: 0.6;
        }

    /* ===== Source panel (mới) ===== */
    .source-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 0.5rem;
    }

    #sourceDocSubtitle {
        font-size: 0.76rem;
    }

    .source-body {
        flex: 1 1 auto;
        overflow-y: auto;
        -webkit-overflow-scrolling: touch;
        background: var(--paper);
        padding: 0.9rem;
    }

    .source-empty {
        text-align: center;
        color: var(--slate-light);
        margin-top: 3rem;
    }

    .source-loading-top,
    .source-loading-bottom {
        text-align: center;
        font-size: 0.78rem;
        color: var(--slate-light);
        padding: 0.5rem 0;
    }

    .source-chunk {
        background: #fff;
        border: 1px solid #edeef5;
        border-radius: 12px;
        padding: 0.85rem 1rem;
        margin-bottom: 0.7rem;
        transition: background 0.4s ease, border-color 0.4s ease;
    }

        .source-chunk.highlight {
            background: rgba(13, 110, 253, 0.08);
            border-color: rgba(13, 110, 253, 0.4);
        }

    .source-chunk-location {
        font-size: 0.72rem;
        font-weight: 700;
        color: var(--brand-blue);
        text-transform: uppercase;
        letter-spacing: 0.02em;
        margin-bottom: 0.4rem;
        display: flex;
        align-items: center;
        gap: 0.3rem;
    }

    .source-chunk-content {
        font-size: 0.86rem;
        color: #33384f;
        white-space: pre-wrap;
        line-height: 1.55;
    }

    .source-close-btn {
        border: none;
        background: transparent;
        color: var(--slate-light);
        font-size: 1.1rem;
        line-height: 1;
        padding: 0.2rem 0.4rem;
    }

        .source-close-btn:hover {
            color: var(--danger, #e5484d);
        }

    @@media (prefers-reduced-motion: reduce) {
        *, *::before, *::after {
            animation-duration: 0.01ms !important;
            animation-iteration-count: 1 !important;
            transition-duration: 0.01ms !important;
        }
    }

    /* ===== Responsive: ≥1200px hiện đủ 3 cột, dưới 1200px dùng tab-switcher ===== */
    .panel-tabs {
        display: none;
    }

    @@media (max-width: 1199.98px) {
        .panel-tabs {
            display: flex;
        }

        .container-fluid.mt-3 .row {
            height: auto !important;
        }

        .panel-col {
            display: none;
        }

            .panel-col.active {
                display: block;
            }

        .chat-panel,
        .sidebar-panel,
        .source-panel {
            height: calc(100vh - 190px);
            min-height: 420px;
        }
    }

    @@media (min-width: 1200px) {
        .panel-col {
            display: block !important;
        }

        .source-close-btn {
            display: none;
        }
    }

    @@media (max-width: 575.98px) {
        .chat-panel > .d-flex.align-items-center {
            flex-wrap: wrap;
            row-gap: 0.5rem;
        }

        #subjectSelect {
            max-width: 160px;
        }

        #tokenBadge {
            margin-left: 0 !important;
        }

        .citation-link {
            max-width: 140px;
        }
    }

    html, body {
        overflow-x: hidden;
    }
</style>

<div class="container-fluid mt-3">

    <div class="panel-tabs">
        <button type="button" class="panel-tab-btn active" data-target="sessions">💬 Phiên chat</button>
        <button type="button" class="panel-tab-btn" data-target="chat">🤖 Chat</button>
        <button type="button" class="panel-tab-btn" data-target="source">📎 Nguồn</button>
    </div>

    <div class="row" style="height: calc(100vh - 120px)">

        <div class="col-12 col-xl-3 panel-col active" data-panel="sessions">
            <div class="sidebar-panel border-end d-flex flex-column">

                <div class="sidebar-header p-2 d-flex justify-content-between align-items-center">
                    <h6 class="mb-0">💬 Phiên chat</h6>
                    <a href="@Url.Action("Index", "Chat")" class="btn btn-sm btn-primary">+ Mới</a>
                </div>

                <div class="sidebar-list p-2">
                    @foreach (var s in sessions)
                    {
                        <div class="card mb-2 shadow-sm @(s.SessionId == currentSessionId ? "border-primary" : "")"
                             data-session-card="@s.SessionId">
                            <div class="card-body p-2">
                                <div class="d-flex justify-content-between">
                                    <a href="@Url.Action("Index", "Chat", new { sessionId = s.SessionId })"
                                       class="text-decoration-none text-dark fw-bold small text-truncate"
                                       style="max-width:150px">
                                        @(s.Title ?? "Phiên mới")
                                    </a>
                                    <form asp-action="DeleteSession" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="sessionId" value="@s.SessionId" />
                                        <button type="submit" class="btn btn-sm btn-link text-danger p-0" onclick="return confirm('Xóa phiên này?')">🗑️</button>
                                    </form>
                                </div>
                                <small class="text-muted">📚 @s.SubjectName | 💬 @s.MessageCount tin</small>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="col-12 col-xl-5 panel-col" data-panel="chat">
            <div class="chat-panel border d-flex flex-column">

                <div class="d-flex align-items-center gap-2 mb-2 p-2">
                    <h5 id="chatTitle" class="mb-0">🤖 @ViewBag.CurrentSessionTitle</h5>

                    <select id="subjectSelect" asp-items="ViewBag.Subjects"
                            class="form-select form-select-sm w-auto">
                        <option value="">-- Tất cả môn học --</option>
                    </select>

                    @if (ViewBag.HasActiveSubscription == true)
                    {
                        <span class="badge bg-info ms-auto" id="tokenBadge">
                            🎫 Token còn lại: <span id="remainingTokens">@(((int)ViewBag.RemainingTokens).ToString("N0"))</span>
                        </span>
                    }
                    else
                    {
                        <span class="badge bg-info ms-auto" id="tokenBadge" title="Token miễn phí, tự động cấp lại theo chu kỳ">
                            🎁 Token miễn phí: <span id="remainingTokens">@(((int)ViewBag.RemainingTokens).ToString("N0"))</span>
                        </span>
                        <a asp-controller="Package" asp-action="List" class="btn btn-sm btn-warning ms-2">
                            💳 Mua gói
                        </a>
                    }
                </div>

                <div id="chatBox" class="chat-messages p-3 bg-light mb-2">

                    @if (!history.Any())
                    {
                        <div id="emptyMsg" class="text-center text-muted mt-5">
                            <h4>👋 Xin chào!</h4>
                            <p>Hãy đặt câu hỏi về tài liệu học tập của bạn.</p>
                        </div>
                    }

                    @foreach (var msg in history)
                    {
                        if (msg.Role == "user")
                        {
                            <div class="d-flex justify-content-end mb-2">
                                <div class="bg-primary text-white rounded p-2 px-3 chat-message-content" style="max-width:75%">
                                    @msg.Content
                                </div>
                            </div>
                        }
                        else
                        {
                            var histBubbleId = "hist_" + msg.Id;
                            <div class="d-flex justify-content-start mb-2">
                                <div class="bg-white border rounded p-2 px-3" style="max-width:75%" data-role="assistant-bubble">
                                    <small class="text-muted d-block mb-1">🤖 SmartEdu AI</small>
                                    <div id="@histBubbleId"></div>
                                    @if (msg.Citations != null && msg.Citations.Any())
                                    {
                                        <div class="citation-block">
                                            <div class="citation-block-label">📎 Nguồn tham khảo</div>
                                            <div class="citation-chips">
                                                @Html.Raw(string.Join(
                                                    "",
                                                    msg.Citations.Select(c =>
                                                        $"<a href='#' class='citation-link' data-chunkid='{c.ChunkId}' data-documentid='{c.DocumentId}' data-number='{c.Number}' title='{System.Net.WebUtility.HtmlEncode(c.DocumentTitle)}'>" +
                                                        $"<span class='chip-num'>{c.Number}</span>" +
                                                        $"<span class='chip-title'>{System.Net.WebUtility.HtmlEncode(c.DocumentTitle)}</span>" +
                                                        $"</a>"
                                                    )
                                                ))
                                            </div>
                                        </div>
                                    }
                                </div>
                            </div>
                            <script>
                                                    document.addEventListener("DOMContentLoaded", function() {
                                                        renderChatMarkdown("@histBubbleId", @Html.Raw(System.Text.Json.JsonSerializer.Serialize(msg.Content)));
                                                    });
                            </script>
                        }
                    }
                </div>

                <div class="chat-input-area p-2 bg-white border-top">
                    <div id="typingIndicator" class="text-muted small mb-1 d-none">
                        🤖 Đang trả lời...
                    </div>

                    <div class="input-group">
                        <textarea id="questionInput" class="form-control" rows="1"
                                  placeholder="Enter để gửi, Shift+Enter xuống dòng..." autocomplete="off"></textarea>
                        <button id="sendBtn" class="btn btn-primary" type="button">➤ Gửi</button>
                    </div>

                    <small class="text-muted mt-1 d-block d-none">
                        Enter để gửi • Shift+Enter xuống dòng • Session: <code>@currentSessionId</code>
                    </small>
                </div>
            </div>
        </div>

        <div class="col-12 col-xl-4 panel-col" data-panel="source">
            <div class="source-panel border d-flex flex-column">
                <div class="source-header">
                    <div>
                        <h6 class="mb-1" id="sourceDocTitle">📎 Nguồn tham khảo</h6>
                        <small class="text-muted" id="sourceDocSubtitle">Bấm vào số trích dẫn trong câu trả lời để xem nguồn</small>
                    </div>
                    <button type="button" class="source-close-btn" id="sourceCloseBtn" title="Đóng">✕</button>
                </div>
                <div class="source-body" id="sourceBody">
                    <div class="source-empty" id="sourceEmptyMsg">
                        <div style="font-size:2rem;">📄</div>
                        <p>Chưa có nguồn nào được chọn</p>
                    </div>
                </div>
            </div>
        </div>

    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/@@microsoft/signalr@8.0.0/dist/browser/signalr.min.js"></script>
    <script>
        const sessionId   = "@currentSessionId";
        const chatBox     = document.getElementById("chatBox");
        const input       = document.getElementById("questionInput");
        const sendBtn     = document.getElementById("sendBtn");
        const typing      = document.getElementById("typingIndicator");
        const emptyMsg    = document.getElementById("emptyMsg");

        function scrollBottom() {
        chatBox.scrollTop = chatBox.scrollHeight;
        }
        scrollBottom();

        function autosizeTextarea(el, maxHeight = 400) {
        if (!el) return;
        el.style.height = 'auto';
        const newH = Math.min(el.scrollHeight, maxHeight);
        el.style.height = newH + 'px';
        }

        function renderChatMarkdown(containerId, markdownText) {
        const container = document.getElementById(containerId);
        if (!container) return;
        if (typeof marked !== 'undefined' && typeof DOMPurify !== 'undefined') {
        marked.setOptions({ gfm: true, breaks: true, smartLists: true, smartypants: false });
        const raw = marked.parse(markdownText ?? '');
        const safe = DOMPurify.sanitize(raw);
        container.classList.add('chat-message-content');
        container.innerHTML = safe;
        } else {
        container.classList.add('chat-message-content');
        container.textContent = (markdownText ?? '').replace(/\\n/g, '\n');
        }
        }

        function appendMessage(role, content) {
        if (emptyMsg) emptyMsg.remove();

        const wrapper = document.createElement("div");
        wrapper.className = `d-flex mb-2 ${role === "user" ? "justify-content-end" : "justify-content-start"}`;

        const bubble = document.createElement("div");
        bubble.style.maxWidth = "75%";

        if (role === "user") {
        bubble.className = "bg-primary text-white rounded p-2 px-3";
        bubble.classList.add('chat-message-content');
        bubble.textContent = content.replace(/\\n/g, '\n');
        } else {
        bubble.className = "bg-white border rounded p-2 px-3";
        const tmpId = 'tmp_' + Date.now() + '_' + Math.random().toString(36).slice(2,6);
        const header = `<small class="text-muted d-block mb-1">🤖 SmartEdu AI</small>`;
        bubble.innerHTML = header + `<div id="${tmpId}"></div>`;
        setTimeout(() => renderChatMarkdown(tmpId, content), 0);
        bubble.dataset.role = 'assistant-bubble';
        }

        wrapper.appendChild(bubble);
        chatBox.appendChild(wrapper);
        scrollBottom();
        return bubble;
        }

        function buildCitationChipsHtml(citations) {
        return citations.map(c =>
        `<a href="#" class="citation-link" data-chunkid="${c.chunkId}" data-documentid="${c.documentId}" data-number="${c.number}" title="${escapeHtml(c.documentTitle)}">` +
        `<span class="chip-num">${c.number}</span>` +
        `<span class="chip-title">${escapeHtml(c.documentTitle)}</span>` +
        `</a>`
        ).join("");
        }

        function appendCitationBlock(bubble, citations) {
        if (!citations || citations.length === 0) return;
        setTimeout(() => {
        const block = document.createElement("div");
        block.className = "citation-block";
        const label = document.createElement("div");
        label.className = "citation-block-label";
        label.textContent = "📎 Nguồn tham khảo";
        const chips = document.createElement("div");
        chips.className = "citation-chips";
        chips.innerHTML = buildCitationChipsHtml(citations);
        block.appendChild(label);
        block.appendChild(chips);
        bubble.appendChild(block);
        scrollBottom();
        }, 10);
        }

        async function sendMessage() {
        const questionRaw = input.value;
        const question = questionRaw.trim();
        if (!question) return;

        const subjectId = document.getElementById("subjectSelect").value;

        input.value = "";
        autosizeTextarea(input);
        sendBtn.disabled = true;
        appendMessage("user", questionRaw);
        typing.classList.remove("d-none");

        try {
        await chatHubReady;

        const res = await fetch("/Chat/Ask", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
        sessionId,
        question,
        subjectId: subjectId ? parseInt(subjectId) : null,
        connectionId: chatHubConnection.connectionId
        })
        });

        const data = await res.json();
        typing.classList.add("d-none");

        if (res.ok) {
        const assistantBubble = appendMessage("assistant", data.answer);
        appendCitationBlock(assistantBubble, data.citations);

        if (data.remainingTokenQuota !== undefined) {
        const tokenSpan = document.getElementById("remainingTokens");
        if (tokenSpan) tokenSpan.textContent = data.remainingTokenQuota.toLocaleString();
        }
        } else {
        appendMessage("assistant", "❌ Lỗi: " + data.error);
        if (data.error && (data.error.includes("token") || data.error.includes("gói"))) {
        const btnDiv = document.createElement("div");
        btnDiv.className = "text-center my-2";
        btnDiv.innerHTML = '<a href="/Package/List" class="btn btn-sm btn-warning">💳 Mua gói dịch vụ</a>';
        chatBox.appendChild(btnDiv);
        scrollBottom();
        }
        }
        } catch (err) {
        typing.classList.add("d-none");
        appendMessage("assistant", "❌ Không thể kết nối server.");
        } finally {
        sendBtn.disabled = false;
        input.focus();
        }
        }

        sendBtn.addEventListener("click", sendMessage);
        autosizeTextarea(input);
        input.addEventListener('input', () => autosizeTextarea(input));
        input.addEventListener("keydown", e => {
        if (e.key === "Enter" && !e.shiftKey) {
        e.preventDefault();
        sendMessage();
        }
        });

        document.addEventListener("DOMContentLoaded", function() {
        const selectEl = document.getElementById("subjectSelect");
        const selectedValue = "@(ViewBag.Subjects?.SelectedValue ?? "")";
        if (selectedValue) selectEl.value = selectedValue;
        });

        function escapeHtml(unsafe) {
        if (!unsafe) return '';
        return String(unsafe)
        .replace(/&/g, "&amp;")
        .replace(/</g, "&lt;")
        .replace(/>/g, "&gt;")
        .replace(/\"/g, "&quot;")
        .replace(/'/g, "&#039;");
        }

        // =====================================================================
        // ===== PANEL TAB SWITCHER (dùng cho <1200px) ============================
        // =====================================================================
        const panelTabBtns = document.querySelectorAll(".panel-tab-btn");
        const panelCols = document.querySelectorAll(".panel-col");

        function switchPanel(target) {
        panelTabBtns.forEach(b => b.classList.toggle("active", b.getAttribute("data-target") === target));
        panelCols.forEach(c => c.classList.toggle("active", c.getAttribute("data-panel") === target));
        }

        panelTabBtns.forEach(btn => {
        btn.addEventListener("click", () => switchPanel(btn.getAttribute("data-target")));
        });

        document.getElementById("sourceCloseBtn")?.addEventListener("click", () => switchPanel("chat"));

        // =====================================================================
        // ===== SOURCE PANEL (click citation -> load + scroll + highlight) =====
        // =====================================================================
        const sourceBody = document.getElementById("sourceBody");
        const sourceDocTitle = document.getElementById("sourceDocTitle");
        const sourceDocSubtitle = document.getElementById("sourceDocSubtitle");

        let currentSourceDocumentId = null;
        let currentLoadedMin = null;
        let currentLoadedMax = null;
        let currentTotalChunks = null;
        let isLoadingMore = false;

        // Ghi thêm data-chunkid vào mỗi block để highlight đúng theo ChunkId (không chỉ ChunkIndex)
        function buildChunkHtmlWithId(documentId, chunk) {
        const loc = chunk.sourceLocation ? escapeHtml(chunk.sourceLocation) : "Không xác định";
        return `<div class="source-chunk" id="chunk-${documentId}-${chunk.chunkIndex}" data-chunk-index="${chunk.chunkIndex}" data-chunk-id="${chunk.chunkId}">
        <div class="source-chunk-location">📍 ${loc}</div>
        <div class="source-chunk-content">${escapeHtml(chunk.content)}</div>
        </div>`;
        }

        function renderSourcePanelFinal(data, highlightChunkId) {
        currentSourceDocumentId = data.documentId;
        currentTotalChunks = data.totalChunks;

        if (data.chunks.length > 0) {
        currentLoadedMin = data.chunks[0].chunkIndex;
        currentLoadedMax = data.chunks[data.chunks.length - 1].chunkIndex;
        } else {
        currentLoadedMin = 0;
        currentLoadedMax = -1;
        }

        sourceDocTitle.textContent = "📎 " + data.documentTitle;
        sourceDocSubtitle.textContent = `${data.totalChunks} đoạn nội dung`;

        sourceBody.innerHTML = data.chunks.map(c => buildChunkHtmlWithId(data.documentId, c)).join("");

        if (highlightChunkId) {
        setTimeout(() => doHighlight(highlightChunkId), 60);
        }
        }

        function doHighlight(chunkId) {
        const el = sourceBody.querySelector(`.source-chunk[data-chunk-id="${chunkId}"]`);
        if (!el) return;
        el.scrollIntoView({ behavior: "smooth", block: "center" });
        el.classList.add("highlight");
        setTimeout(() => el.classList.remove("highlight"), 2500);
        }

        async function openSourcePanel(documentId, chunkId, range = 15) {
        if (window.innerWidth < 1200) switchPanel("source");

        sourceBody.innerHTML = `<div class="source-empty"><div style="font-size:2rem;">⏳</div><p>Đang tải nguồn...</p></div>`;

        try {
        const resp = await fetch(`/Document/GetChunksAroundCitation?documentId=${documentId}&chunkId=${chunkId}&range=${range}`);
        if (!resp.ok) {
        sourceBody.innerHTML = `<div class="source-empty"><div style="font-size:2rem;">⚠️</div><p>Không thể tải nguồn (bạn có thể không có quyền truy cập).</p></div>`;
        return;
        }
        const data = await resp.json();
        renderSourcePanelFinal(data, chunkId);
        } catch (err) {
        console.error(err);
        sourceBody.innerHTML = `<div class="source-empty"><div style="font-size:2rem;">⚠️</div><p>Lỗi kết nối khi tải nguồn.</p></div>`;
        }
        }

        // Infinite scroll: load thêm khi cuộn gần đầu/cuối panel nguồn
        sourceBody.addEventListener("scroll", async function () {
        if (isLoadingMore || currentSourceDocumentId == null) return;

        const nearTop = sourceBody.scrollTop < 60;
        const nearBottom = sourceBody.scrollHeight - sourceBody.scrollTop - sourceBody.clientHeight < 60;

        if (nearTop && currentLoadedMin > 0) {
        isLoadingMore = true;
        const oldScrollHeight = sourceBody.scrollHeight;
        const fromIdx = Math.max(0, currentLoadedMin - 15);
        const toIdx = currentLoadedMin - 1;

        try {
        const resp = await fetch(`/Document/GetChunksRange?documentId=${currentSourceDocumentId}&fromIndex=${fromIdx}&toIndex=${toIdx}`);
        if (resp.ok) {
        const data = await resp.json();
        if (data.chunks.length > 0) {
        const html = data.chunks.map(c => buildChunkHtmlWithId(currentSourceDocumentId, c)).join("");
        sourceBody.insertAdjacentHTML("afterbegin", html);
        currentLoadedMin = data.chunks[0].chunkIndex;
        sourceBody.scrollTop += (sourceBody.scrollHeight - oldScrollHeight);
        } else {
        currentLoadedMin = 0;
        }
        }
        } catch (err) {
        console.error("Lỗi load thêm (top):", err);
        } finally {
        isLoadingMore = false;
        }
        } else if (nearBottom && currentLoadedMax < currentTotalChunks - 1) {
        isLoadingMore = true;
        const fromIdx = currentLoadedMax + 1;
        const toIdx = Math.min(currentTotalChunks - 1, currentLoadedMax + 15);

        try {
        const resp = await fetch(`/Document/GetChunksRange?documentId=${currentSourceDocumentId}&fromIndex=${fromIdx}&toIndex=${toIdx}`);
        if (resp.ok) {
        const data = await resp.json();
        if (data.chunks.length > 0) {
        const html = data.chunks.map(c => buildChunkHtmlWithId(currentSourceDocumentId, c)).join("");
        sourceBody.insertAdjacentHTML("beforeend", html);
        currentLoadedMax = data.chunks[data.chunks.length - 1].chunkIndex;
        } else {
        currentLoadedMax = currentTotalChunks - 1;
        }
        }
        } catch (err) {
        console.error("Lỗi load thêm (bottom):", err);
        } finally {
        isLoadingMore = false;
        }
        }
        });

        // Click handler cho citation-link: mở/scroll panel nguồn (thay hoàn toàn modal cũ)
        document.addEventListener('click', function (e) {
        const el = e.target.closest('.citation-link');
        if (!el) return;
        e.preventDefault();

        const chunkId = parseInt(el.getAttribute('data-chunkid'), 10);
        const documentId = parseInt(el.getAttribute('data-documentid'), 10);
        if (!chunkId || !documentId) return;

        if (currentSourceDocumentId === documentId) {
        const existing = sourceBody.querySelector(`.source-chunk[data-chunk-id="${chunkId}"]`);
        if (existing) {
        if (window.innerWidth < 1200) switchPanel("source");
        doHighlight(chunkId);
        return;
        }
        }

        openSourcePanel(documentId, chunkId);
        });

        // === SignalR: đồng bộ đa tab cùng session + cập nhật token quota real-time ===
        const chatHubConnection = new signalR.HubConnectionBuilder()
        .withUrl("/hubs/chat")
        .withAutomaticReconnect()
        .build();

        chatHubConnection.on("ReceiveMessage", (msg) => {
        if (msg.role === "assistant") {
        const bubble = appendMessage("assistant", msg.content);
        appendCitationBlock(bubble, msg.citations);
        } else {
        appendMessage(msg.role, msg.content);
        }
        });

        const chatHubReady = chatHubConnection.start()
        .then(() => chatHubConnection.invoke("JoinSession", sessionId))
        .catch(err => console.error("ChatHub connect failed:", err));

        const notifyHubConnection = new signalR.HubConnectionBuilder()
        .withUrl("/hubs/notifications")
        .withAutomaticReconnect()
        .build();

        notifyHubConnection.on("TokenQuotaUpdated", (data) => {
        const tokenSpan = document.getElementById("remainingTokens");
        if (tokenSpan) tokenSpan.textContent = data.remainingTokenQuota.toLocaleString();
        });

        notifyHubConnection.on("PaymentCompleted", (data) => {
        const tokenSpan = document.getElementById("remainingTokens");
        if (tokenSpan && data.remainingTokenQuota !== undefined) {
        tokenSpan.textContent = data.remainingTokenQuota.toLocaleString();
        }
        });

        function buildSessionCardHtml(s) {
        const isActive = s.sessionId === sessionId;
        return `
        <div class="card mb-2 shadow-sm ${isActive ? 'border-primary' : ''}" data-session-card="${s.sessionId}">
        <div class="card-body p-2">
        <div class="d-flex justify-content-between">
        <a href="/Chat?sessionId=${encodeURIComponent(s.sessionId)}"
        class="text-decoration-none text-dark fw-bold small text-truncate"
        style="max-width:150px">
        ${escapeHtml(s.title || 'Phiên mới')}
        </a>
        <form action="/Chat/DeleteSession" method="post" class="d-inline">
        <input type="hidden" name="__RequestVerificationToken" value="${getAntiForgeryToken()}" />
        <input type="hidden" name="sessionId" value="${s.sessionId}" />
        <button type="submit" class="btn btn-sm btn-link text-danger p-0" onclick="return confirm('Xóa phiên này?')">🗑️</button>
        </form>
        </div>
        <small class="text-muted">📚 ${escapeHtml(s.subjectName || '')} | 💬 ${s.messageCount} tin</small>
        </div>
        </div>`;
        }

        function getAntiForgeryToken() {
        const el = document.querySelector('input[name="__RequestVerificationToken"]');
        return el ? el.value : '';
        }

        const sidebarList = document.querySelector('.sidebar-list');

        function upsertSessionCard(s) {
        if (!sidebarList) return;
        const existing = sidebarList.querySelector(`[data-session-card="${s.sessionId}"]`);
        const html = buildSessionCardHtml(s);

        if (existing) {
        existing.outerHTML = html;
        const updated = sidebarList.querySelector(`[data-session-card="${s.sessionId}"]`);
        if (updated) sidebarList.prepend(updated);
        } else {
        sidebarList.insertAdjacentHTML('afterbegin', html);
        }
        }

        function removeSessionCard(sid) {
        if (!sidebarList) return;
        const el = sidebarList.querySelector(`[data-session-card="${sid}"]`);
        if (el) el.remove();

        if (sid === sessionId) {
        window.location.href = '/Chat';
        }
        }

        notifyHubConnection.on("SessionUpsert", (s) => {
        upsertSessionCard(s);
        });

        notifyHubConnection.on("SessionDeleted", (data) => {
        removeSessionCard(data.sessionId);
        });

        notifyHubConnection.start().catch(err => console.error("NotificationHub connect failed:", err));
    </script>
}