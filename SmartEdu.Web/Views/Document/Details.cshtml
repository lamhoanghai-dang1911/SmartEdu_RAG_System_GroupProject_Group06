@model SmartEdu.Shared.DTOs.DocumentDto
@{
    ViewData["Title"] = "Chi tiết tài liệu";
}
<div class="container mt-4" style="max-width:700px">
    <h2>🔍 Chi tiết tài liệu</h2>
    <hr />

    <dl class="row">
        <dt class="col-sm-4">Tiêu đề</dt>
        <dd class="col-sm-8">@Model.Title</dd>

        <dt class="col-sm-4">File gốc</dt>
        <dd class="col-sm-8">@Model.FileName</dd>

        <dt class="col-sm-4">Loại file</dt>
        <dd class="col-sm-8">
            <span class="badge bg-secondary">@Model.FileType.ToUpper()</span>
        </dd>

        <dt class="col-sm-4">Kích thước</dt>
        <dd class="col-sm-8">@($"{Model.FileSize / 1024.0:F1}") KB</dd>

        <dt class="col-sm-4">Môn học</dt>
        <dd class="col-sm-8">@Model.SubjectName</dd>

        <dt class="col-sm-4">Trạng thái</dt>
        <dd class="col-sm-8">
            @{
                var (badge, label) = Model.Status.ToString() switch
                {
                    "Pending" => ("warning", "⏳ Chờ xử lý"),
                    "Processing" => ("info", "⚙️ Đang xử lý"),
                    "Ready" => ("success", "✅ Sẵn sàng"),
                    "Failed" => ("danger", "❌ Lỗi"),
                    _ => ("secondary", Model.Status.ToString())
                };
            }
            <span class="badge bg-@badge">@label</span>
        </dd>

        <dt class="col-sm-4">Ngày upload</dt>
        <dd class="col-sm-8">@Model.CreatedAt.ToVietnamTime().ToString("dd/MM/yyyy HH:mm")</dd>
    </dl>

    <div class="mt-4">
        <a asp-action="Index" class="btn btn-secondary">← Quay lại</a>
    </div>
</div>