@model SmartEdu.Shared.DTOs.DocumentDto
@{
    ViewData["Title"] = "Chi tiết tài liệu";
    var extension = (Model.FileType ?? string.Empty).TrimStart('.').ToUpperInvariant();
    var fileIcon = extension switch
    {
        "PDF" => "bi-file-earmark-pdf",
        "DOCX" => "bi-file-earmark-word",
        "PPTX" => "bi-file-earmark-slides",
        _ => "bi-file-earmark-text"
    };
    var (statusClass, statusIcon, statusLabel, statusDescription) = Model.Status.ToString() switch
    {
        "Pending" => ("pending", "bi-clock", "Chờ xử lý", "Tài liệu đang chờ được đưa vào hàng xử lý."),
        "Processing" => ("processing", "bi-arrow-repeat", "Đang xử lý", "Hệ thống đang tạo nội dung và embedding cho tài liệu."),
        "Ready" => ("ready", "bi-check2", "Sẵn sàng", "Tài liệu đã có thể được sử dụng trong Chat RAG."),
        "Failed" => ("failed", "bi-exclamation-circle", "Xử lý thất bại", "Quá trình xử lý gặp lỗi và cần được thử lại."),
        _ => ("default", "bi-info-circle", Model.Status.ToString(), "Trạng thái hiện tại của tài liệu.")
    };
    var fileSize = Model.FileSize >= 1024 * 1024
        ? $"{Model.FileSize / 1024d / 1024d:F2} MB"
        : $"{Model.FileSize / 1024d:F1} KB";
}

<style>
    .document-detail { max-width: 1040px; margin: 0 auto; padding: 10px 0 48px; }
    .document-back { display: inline-flex; align-items: center; gap: 6px; margin-bottom: 16px; color: #78827b; font-size: 11px; text-decoration: none; }
    .document-back:hover { color: #246b4b; }
    .document-detail-head { display: flex; justify-content: space-between; align-items: flex-start; gap: 20px; margin-bottom: 18px; }
    .document-title-wrap { display: flex; align-items: flex-start; gap: 13px; min-width: 0; }
    .document-file-icon { width: 46px; height: 46px; display: grid; place-items: center; flex: 0 0 auto; color: #246b4b; border: 1px solid #d6e2da; border-radius: 12px; background: #ebf3ee; font-size: 20px; }
    .document-eyebrow { margin-bottom: 4px; color: #7e8881; font-size: 9px; font-weight: 750; letter-spacing: .07em; text-transform: uppercase; }
    .document-detail-head h1 { max-width: 670px; margin: 0 0 6px; overflow-wrap: anywhere; color: #222b25; font-family: 'Sora', sans-serif; font-size: clamp(21px, 3vw, 28px); font-weight: 720; letter-spacing: -.035em; }
    .document-original-name { display: flex; align-items: center; gap: 5px; color: #7d8780; font-size: 10px; overflow-wrap: anywhere; }
    .document-actions { display: flex; flex: 0 0 auto; gap: 7px; }
    .document-actions .btn { min-height: 39px; display: inline-flex; align-items: center; gap: 6px; padding: 8px 12px; border-radius: 9px; font-size: 10px; }
    .document-grid { display: grid; grid-template-columns: minmax(0, 1.4fr) minmax(270px, .6fr); gap: 15px; align-items: start; }
    .document-panel { border: 1px solid #dde5df; border-radius: 14px; background: #fff; box-shadow: 0 7px 24px rgba(26,57,40,.045); overflow: hidden; }
    .document-panel-head { padding: 14px 16px; border-bottom: 1px solid #e5ebe7; background: #fbfcfb; }
    .document-panel-head h2 { margin: 0; color: #353f38; font-family: 'Sora', sans-serif; font-size: 12px; }
    .document-meta { display: grid; grid-template-columns: 1fr 1fr; }
    .document-meta-item { min-height: 84px; padding: 16px; border-bottom: 1px solid #e8ede9; }
    .document-meta-item:nth-child(odd) { border-right: 1px solid #e8ede9; }
    .document-meta-item:nth-last-child(-n+2) { border-bottom: 0; }
    .document-meta-label { display: flex; align-items: center; gap: 6px; margin-bottom: 8px; color: #89928c; font-size: 9px; font-weight: 720; letter-spacing: .04em; text-transform: uppercase; }
    .document-meta-label i { color: #789084; font-size: 10px; }
    .document-meta-value { color: #374139; font-size: 12px; font-weight: 650; overflow-wrap: anywhere; }
    .file-type-chip { display: inline-flex; align-items: center; padding: 4px 8px; color: #4e6558; border: 1px solid #d6e1da; border-radius: 7px; background: #f5f8f6; font-size: 9px; font-weight: 750; }
    .status-card { padding: 17px; }
    .status-indicator { width: 38px; height: 38px; display: grid; place-items: center; margin-bottom: 12px; border-radius: 10px; font-size: 16px; }
    .status-indicator.ready { color: #246b4b; background: #e8f3ec; }
    .status-indicator.processing { color: #37658b; background: #eaf2f8; }
    .status-indicator.pending { color: #8a6829; background: #faf3df; }
    .status-indicator.failed { color: #a24c45; background: #faecea; }
    .status-indicator.default { color: #637068; background: #eff2f0; }
    .status-indicator.processing i { animation: status-spin 1.5s linear infinite; }
    @@keyframes status-spin { to { transform: rotate(360deg); } }
    .status-card h3 { margin: 0 0 5px; color: #343e37; font-family: 'Sora', sans-serif; font-size: 13px; }
    .status-card p { margin: 0; color: #818b84; font-size: 10px; line-height: 1.6; }
    .document-reference { display: grid; gap: 9px; padding: 14px; }
    .reference-row { display: flex; justify-content: space-between; align-items: center; gap: 12px; color: #7d8780; font-size: 9px; }
    .reference-row strong { color: #414b44; font-size: 10px; font-weight: 650; text-align: right; }
    @@media (max-width: 760px) { .document-detail-head { flex-direction: column; } .document-actions { padding-left: 59px; } .document-grid { grid-template-columns: 1fr; } }
    @@media (max-width: 500px) { .document-actions { width: 100%; padding-left: 0; } .document-actions .btn { flex: 1; justify-content: center; } .document-meta { grid-template-columns: 1fr; } .document-meta-item, .document-meta-item:nth-child(odd), .document-meta-item:nth-last-child(-n+2) { border-right: 0; border-bottom: 1px solid #e8ede9; } .document-meta-item:last-child { border-bottom: 0; } }
    @@media (prefers-reduced-motion: reduce) { .status-indicator.processing i { animation: none; } }
</style>

<div class="document-detail">
    <a asp-action="Index" class="document-back"><i class="bi bi-arrow-left"></i> Quay lại danh sách tài liệu</a>

    <header class="document-detail-head">
        <div class="document-title-wrap">
            <span class="document-file-icon"><i class="bi @fileIcon"></i></span>
            <div>
                <div class="document-eyebrow">Tài liệu #@Model.Id</div>
                <h1>@Model.Title</h1>
                <div class="document-original-name"><i class="bi bi-paperclip"></i>@Model.FileName</div>
            </div>
        </div>
        <div class="document-actions">
            <a asp-action="Download" asp-route-id="@Model.Id" class="btn btn-primary"><i class="bi bi-download"></i> Tải file gốc</a>
            <a asp-action="Index" asp-route-subjectId="@Model.SubjectId" class="btn btn-light"><i class="bi bi-list-ul"></i> Danh sách</a>
        </div>
    </header>

    @await Html.PartialAsync("Partial/_Alerts")

    <div class="document-grid">
        <section class="document-panel">
            <div class="document-panel-head"><h2>Thông tin tài liệu</h2></div>
            <div class="document-meta">
                <div class="document-meta-item"><div class="document-meta-label"><i class="bi bi-book"></i>Môn học</div><div class="document-meta-value">@Model.SubjectName</div></div>
                <div class="document-meta-item"><div class="document-meta-label"><i class="bi bi-calendar3"></i>Ngày tải lên</div><div class="document-meta-value">@Model.CreatedAt.ToVietnamTime().ToString("dd/MM/yyyy, HH:mm")</div></div>
                <div class="document-meta-item"><div class="document-meta-label"><i class="bi bi-file-earmark"></i>Định dạng</div><div class="document-meta-value"><span class="file-type-chip">@(string.IsNullOrWhiteSpace(extension) ? "Không xác định" : extension)</span></div></div>
                <div class="document-meta-item"><div class="document-meta-label"><i class="bi bi-device-ssd"></i>Kích thước</div><div class="document-meta-value">@fileSize</div></div>
                <div class="document-meta-item"><div class="document-meta-label"><i class="bi bi-card-text"></i>Tiêu đề</div><div class="document-meta-value">@Model.Title</div></div>
                <div class="document-meta-item"><div class="document-meta-label"><i class="bi bi-file-text"></i>File gốc</div><div class="document-meta-value">@Model.FileName</div></div>
            </div>
        </section>

        <aside class="d-grid gap-3">
            <section class="document-panel">
                <div class="document-panel-head"><h2>Trạng thái xử lý</h2></div>
                <div class="status-card">
                    <span class="status-indicator @statusClass"><i class="bi @statusIcon"></i></span>
                    <h3>@statusLabel</h3>
                    <p>@statusDescription</p>
                </div>
            </section>
            <section class="document-panel">
                <div class="document-panel-head"><h2>Tham chiếu</h2></div>
                <div class="document-reference">
                    <div class="reference-row"><span>Mã tài liệu</span><strong>#@Model.Id</strong></div>
                    <div class="reference-row"><span>Mã môn học</span><strong>#@Model.SubjectId</strong></div>
                    <div class="reference-row"><span>Định dạng</span><strong>@extension</strong></div>
                </div>
            </section>
        </aside>
    </div>
</div>
