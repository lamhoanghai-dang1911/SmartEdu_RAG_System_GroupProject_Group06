@{
    ViewData["Title"] = "Upload tài liệu";
}

<style>
    :root {
        --brand-blue: #0d6efd;
        --brand-purple: #6610f2;
        --ink-navy: #0b1120;
        --amber: #ffb648;
        --paper: #f7f8fc;
        --slate: #5a6072;
        --slate-light: #9aa0b4;
        --success: #1fae63;
        --danger: #e5484d;
    }

    @@keyframes fadeUp {
        from {
            opacity: 0;
            transform: translateY(10px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .page-head h2 {
        font-family: 'Sora', sans-serif;
        font-weight: 700;
        font-size: 1.5rem;
        color: #12162b;
        margin-bottom: 1.5rem;
    }

    .upload-card {
        background: #fff;
        border-radius: 16px;
        box-shadow: 0 10px 32px -12px rgba(11, 17, 32, 0.14);
        padding: 1.85rem;
        opacity: 0;
        animation: fadeUp 0.45s ease forwards;
    }

    .form-label {
        font-weight: 600;
        font-size: 0.88rem;
        color: #33384f;
        margin-bottom: 0.4rem;
    }

    .form-control,
    .form-select {
        border: 1.5px solid #e3e5ef;
        border-radius: 10px;
        padding: 0.6rem 0.85rem;
        font-size: 0.95rem;
        transition: border-color 0.2s ease, box-shadow 0.2s ease;
    }

        .form-control:focus,
        .form-select:focus {
            border-color: var(--brand-blue);
            box-shadow: 0 0 0 4px rgba(13, 110, 253, 0.12);
        }

        .form-control[type="file"] {
            padding: 0.5rem 0.85rem;
        }

    .alert-danger {
        border: none;
        border-radius: 10px;
        background: rgba(229, 72, 77, 0.08);
        color: var(--danger);
        border-left: 3px solid var(--danger);
        font-size: 0.88rem;
    }

    /* ===== Upload limits info box ===== */
    .upload-limits-box {
        background: var(--paper);
        border-radius: 12px;
        padding: 0.75rem 0.9rem;
        margin-bottom: 1rem;
        display: none;
    }

        .upload-limits-box.show {
            display: block;
            animation: fadeUp 0.3s ease forwards;
        }

    .upload-limits-label {
        font-size: 0.74rem;
        font-weight: 700;
        color: var(--slate-light);
        text-transform: uppercase;
        letter-spacing: 0.03em;
        margin-bottom: 0.5rem;
        display: flex;
        align-items: center;
        gap: 0.35rem;
    }

    .upload-limits-chips {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
    }

    .limit-chip {
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
        background: #fff;
        border: 1px solid #e3e5ef;
        border-radius: 999px;
        padding: 0.32rem 0.75rem;
        font-size: 0.8rem;
        font-weight: 600;
        color: #33384f;
        transition: border-color 0.15s ease, background 0.15s ease;
    }

        .limit-chip.matched {
            border-color: var(--brand-blue);
            background: rgba(13, 110, 253, 0.06);
            color: var(--brand-blue);
        }

    .file-size-warning {
        font-size: 0.82rem;
        color: var(--danger);
        margin-top: 0.4rem;
        display: none;
    }

        .file-size-warning.show {
            display: block;
        }

    .btn-upload {
        border: none;
        border-radius: 12px;
        padding: 0.7rem 1.5rem;
        font-weight: 700;
        color: #fff;
        background: linear-gradient(120deg, var(--brand-blue), var(--brand-purple));
        box-shadow: 0 10px 24px -10px rgba(13, 110, 253, 0.5);
        transition: transform 0.15s ease, filter 0.15s ease, opacity 0.15s ease;
    }

        .btn-upload:hover:not(:disabled) {
            transform: translateY(-1px);
            filter: brightness(1.07);
        }

        .btn-upload:disabled {
            opacity: 0.5;
            box-shadow: none;
            cursor: not-allowed;
        }

    .btn-back {
        border-radius: 12px;
        border: none;
        background: #eef0f6;
        color: #33384f;
        font-weight: 600;
        padding: 0.7rem 1.4rem;
        transition: background 0.15s ease, transform 0.15s ease;
    }

        .btn-back:hover {
            background: #e2e5f0;
            color: #12162b;
            transform: translateY(-1px);
        }

    /* ===== Duplicate modal ===== */
    #duplicateModal .modal-content {
        border: none;
        border-radius: 16px;
        overflow: hidden;
    }

    #duplicateModal .modal-header {
        background: linear-gradient(120deg, var(--ink-navy), #171d3d);
        color: #fff;
        border: none;
        padding: 1.1rem 1.4rem;
    }

    #duplicateModal .modal-title {
        font-family: 'Sora', sans-serif;
        font-weight: 700;
        font-size: 1.05rem;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    #dupMessage {
        font-size: 0.92rem;
        color: #33384f;
    }

    #dupOldStatus {
        border: none;
        border-radius: 10px;
        font-size: 0.85rem;
    }

        #dupOldStatus.alert-success {
            background: rgba(31, 174, 99, 0.09);
            color: var(--success);
            border-left: 3px solid var(--success);
        }

        #dupOldStatus.alert-warning {
            background: rgba(255, 182, 72, 0.14);
            color: #b8790a;
            border-left: 3px solid var(--amber);
        }

        #dupOldStatus a {
            color: inherit;
            font-weight: 600;
            text-decoration: underline;
        }

    .action-choice-label {
        font-size: 0.82rem;
        font-weight: 600;
        color: var(--slate);
        text-transform: uppercase;
        letter-spacing: 0.02em;
        margin: 1.1rem 0 0.6rem;
    }

    .action-options {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 0.7rem;
    }

    .action-option {
        position: relative;
        border: 1.5px solid #e3e5ef;
        border-radius: 12px;
        padding: 0.9rem 0.85rem;
        cursor: pointer;
        transition: border-color 0.18s ease, background 0.18s ease, transform 0.12s ease;
        text-align: left;
    }

        .action-option:hover {
            border-color: rgba(13, 110, 253, 0.35);
            transform: translateY(-1px);
        }

        .action-option .opt-icon {
            font-size: 1.3rem;
            margin-bottom: 0.4rem;
            display: block;
        }

        .action-option .opt-title {
            font-family: 'Sora', sans-serif;
            font-weight: 700;
            font-size: 0.9rem;
            color: #12162b;
            margin-bottom: 0.2rem;
        }

        .action-option .opt-desc {
            font-size: 0.78rem;
            color: var(--slate-light);
            line-height: 1.4;
        }

        .action-option .opt-check {
            position: absolute;
            top: 0.7rem;
            right: 0.7rem;
            width: 18px;
            height: 18px;
            border-radius: 50%;
            border: 1.5px solid #d7dbe8;
            transition: border-color 0.18s ease, background 0.18s ease;
        }

        .action-option.selected {
            border-color: var(--brand-blue);
            background: rgba(13, 110, 253, 0.05);
        }

            .action-option.selected .opt-check {
                border-color: var(--brand-blue);
                background: var(--brand-blue);
            }

                .action-option.selected .opt-check::after {
                    content: "✓";
                    display: block;
                    color: #fff;
                    font-size: 0.68rem;
                    font-weight: 700;
                    text-align: center;
                    line-height: 18px;
                }

    #duplicateModal .modal-footer {
        border: none;
        padding: 1rem 1.4rem;
        display: flex;
        justify-content: space-between;
        gap: 0.6rem;
    }

    .btn-cancel-upload {
        border: none;
        border-radius: 999px;
        background: rgba(229, 72, 77, 0.08);
        color: var(--danger);
        font-weight: 600;
        padding: 0.55rem 1.2rem;
        font-size: 0.86rem;
        transition: background 0.15s ease;
    }

        .btn-cancel-upload:hover {
            background: rgba(229, 72, 77, 0.15);
            color: var(--danger);
        }

    .btn-confirm-action {
        border: none;
        border-radius: 999px;
        background: linear-gradient(120deg, var(--brand-blue), var(--brand-purple));
        color: #fff;
        font-weight: 700;
        padding: 0.55rem 1.4rem;
        font-size: 0.86rem;
        box-shadow: 0 8px 20px -10px rgba(13, 110, 253, 0.5);
        transition: transform 0.15s ease, filter 0.15s ease;
    }

        .btn-confirm-action:hover {
            transform: translateY(-1px);
            filter: brightness(1.07);
            color: #fff;
        }

    @@media (prefers-reduced-motion: reduce) {
        *, *::before, *::after {
            animation-duration: 0.01ms !important;
            transition-duration: 0.01ms !important;
        }
    }

    /* Upload workspace */
    .upload-page { max-width: 1080px; margin: 0 auto; padding: 12px 0 48px; }
    .upload-breadcrumb { display: inline-flex; align-items: center; gap: 7px; margin-bottom: 18px; color: #778179; font-size: 12px; text-decoration: none; }
    .upload-breadcrumb:hover { color: #246b4b; }
    .upload-heading { margin-bottom: 24px; }
    .upload-heading h1 { margin: 0 0 7px; color: #202822; font-family: 'Sora', sans-serif; font-size: clamp(24px, 3vw, 31px); font-weight: 700; letter-spacing: -.035em; }
    .upload-heading p { max-width: 650px; margin: 0; color: #6f7972; font-size: 13px; line-height: 1.65; }
    .upload-layout { display: grid; grid-template-columns: minmax(0, 1.6fr) minmax(250px, .75fr); gap: 18px; align-items: start; }
    .upload-card { padding: 0; border: 1px solid #dde5df; border-radius: 15px; box-shadow: 0 8px 28px rgba(26,57,40,.055); animation: none; opacity: 1; overflow: hidden; }
    .upload-card-head { display: flex; align-items: center; gap: 12px; padding: 18px 20px; border-bottom: 1px solid #e5ebe7; background: #fbfcfb; }
    .upload-card-head-icon { width: 38px; height: 38px; display: grid; place-items: center; flex: 0 0 auto; color: #246b4b; border: 1px solid #d5e2da; border-radius: 10px; background: #edf5f0; font-size: 17px; }
    .upload-card-head h2 { margin: 0 0 2px; font-family: 'Sora', sans-serif; font-size: 14px; font-weight: 700; }
    .upload-card-head p { margin: 0; color: #879089; font-size: 11px; }
    .upload-form-body { padding: 21px 20px 20px; }
    .upload-form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 15px; }
    .upload-field { margin-bottom: 17px; }
    .upload-field .form-label { display: flex; justify-content: space-between; margin-bottom: 7px; color: #39423c; font-size: 12px; font-weight: 650; }
    .field-required { color: #9a5b4e; font-size: 10px; font-weight: 600; }
    .upload-field .form-control, .upload-field .form-select { min-height: 44px; padding: 9px 12px; border: 1px solid #d8e1db; border-radius: 9px; background-color: #fff; color: #2d3630; font-size: 13px; }
    .upload-field .form-control:focus, .upload-field .form-select:focus { border-color: #4c8165; box-shadow: 0 0 0 3px rgba(36,107,75,.10); }
    .file-drop { min-height: 158px; display: flex; align-items: center; justify-content: center; padding: 22px; border: 1.5px dashed #bdccc2; border-radius: 12px; background: #f9fbf9; cursor: pointer; transition: .18s ease; text-align: center; }
    .file-drop:hover, .file-drop.has-file { border-color: #4c8165; background: #f2f7f4; }
    .file-drop-icon { width: 42px; height: 42px; display: grid; place-items: center; margin: 0 auto 10px; color: #246b4b; border-radius: 12px; background: #e6f0ea; font-size: 19px; }
    .file-drop strong { display: block; margin-bottom: 4px; color: #303a33; font-size: 13px; }
    .file-drop span { color: #818b84; font-size: 11px; }
    .file-drop-meta { display: block; margin-top: 8px; color: #246b4b !important; font-weight: 650; }
    .upload-limits-box { margin: 12px 0 0; padding: 10px 12px; border: 1px solid #e1e8e3; border-radius: 10px; background: #fafcfa; }
    .upload-limits-label { color: #778179; font-size: 9px; }
    .limit-chip { padding: 4px 8px; border-color: #dde5df; border-radius: 7px; color: #5f6962; font-size: 10px; }
    .limit-chip.matched { color: #246b4b; border-color: #8eb19e; background: #eef6f1; }
    .upload-actions { display: flex; justify-content: flex-end; gap: 8px; padding-top: 4px; }
    .btn-upload, .btn-back { min-height: 41px; display: inline-flex; align-items: center; gap: 7px; padding: 9px 15px; border-radius: 9px; font-size: 12px; box-shadow: none; }
    .btn-upload { background: #246b4b; }
    .btn-upload:hover:not(:disabled) { color: #fff; background: #1c583d; filter: none; }
    .btn-back { order: -1; color: #58625b; border: 1px solid #dbe3dd; background: #fff; }
    .upload-note { padding: 18px; border: 1px solid #dde5df; border-radius: 15px; background: #fff; box-shadow: 0 7px 24px rgba(26,57,40,.04); }
    .upload-note h3 { margin: 0 0 14px; font-family: 'Sora', sans-serif; font-size: 13px; }
    .upload-note-list { display: grid; gap: 14px; }
    .upload-note-item { display: grid; grid-template-columns: 28px 1fr; gap: 10px; }
    .upload-note-number { width: 28px; height: 28px; display: grid; place-items: center; color: #246b4b; border-radius: 8px; background: #edf5f0; font-size: 10px; font-weight: 750; }
    .upload-note-item strong { display: block; margin-bottom: 2px; color: #3b453e; font-size: 11px; }
    .upload-note-item p { margin: 0; color: #828b85; font-size: 10px; line-height: 1.5; }
    .leader-note { display: flex; gap: 8px; margin-top: 16px; padding: 10px; color: #526158; border-radius: 9px; background: #f4f7f5; font-size: 10px; line-height: 1.5; }
    .leader-note i { color: #246b4b; }
    #uploadErrorAlert, #uploadPermissionAlert { font-size: 11px; }
    @@media (max-width: 850px) { .upload-layout { grid-template-columns: 1fr; } .upload-note { order: -1; } }
    @@media (max-width: 600px) { .upload-form-grid { grid-template-columns: 1fr; gap: 0; } .upload-actions { flex-direction: column-reverse; } .btn-upload, .btn-back { justify-content: center; width: 100%; } }
</style>

<div class="upload-page">
    <a asp-action="Index" class="upload-breadcrumb"><i class="bi bi-arrow-left"></i> Danh sách tài liệu</a>

    <header class="upload-heading">
        <h1>Thêm tài liệu môn học</h1>
        <p>Tải lên tài liệu giảng dạy để hệ thống chuẩn bị nội dung cho tra cứu và hỏi đáp. Tài liệu sẽ được kiểm tra trước khi đưa vào xử lý.</p>
    </header>

    <div class="upload-layout">
    <section class="upload-card">
        <div class="upload-card-head">
            <div class="upload-card-head-icon"><i class="bi bi-file-earmark-arrow-up"></i></div>
            <div><h2>Thông tin tài liệu</h2><p>Các trường có dấu bắt buộc cần được điền đầy đủ.</p></div>
        </div>
        <div class="upload-form-body">
            <div id="uploadErrorAlert" class="alert alert-danger" style="display:none;"></div>

            <form id="uploadForm" method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()
                <div class="upload-form-grid">
                    <div class="upload-field">
                        <label class="form-label" for="documentTitle"><span>Tiêu đề tài liệu</span><span class="field-required">Bắt buộc</span></label>
                        <input id="documentTitle" name="title" class="form-control" placeholder="Ví dụ: Bài giảng chương 1" required />
                    </div>
                    <div class="upload-field">
                        <label class="form-label" for="subjectSelect"><span>Môn học</span><span class="field-required">Bắt buộc</span></label>
                        <select id="subjectSelect" name="subjectId" class="form-select" required><option value="">Chọn môn học phụ trách</option></select>
                    </div>
                </div>

                <div id="uploadPermissionAlert" class="alert alert-danger" style="display:none;"></div>

                <div class="upload-field">
                    <label class="form-label" for="fileInput"><span>File tài liệu</span><span class="field-required">PDF, DOCX, PPTX</span></label>
                    <label class="file-drop" id="fileDrop" for="fileInput">
                        <span><span class="file-drop-icon"><i class="bi bi-cloud-arrow-up"></i></span><strong id="fileName">Chọn file từ máy tính</strong><span>Nhấn vào đây để duyệt file</span><span class="file-drop-meta" id="fileMeta"></span></span>
                    </label>
                    <input name="file" id="fileInput" type="file" class="visually-hidden" accept=".pdf,.docx,.pptx" required />
                    <div id="fileSizeWarning" class="file-size-warning"></div>
                    <div id="uploadLimitsBox" class="upload-limits-box"><div class="upload-limits-label"><i class="bi bi-info-circle"></i> Giới hạn theo định dạng</div><div id="uploadLimitsChips" class="upload-limits-chips"></div></div>
                </div>

                <div class="upload-actions">
                    <a asp-action="Index" class="btn btn-back"><i class="bi bi-x"></i> Hủy</a>
                    <button type="submit" id="uploadBtn" class="btn btn-upload" disabled><i class="bi bi-arrow-up-circle"></i> Tải tài liệu lên</button>
                </div>
            </form>
        </div>
    </section>

    <aside class="upload-note">
        <h3>Trước khi tải lên</h3>
        <div class="upload-note-list">
            <div class="upload-note-item"><span class="upload-note-number">01</span><div><strong>Đặt tên rõ ràng</strong><p>Tiêu đề nên phản ánh đúng chương hoặc chủ đề của tài liệu.</p></div></div>
            <div class="upload-note-item"><span class="upload-note-number">02</span><div><strong>Kiểm tra nội dung</strong><p>Ưu tiên file có văn bản đọc được, không chỉ chứa ảnh scan.</p></div></div>
            <div class="upload-note-item"><span class="upload-note-number">03</span><div><strong>Đúng môn phụ trách</strong><p>Tài liệu chỉ có thể được thêm vào môn mà bạn đang là trưởng môn.</p></div></div>
        </div>
        <div class="leader-note"><i class="bi bi-shield-check"></i><span>Quyền tải lên và chỉnh sửa được xác thực lại trên máy chủ cho mỗi thao tác.</span></div>
    </aside>
    </div>
</div>

<!-- Modal xử lý trùng lặp -->
<div class="modal fade" id="duplicateModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="dupModalTitle"><i class="bi bi-files me-2"></i>Phát hiện tài liệu trùng</h5>
            </div>
            <div class="modal-body">
                <p id="dupMessage"></p>
                <div id="dupOldStatus" class="alert" style="display:none;"></div>

                <div class="action-choice-label">Chọn hành động</div>
                <form id="dupForm">
                    @Html.AntiForgeryToken()
                    <input type="hidden" id="oldDocId" name="OldDocumentId" />
                    <input type="hidden" id="dupAction" name="action" value="3" />

                    <div class="action-options">
                        <div class="action-option selected" data-value="3">
                            <span class="opt-check"></span>
                            <span class="opt-icon"><i class="bi bi-book"></i></span>
                            <div class="opt-title">Giữ cả hai</div>
                            <div class="opt-desc">Lưu tài liệu mới như một phiên bản riêng, không xoá bản cũ.</div>
                        </div>
                        <div class="action-option" data-value="2">
                            <span class="opt-check"></span>
                            <span class="opt-icon"><i class="bi bi-arrow-repeat"></i></span>
                            <div class="opt-title">Thay thế</div>
                            <div class="opt-desc">Ghi đè tài liệu cũ bằng tài liệu vừa upload.</div>
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn-cancel-upload" onclick="cancelDuplicateUpload()">Hủy bỏ upload</button>
                <button type="button" class="btn-confirm-action" onclick="confirmDuplicate()">Xác nhận</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        (function(){
            const form = document.getElementById('uploadForm');
            const select = document.querySelector('select[name="subjectId"]');
            const uploadBtn = document.getElementById('uploadBtn');
            const alertEl = document.getElementById('uploadPermissionAlert');
            const errorAlert = document.getElementById('uploadErrorAlert');
            const limitsBox = document.getElementById('uploadLimitsBox');
            const limitsChips = document.getElementById('uploadLimitsChips');
            const fileInput = document.getElementById('fileInput');
            const fileSizeWarning = document.getElementById('fileSizeWarning');
            const fileDrop = document.getElementById('fileDrop');
            const fileName = document.getElementById('fileName');
            const fileMeta = document.getElementById('fileMeta');

            let currentLimits = null; // { pdf: 10, docx: 15, pptx: 50 }

            // Logic tải danh sách môn học
            async function loadSubjects() {
                const resp = await fetch('/Document/GetAssignedSubjects');
                if (!resp.ok) {
                    alertEl.textContent = 'Không thể tải danh sách môn học bạn đang phụ trách.';
                    alertEl.style.display = 'block';
                    return;
                }
                const items = await resp.json();
                items.forEach(s => {
                    const opt = new Option(s.name, s.id);
                    select.add(opt);
                });
                if (items.length === 0) {
                    alertEl.textContent = 'Bạn chưa được phân công làm trưởng môn nên chưa thể tải tài liệu lên.';
                    alertEl.style.display = 'block';
                    select.disabled = true;
                }
            }

            // Logic kiểm tra quyền upload
            async function check(subjectId) {
                if (!subjectId) {
                    uploadBtn.disabled = true;
                    limitsBox.classList.remove('show');
                    return;
                }
                const resp = await fetch(`/Document/CanUpload?subjectId=${subjectId}`);
                const j = await resp.json();
                uploadBtn.disabled = !j.canUpload;
                alertEl.style.display = j.canUpload ? 'none' : 'block';
                alertEl.textContent = j.message || '';
            }

            // Tải + hiển thị giới hạn upload theo từng loại file cho môn đã chọn
            async function loadUploadLimits(subjectId) {
                if (!subjectId) {
                    limitsBox.classList.remove('show');
                    currentLimits = null;
                    return;
                }
                try {
                    const resp = await fetch(`/Document/GetUploadLimits?subjectId=${subjectId}`);
                    if (!resp.ok) return;
                    const limits = await resp.json();
                    if (!limits || Object.keys(limits).length === 0) {
                        limitsBox.classList.remove('show');
                        currentLimits = null;
                        return;
                    }
                    currentLimits = limits;
                    renderLimitsChips();
                    limitsBox.classList.add('show');
                } catch (err) {
                    console.error('Không thể tải giới hạn upload:', err);
                }
            }

            function renderLimitsChips(highlightExt) {
                if (!currentLimits) return;
                const labels = { pdf: 'PDF', docx: 'DOCX', pptx: 'PPTX' };
                limitsChips.innerHTML = Object.keys(currentLimits).map(type => {
                    const isMatched = highlightExt === type;
                    return `<span class="limit-chip ${isMatched ? 'matched' : ''}">${labels[type] || type.toUpperCase()}: ${currentLimits[type]}MB</span>`;
                }).join('');
            }

            select.addEventListener('change', () => {
                check(select.value);
                loadUploadLimits(select.value);
                fileSizeWarning.classList.remove('show');
            });

            // Kiểm tra size file phía client ngay khi chọn file (UX nhanh, không thay thế validate server)
            fileInput.addEventListener('change', () => {
                const file = fileInput.files[0];
                fileSizeWarning.classList.remove('show');
                fileDrop.classList.toggle('has-file', !!file);
                fileName.textContent = file ? file.name : 'Chọn file từ máy tính';
                fileMeta.textContent = file ? `${(file.size / 1024 / 1024).toFixed(2)} MB` : '';
                if (!file || !currentLimits) {
                    renderLimitsChips();
                    return;
                }

                const ext = file.name.split('.').pop().toLowerCase();
                renderLimitsChips(ext);

                const limitMB = currentLimits[ext];
                if (limitMB !== undefined) {
                    const fileSizeMB = file.size / 1024 / 1024;
                    if (fileSizeMB > limitMB) {
                        fileSizeWarning.textContent = `File của bạn (${fileSizeMB.toFixed(1)}MB) vượt quá giới hạn ${limitMB}MB dành cho định dạng ${ext.toUpperCase()}.`;
                        fileSizeWarning.classList.add('show');
                    }
                }
            });

            // Xử lý Submit form qua AJAX
            form.addEventListener('submit', async (e) => {
                e.preventDefault();
                errorAlert.style.display = 'none';
                uploadBtn.disabled = true;

                try {
                    const formData = new FormData(form);
                    const resp = await fetch('/Document/Upload', { method: 'POST', body: formData });
                    const result = await resp.json();

                    if (result.success === false) {
                        errorAlert.textContent = result.error || 'Đã xảy ra lỗi khi upload.';
                        errorAlert.style.display = 'block';
                        uploadBtn.disabled = false;
                        return;
                    }

                     if (result.isDuplicate) {
            document.getElementById('oldDocId').value = result.oldDocumentId;
            document.getElementById('dupMessage').textContent = result.message;

            const isExact = result.matchType === 'Exact';

            document.getElementById('dupModalTitle').textContent = isExact
                ? 'Tài liệu trùng khớp hoàn toàn'
                : 'Tài liệu có vẻ giống bản đã tải trước';

            const keepBothOption = document.querySelector('.action-option[data-value="3"]');

            if (isExact) {
                keepBothOption.style.display = 'none';
                setActionChoice('2');
            } else {
                keepBothOption.style.display = '';
                setActionChoice('3');
            }

            const statusEl = document.getElementById('dupOldStatus');
            if (result.isEmbeddingReady) {
                statusEl.className = 'alert alert-success';
                statusEl.textContent = isExact
                    ? 'Tài liệu cũ đã có embeddings (sẵn sàng sử dụng). Bạn có thể thay thế hoặc hủy upload.'
                    : 'Tài liệu cũ đã có embeddings. Vì chỉ giống một phần, bạn có thể giữ cả hai, thay thế, hoặc hủy.';
                statusEl.style.display = 'block';
            } else {
                statusEl.className = 'alert alert-warning';
                statusEl.innerHTML = 'Tài liệu cũ chưa được chunk/embed. Bạn có thể kích hoạt embedding cho tài liệu cũ để sử dụng (nhấn <a href="/Document/TriggerEmbeddingGet?id=' + encodeURIComponent(result.oldDocumentId) + '">ở đây</a>).';
                statusEl.style.display = 'block';
            }
            new bootstrap.Modal(document.getElementById('duplicateModal')).show();
            uploadBtn.disabled = false;
        } else {
            window.location.href = '@Url.Action("Index", "Document")';
        }
                } catch (err) {
                    errorAlert.textContent = 'Không thể kết nối server. Vui lòng thử lại.';
                    errorAlert.style.display = 'block';
                    uploadBtn.disabled = false;
                }
            });

            loadSubjects();
        })();

        // Chọn hành động (Giữ cả hai / Thay thế) bằng cách click vào thẻ option
        function setActionChoice(value) {
            document.getElementById('dupAction').value = value;
            document.querySelectorAll('.action-option').forEach(el => {
                el.classList.toggle('selected', el.getAttribute('data-value') === value);
            });
        }

        document.querySelectorAll('.action-option').forEach(el => {
            el.addEventListener('click', () => setActionChoice(el.getAttribute('data-value')));
        });

        // Xác nhận hành động trùng lặp (Giữ cả hai / Thay thế)
        async function confirmDuplicate() {
            const formData = new FormData(document.getElementById('dupForm'));
            await fetch('/Document/ConfirmDuplicate', { method: 'POST', body: formData, credentials: 'same-origin' });
            window.location.href = '@Url.Action("Index", "Document")';
        }

        // Hủy bỏ upload: luôn gửi action=1 (Hủy bỏ upload) bất kể đang chọn option nào
        async function cancelDuplicateUpload() {
            const formData = new FormData(document.getElementById('dupForm'));
            formData.set('action', '1');
            await fetch('/Document/ConfirmDuplicate', { method: 'POST', body: formData, credentials: 'same-origin' });
            window.location.href = '@Url.Action("Index", "Document")';
        }
    </script>
}
