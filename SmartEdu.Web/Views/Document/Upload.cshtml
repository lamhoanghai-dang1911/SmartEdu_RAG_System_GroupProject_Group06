@{
    ViewData["Title"] = "Upload tài liệu";
}

<style>
    :root {
        --brand-blue: #0d6efd;
        --brand-purple: #6610f2;
        --ink-navy: #0b1120;
        --amber: #ffb648;
        --paper: #f7f8fc;
        --slate: #5a6072;
        --slate-light: #9aa0b4;
        --success: #1fae63;
        --danger: #e5484d;
    }

    @@keyframes fadeUp {
        from {
            opacity: 0;
            transform: translateY(10px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .page-head h2 {
        font-family: 'Sora', sans-serif;
        font-weight: 700;
        font-size: 1.5rem;
        color: #12162b;
        margin-bottom: 1.5rem;
    }

    .upload-card {
        background: #fff;
        border-radius: 16px;
        box-shadow: 0 10px 32px -12px rgba(11, 17, 32, 0.14);
        padding: 1.85rem;
        opacity: 0;
        animation: fadeUp 0.45s ease forwards;
    }

    .form-label {
        font-weight: 600;
        font-size: 0.88rem;
        color: #33384f;
        margin-bottom: 0.4rem;
    }

    .form-control,
    .form-select {
        border: 1.5px solid #e3e5ef;
        border-radius: 10px;
        padding: 0.6rem 0.85rem;
        font-size: 0.95rem;
        transition: border-color 0.2s ease, box-shadow 0.2s ease;
    }

        .form-control:focus,
        .form-select:focus {
            border-color: var(--brand-blue);
            box-shadow: 0 0 0 4px rgba(13, 110, 253, 0.12);
        }

        .form-control[type="file"] {
            padding: 0.5rem 0.85rem;
        }

    .alert-danger {
        border: none;
        border-radius: 10px;
        background: rgba(229, 72, 77, 0.08);
        color: var(--danger);
        border-left: 3px solid var(--danger);
        font-size: 0.88rem;
    }

    /* ===== Upload limits info box ===== */
    .upload-limits-box {
        background: var(--paper);
        border-radius: 12px;
        padding: 0.75rem 0.9rem;
        margin-bottom: 1rem;
        display: none;
    }

        .upload-limits-box.show {
            display: block;
            animation: fadeUp 0.3s ease forwards;
        }

    .upload-limits-label {
        font-size: 0.74rem;
        font-weight: 700;
        color: var(--slate-light);
        text-transform: uppercase;
        letter-spacing: 0.03em;
        margin-bottom: 0.5rem;
        display: flex;
        align-items: center;
        gap: 0.35rem;
    }

    .upload-limits-chips {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
    }

    .limit-chip {
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
        background: #fff;
        border: 1px solid #e3e5ef;
        border-radius: 999px;
        padding: 0.32rem 0.75rem;
        font-size: 0.8rem;
        font-weight: 600;
        color: #33384f;
        transition: border-color 0.15s ease, background 0.15s ease;
    }

        .limit-chip.matched {
            border-color: var(--brand-blue);
            background: rgba(13, 110, 253, 0.06);
            color: var(--brand-blue);
        }

    .file-size-warning {
        font-size: 0.82rem;
        color: var(--danger);
        margin-top: 0.4rem;
        display: none;
    }

        .file-size-warning.show {
            display: block;
        }

    .btn-upload {
        border: none;
        border-radius: 12px;
        padding: 0.7rem 1.5rem;
        font-weight: 700;
        color: #fff;
        background: linear-gradient(120deg, var(--brand-blue), var(--brand-purple));
        box-shadow: 0 10px 24px -10px rgba(13, 110, 253, 0.5);
        transition: transform 0.15s ease, filter 0.15s ease, opacity 0.15s ease;
    }

        .btn-upload:hover:not(:disabled) {
            transform: translateY(-1px);
            filter: brightness(1.07);
        }

        .btn-upload:disabled {
            opacity: 0.5;
            box-shadow: none;
            cursor: not-allowed;
        }

    .btn-back {
        border-radius: 12px;
        border: none;
        background: #eef0f6;
        color: #33384f;
        font-weight: 600;
        padding: 0.7rem 1.4rem;
        transition: background 0.15s ease, transform 0.15s ease;
    }

        .btn-back:hover {
            background: #e2e5f0;
            color: #12162b;
            transform: translateY(-1px);
        }

    /* ===== Duplicate modal ===== */
    #duplicateModal .modal-content {
        border: none;
        border-radius: 16px;
        overflow: hidden;
    }

    #duplicateModal .modal-header {
        background: linear-gradient(120deg, var(--ink-navy), #171d3d);
        color: #fff;
        border: none;
        padding: 1.1rem 1.4rem;
    }

    #duplicateModal .modal-title {
        font-family: 'Sora', sans-serif;
        font-weight: 700;
        font-size: 1.05rem;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    #dupMessage {
        font-size: 0.92rem;
        color: #33384f;
    }

    /* ===== Bảng danh sách tài liệu trùng ===== */
    .dup-table-wrap {
        border: 1.5px solid #e3e5ef;
        border-radius: 12px;
        overflow: hidden;
        max-height: 260px;
        overflow-y: auto;
        margin-bottom: 0.5rem;
    }

    .dup-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 0.85rem;
    }

        .dup-table thead th {
            position: sticky;
            top: 0;
            background: var(--paper);
            font-size: 0.72rem;
            font-weight: 700;
            color: var(--slate-light);
            text-transform: uppercase;
            letter-spacing: 0.03em;
            padding: 0.55rem 0.7rem;
            text-align: left;
            border-bottom: 1.5px solid #e3e5ef;
            white-space: nowrap;
        }

        .dup-table tbody td {
            padding: 0.6rem 0.7rem;
            border-bottom: 1px solid #eef0f6;
            color: #33384f;
            vertical-align: middle;
        }

        .dup-table tbody tr:last-child td {
            border-bottom: none;
        }

        .dup-table tbody tr.selectable {
            cursor: pointer;
            transition: background 0.15s ease;
        }

            .dup-table tbody tr.selectable:hover {
                background: rgba(13, 110, 253, 0.04);
            }

        .dup-table tbody tr.selected-row {
            background: rgba(13, 110, 253, 0.07);
        }

    .dup-col-select {
        width: 42px;
        text-align: center !important;
    }

        .dup-col-select input[type="radio"] {
            accent-color: var(--brand-blue);
            width: 16px;
            height: 16px;
            cursor: pointer;
        }

    .dup-title-cell {
        font-weight: 600;
        color: #12162b;
        max-width: 220px;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .dup-pct {
        display: inline-block;
        font-weight: 700;
        font-size: 0.8rem;
        border-radius: 999px;
        padding: 0.18rem 0.6rem;
    }

        .dup-pct.exact {
            background: rgba(229, 72, 77, 0.1);
            color: var(--danger);
        }

        .dup-pct.near {
            background: rgba(255, 182, 72, 0.16);
            color: #b8790a;
        }

    .dup-badge {
        display: inline-block;
        font-size: 0.72rem;
        font-weight: 600;
        border-radius: 999px;
        padding: 0.16rem 0.55rem;
        white-space: nowrap;
    }

        .dup-badge.ok {
            background: rgba(31, 174, 99, 0.1);
            color: var(--success);
        }

        .dup-badge.warn {
            background: rgba(255, 182, 72, 0.16);
            color: #b8790a;
        }

    .dup-embed-link {
        font-size: 0.8rem;
        text-decoration: none;
        margin-left: 0.2rem;
    }

    .dup-replace-hint {
        font-size: 0.8rem;
        color: var(--slate);
        margin-bottom: 0.3rem;
    }

    .dup-select-warning {
        font-size: 0.82rem;
        color: var(--danger);
        font-weight: 600;
        margin-bottom: 0.3rem;
    }

    .action-choice-label {
        font-size: 0.82rem;
        font-weight: 600;
        color: var(--slate);
        text-transform: uppercase;
        letter-spacing: 0.02em;
        margin: 1.1rem 0 0.6rem;
    }

    .action-options {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 0.7rem;
    }

    .action-option {
        position: relative;
        border: 1.5px solid #e3e5ef;
        border-radius: 12px;
        padding: 0.9rem 0.85rem;
        cursor: pointer;
        transition: border-color 0.18s ease, background 0.18s ease, transform 0.12s ease;
        text-align: left;
    }

        .action-option:hover {
            border-color: rgba(13, 110, 253, 0.35);
            transform: translateY(-1px);
        }

        .action-option .opt-icon {
            font-size: 1.3rem;
            margin-bottom: 0.4rem;
            display: block;
        }

        .action-option .opt-title {
            font-family: 'Sora', sans-serif;
            font-weight: 700;
            font-size: 0.9rem;
            color: #12162b;
            margin-bottom: 0.2rem;
        }

        .action-option .opt-desc {
            font-size: 0.78rem;
            color: var(--slate-light);
            line-height: 1.4;
        }

        .action-option .opt-check {
            position: absolute;
            top: 0.7rem;
            right: 0.7rem;
            width: 18px;
            height: 18px;
            border-radius: 50%;
            border: 1.5px solid #d7dbe8;
            transition: border-color 0.18s ease, background 0.18s ease;
        }

        .action-option.selected {
            border-color: var(--brand-blue);
            background: rgba(13, 110, 253, 0.05);
        }

            .action-option.selected .opt-check {
                border-color: var(--brand-blue);
                background: var(--brand-blue);
            }

                .action-option.selected .opt-check::after {
                    content: "✓";
                    display: block;
                    color: #fff;
                    font-size: 0.68rem;
                    font-weight: 700;
                    text-align: center;
                    line-height: 18px;
                }

    #duplicateModal .modal-footer {
        border: none;
        padding: 1rem 1.4rem;
        display: flex;
        justify-content: space-between;
        gap: 0.6rem;
    }

    .btn-cancel-upload {
        border: none;
        border-radius: 999px;
        background: rgba(229, 72, 77, 0.08);
        color: var(--danger);
        font-weight: 600;
        padding: 0.55rem 1.2rem;
        font-size: 0.86rem;
        transition: background 0.15s ease;
    }

        .btn-cancel-upload:hover {
            background: rgba(229, 72, 77, 0.15);
            color: var(--danger);
        }

    .btn-confirm-action {
        border: none;
        border-radius: 999px;
        background: linear-gradient(120deg, var(--brand-blue), var(--brand-purple));
        color: #fff;
        font-weight: 700;
        padding: 0.55rem 1.4rem;
        font-size: 0.86rem;
        box-shadow: 0 8px 20px -10px rgba(13, 110, 253, 0.5);
        transition: transform 0.15s ease, filter 0.15s ease;
    }

        .btn-confirm-action:hover {
            transform: translateY(-1px);
            filter: brightness(1.07);
            color: #fff;
        }

    @@media (prefers-reduced-motion: reduce) {
        *, *::before, *::after {
            animation-duration: 0.01ms !important;
            transition-duration: 0.01ms !important;
        }
    }
</style>

<div class="container mt-4" style="max-width:600px">
    <div class="page-head">
        <h2>⬆️ Upload tài liệu</h2>
    </div>

    <div class="upload-card">
        <div id="uploadErrorAlert" class="alert alert-danger" style="display:none;"></div>

        <form id="uploadForm" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()

            <div class="mb-3">
                <label class="form-label">Tiêu đề tài liệu</label>
                <input name="title" class="form-control" placeholder="VD: Bài giảng Chương 1" required />
            </div>

            <div class="mb-3">
                <label class="form-label">Môn học</label>
                <select name="subjectId" class="form-select" required>
                    <option value="">-- Chọn môn học --</option>
                </select>
            </div>

            <div id="uploadPermissionAlert" class="alert alert-danger" style="display:none;"></div>

            <div id="uploadLimitsBox" class="upload-limits-box">
                <div class="upload-limits-label">📦 Giới hạn kích thước file cho môn này</div>
                <div id="uploadLimitsChips" class="upload-limits-chips"></div>
            </div>

            <div class="mb-2">
                <label class="form-label">File (PDF, DOCX hoặc PPTX)</label>
                <input name="file" id="fileInput" type="file" class="form-control" accept=".pdf,.docx,.pptx" required />
                <div id="fileSizeWarning" class="file-size-warning"></div>
            </div>

            <div class="d-flex gap-2 mt-3">
                <button type="submit" id="uploadBtn" class="btn btn-upload" disabled>💾 Upload</button>
                <a asp-action="Index" class="btn btn-back">← Quay lại</a>
            </div>
        </form>
    </div>
</div>

<!-- Modal xử lý trùng lặp -->
<div class="modal fade" id="duplicateModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="dupModalTitle">⚠️ Phát hiện tài liệu trùng</h5>
            </div>
            <div class="modal-body">
                <p id="dupMessage"></p>

                <div class="action-choice-label" style="margin-top:0.4rem;">Danh sách tài liệu trùng trong môn học</div>
                <div class="dup-table-wrap">
                    <table class="dup-table">
                        <thead>
                            <tr>
                                <th class="dup-col-select dup-select-ui" style="display:none;"></th>
                                <th>Tài liệu</th>
                                <th>Độ trùng</th>
                                <th>Ngày tải</th>
                                <th>Embedding</th>
                            </tr>
                        </thead>
                        <tbody id="dupListBody"></tbody>
                    </table>
                </div>
                <div id="dupReplaceHint" class="dup-replace-hint dup-select-ui" style="display:none;">
                    👉 Chọn một tài liệu trong danh sách trên để thay thế bằng tài liệu vừa upload.
                </div>
                <div id="dupSelectWarning" class="dup-select-warning" style="display:none;">
                    ⚠️ Vui lòng chọn tài liệu cần thay thế trước khi xác nhận.
                </div>

                <div class="action-choice-label">Chọn hành động</div>
                <form id="dupForm">
                    @Html.AntiForgeryToken()
                    <input type="hidden" id="replaceDocId" name="replaceDocumentId" />
                    <input type="hidden" id="dupAction" name="action" value="3" />

                    <div class="action-options">
                        <div class="action-option selected" data-value="3">
                            <span class="opt-check"></span>
                            <span class="opt-icon">📚</span>
                            <div class="opt-title">Giữ</div>
                            <div class="opt-desc">Lưu tài liệu mới như một phiên bản riêng, không xoá các bản cũ.</div>
                        </div>
                        <div class="action-option" data-value="2">
                            <span class="opt-check"></span>
                            <span class="opt-icon">♻️</span>
                            <div class="opt-title">Thay thế</div>
                            <div class="opt-desc">Ghi đè tài liệu cũ do bạn chọn trong danh sách bên trên.</div>
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn-cancel-upload" onclick="cancelDuplicateUpload()">Hủy bỏ upload</button>
                <button type="button" class="btn-confirm-action" onclick="confirmDuplicate()">Xác nhận</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Danh sách tài liệu trùng hiện tại (server trả về khi upload phát hiện trùng)
        let currentDuplicates = [];

        (function() {
            const form = document.getElementById('uploadForm');
            const select = document.querySelector('select[name="subjectId"]');
            const uploadBtn = document.getElementById('uploadBtn');
            const alertEl = document.getElementById('uploadPermissionAlert');
            const errorAlert = document.getElementById('uploadErrorAlert');
            const limitsBox = document.getElementById('uploadLimitsBox');
            const limitsChips = document.getElementById('uploadLimitsChips');
            const fileInput = document.getElementById('fileInput');
            const fileSizeWarning = document.getElementById('fileSizeWarning');

            let currentLimits = null; // { pdf: 10, docx: 15, pptx: 50 }

            // Logic tải danh sách môn học
            async function loadSubjects() {
                const resp = await fetch('/Document/GetAssignedSubjects');
                if (!resp.ok) return;
                const items = await resp.json();
                items.forEach(s => {
                    const opt = new Option(s.name, s.id);
                    select.add(opt);
                });
            }

            // Logic kiểm tra quyền upload
            async function check(subjectId) {
                if (!subjectId) {
                    uploadBtn.disabled = true;
                    limitsBox.classList.remove('show');
                    return;
                }
                const resp = await fetch(`/Document/CanUpload?subjectId=${subjectId}`);
                const j = await resp.json();
                uploadBtn.disabled = !j.canUpload;
                alertEl.style.display = j.canUpload ? 'none' : 'block';
                alertEl.textContent = j.message || '';
            }

            // Tải + hiển thị giới hạn upload theo từng loại file cho môn đã chọn
            async function loadUploadLimits(subjectId) {
                if (!subjectId) {
                    limitsBox.classList.remove('show');
                    currentLimits = null;
                    return;
                }
                try {
                    const resp = await fetch(`/Document/GetUploadLimits?subjectId=${subjectId}`);
                    if (!resp.ok) return;
                    const limits = await resp.json();
                    if (!limits || Object.keys(limits).length === 0) {
                        limitsBox.classList.remove('show');
                        currentLimits = null;
                        return;
                    }
                    currentLimits = limits;
                    renderLimitsChips();
                    limitsBox.classList.add('show');
                } catch (err) {
                    console.error('Không thể tải giới hạn upload:', err);
                }
            }

            function renderLimitsChips(highlightExt) {
                if (!currentLimits) return;
                const labels = { pdf: '📕 PDF', docx: '📘 DOCX', pptx: '📙 PPTX' };
                limitsChips.innerHTML = Object.keys(currentLimits).map(type => {
                    const isMatched = highlightExt === type;
                    return `<span class="limit-chip ${isMatched ? 'matched' : ''}">${labels[type] || type.toUpperCase()}: ${currentLimits[type]}MB</span>`;
                }).join('');
            }

            select.addEventListener('change', () => {
                check(select.value);
                loadUploadLimits(select.value);
                fileSizeWarning.classList.remove('show');
            });

            // Kiểm tra size file phía client ngay khi chọn file (UX nhanh, không thay thế validate server)
            fileInput.addEventListener('change', () => {
                const file = fileInput.files[0];
                fileSizeWarning.classList.remove('show');
                if (!file || !currentLimits) {
                    renderLimitsChips();
                    return;
                }

                const ext = file.name.split('.').pop().toLowerCase();
                renderLimitsChips(ext);

                const limitMB = currentLimits[ext];
                if (limitMB !== undefined) {
                    const fileSizeMB = file.size / 1024 / 1024;
                    if (fileSizeMB > limitMB) {
                        fileSizeWarning.textContent = `⚠️ File của bạn (${fileSizeMB.toFixed(1)}MB) vượt quá giới hạn cho phép (${limitMB}MB) đối với file ${ext.toUpperCase()}.`;
                        fileSizeWarning.classList.add('show');
                    }
                }
            });

            // Xử lý Submit form qua AJAX
            form.addEventListener('submit', async (e) => {
                e.preventDefault();
                errorAlert.style.display = 'none';
                uploadBtn.disabled = true;

                try {
                    const formData = new FormData(form);
                    const resp = await fetch('/Document/Upload', { method: 'POST', body: formData });
                    const result = await resp.json();

                    if (result.success === false) {
                        errorAlert.textContent = result.error || 'Đã xảy ra lỗi khi upload.';
                        errorAlert.style.display = 'block';
                        uploadBtn.disabled = false;
                        return;
                    }

                    if (result.isDuplicate) {
                        currentDuplicates = result.duplicates || [];
                        document.getElementById('dupMessage').textContent = result.message;

                        const isExact = result.matchType === 'Exact';

                        document.getElementById('dupModalTitle').textContent = isExact
                            ? '⚠️ Tài liệu trùng khớp hoàn toàn'
                            : '🔍 Phát hiện tài liệu gần giống trong môn học';

                        const keepOption = document.querySelector('.action-option[data-value="3"]');

                        if (isExact) {
                            // Trùng 100% với ít nhất một tài liệu -> không cho "Giữ"
                            keepOption.style.display = 'none';
                            setActionChoice('2');
                        } else {
                            keepOption.style.display = '';
                            setActionChoice('3');
                        }

                        renderDupList();
                        new bootstrap.Modal(document.getElementById('duplicateModal')).show();
                        uploadBtn.disabled = false;
                    } else {
                        window.location.href = '@Url.Action("Index", "Document")';
                    }
                } catch (err) {
                    errorAlert.textContent = 'Không thể kết nối server. Vui lòng thử lại.';
                    errorAlert.style.display = 'block';
                    uploadBtn.disabled = false;
                }
            });

            loadSubjects();
        })();

        // ===== Danh sách tài liệu trùng =====

        function escapeHtml(str) {
            const div = document.createElement('div');
            div.textContent = str ?? '';
            return div.innerHTML;
        }

        function renderDupList() {
            const body = document.getElementById('dupListBody');
            body.innerHTML = currentDuplicates.map(d => {
                const isExact = d.matchType === 'Exact';
                const pct = isExact ? '100%' : `${d.similarityPercent}%`;
                const pctClass = isExact ? 'dup-pct exact' : 'dup-pct near';
                const pctTitle = isExact ? 'Trùng khớp hoàn toàn (hash giống nhau)' : 'Độ tương đồng nội dung';
                const embed = d.isEmbeddingReady
                    ? '<span class="dup-badge ok">✓ Sẵn sàng</span>'
                    : `<span class="dup-badge warn">Chưa embed</span><a class="dup-embed-link" href="/Document/TriggerEmbeddingGet?id=${d.id}" title="Kích hoạt embedding cho tài liệu này">⚡</a>`;

                return `<tr data-id="${d.id}">
                            <td class="dup-col-select dup-select-ui" style="display:none;">
                                <input type="radio" name="replaceTarget" value="${d.id}" aria-label="Chọn thay thế ${escapeHtml(d.title)}">
                            </td>
                            <td class="dup-title-cell" title="${escapeHtml(d.title)}">${escapeHtml(d.title || '(không tiêu đề)')}</td>
                            <td><span class="${pctClass}" title="${pctTitle}">${pct}</span></td>
                            <td>${d.createdAt || '—'}</td>
                            <td>${embed}</td>
                        </tr>`;
            }).join('');

            // Click cả dòng để chọn radio (khi đang ở chế độ Thay thế)
            body.querySelectorAll('tr').forEach(tr => {
                tr.addEventListener('click', (e) => {
                    if (document.getElementById('dupAction').value !== '2') return;
                    if (e.target.closest('a')) return; // đừng chặn link ⚡
                    const radio = tr.querySelector('input[name="replaceTarget"]');
                    if (radio) {
                        radio.checked = true;
                        markSelectedRow();
                        hideSelectWarning();
                    }
                });
            });
            body.querySelectorAll('input[name="replaceTarget"]').forEach(r => {
                r.addEventListener('change', () => { markSelectedRow(); hideSelectWarning(); });
            });

            // Nếu chỉ có đúng 1 tài liệu trùng thì tự chọn sẵn cho tiện
            if (currentDuplicates.length === 1) {
                const only = body.querySelector('input[name="replaceTarget"]');
                if (only) only.checked = true;
            }

            updateReplaceUI();
        }

        function markSelectedRow() {
            document.querySelectorAll('#dupListBody tr').forEach(tr => {
                const radio = tr.querySelector('input[name="replaceTarget"]');
                tr.classList.toggle('selected-row', !!(radio && radio.checked));
            });
        }

        // Bật/tắt cột chọn tài liệu tùy theo hành động đang chọn (chỉ hiện khi Thay thế)
        function updateReplaceUI() {
            const isReplace = document.getElementById('dupAction').value === '2';
            document.querySelectorAll('.dup-select-ui').forEach(el => {
                el.style.display = isReplace ? '' : 'none';
            });
            document.querySelectorAll('#dupListBody tr').forEach(tr => {
                tr.classList.toggle('selectable', isReplace);
            });
            if (isReplace) {
                markSelectedRow();
            } else {
                hideSelectWarning();
                document.querySelectorAll('#dupListBody tr').forEach(tr => tr.classList.remove('selected-row'));
            }
        }

        function hideSelectWarning() {
            document.getElementById('dupSelectWarning').style.display = 'none';
        }

        // ===== Chọn hành động (Giữ / Thay thế) =====

        function setActionChoice(value) {
            document.getElementById('dupAction').value = value;
            document.querySelectorAll('.action-option').forEach(el => {
                el.classList.toggle('selected', el.getAttribute('data-value') === value);
            });
            updateReplaceUI();
        }

        document.querySelectorAll('.action-option').forEach(el => {
            el.addEventListener('click', () => setActionChoice(el.getAttribute('data-value')));
        });

        // ===== Xác nhận hành động trùng lặp (Giữ / Thay thế) =====
        async function confirmDuplicate() {
            const action = document.getElementById('dupAction').value;
            const replaceInput = document.getElementById('replaceDocId');

            if (action === '2') {
                // Thay thế: bắt buộc phải chọn 1 tài liệu trong danh sách
                const selected = document.querySelector('input[name="replaceTarget"]:checked');
                if (!selected) {
                    document.getElementById('dupSelectWarning').style.display = 'block';
                    return;
                }
                replaceInput.value = selected.value;
            } else {
                replaceInput.value = '';
            }

            const formData = new FormData(document.getElementById('dupForm'));
            await fetch('/Document/ConfirmDuplicate', { method: 'POST', body: formData, credentials: 'same-origin' });
            window.location.href = '@Url.Action("Index", "Document")';
        }

        // Hủy bỏ upload: luôn gửi action=1 (Hủy bỏ upload) bất kể đang chọn option nào
        async function cancelDuplicateUpload() {
            const formData = new FormData(document.getElementById('dupForm'));
            formData.set('action', '1');
            formData.set('replaceDocumentId', '');
            await fetch('/Document/ConfirmDuplicate', { method: 'POST', body: formData, credentials: 'same-origin' });
            window.location.href = '@Url.Action("Index", "Document")';
        }
    </script>
}
