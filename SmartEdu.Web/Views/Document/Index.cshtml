@model IEnumerable<SmartEdu.Shared.Entities.Document>
@{
    ViewData["Title"] = "Tài liệu";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>📄 Danh sách tài liệu</h2>
        <a asp-action="Upload" class="btn btn-primary">⬆️ Upload tài liệu</a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    {{!-- Filter theo môn học --}}
    <form method="get" class="row g-2 mb-3">
        <div class="col-auto">
            <select name="subjectId" asp-items="ViewBag.Subjects"
                    class="form-select" onchange="this.form.submit()">
                <option value="">-- Tất cả môn học --</option>
            </select>
        </div>
    </form>

    <table class="table table-bordered table-hover align-middle">
        <thead class="table-dark">
            <tr>
                <th>#</th>
                <th>Tiêu đề</th>
                <th>File gốc</th>
                <th>Loại</th>
                <th>Kích thước</th>
                <th>Môn học</th>
                <th>Trạng thái</th>
                <th>Ngày upload</th>
                <th>Thao tác</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var d in Model)
            {
                <tr>
                    <td>@d.Id</td>
                    <td>@d.Title</td>
                    <td><small>@d.FileName</small></td>
                    <td>
                        <span class="badge bg-secondary">
                            @d.FileType.ToUpper()
                        </span>
                    </td>
                    <td>@($"{d.FileSize / 1024.0:F1}") KB</td>
                    <td>@d.Subject?.Name</td>
                    <td>
                        @{
                            var (badge, label) = d.Status.ToString() switch
                            {
                                "Pending" => ("warning", "⏳ Chờ xử lý"),
                                "Processing" => ("info", "⚙️ Đang xử lý"),
                                "Ready" => ("success", "✅ Sẵn sàng"),
                                "Failed" => ("danger", "❌ Lỗi"),
                                _ => ("secondary", d.Status.ToString())
                            };
                        }
                        <span class="badge bg-@badge">@label</span>
                    </td>
                    <td>@d.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                    <td>
                        <a asp-action="Details" asp-route-id="@d.Id"
                           class="btn btn-sm btn-info">🔍</a>

                        <form asp-action="TriggerEmbedding" asp-route-id="@d.Id"
                              method="post" class="d-inline">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-sm btn-success"
                                    title="Kích hoạt Embedding">
                                ⚡
                            </button>
                        </form>

                        <form asp-action="Delete" asp-route-id="@d.Id"
                              method="post" class="d-inline"
                              onsubmit="return confirm('Xóa tài liệu này?')">
                            @Html.AntiForgeryToken()
                            <button type="submit"
                                    class="btn btn-sm btn-danger">
                                🗑️
                            </button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>