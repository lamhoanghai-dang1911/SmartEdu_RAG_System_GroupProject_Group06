@{
    ViewData["Title"] = "Privacy";
}
<div class="app-content-inner">
    <div class="page-head">
        <div>
            <div class="page-head-sub">Legal</div>
            <h1 class="page-head-title"><i class="bi bi-shield-check me-2"></i>Privacy</h1>
        </div>
    </div>

    <div class="surface-card" style="max-width: 760px;">
        <p class="text-muted">
            SmartEdu is built for educational use. Documents you upload are scoped to your subjects
            and only visible to enrolled users and the lecturers assigned to that subject.
            Chat history is private to the user who created it.
        </p>
        <p class="text-muted mb-0">
            This page is a placeholder for your full privacy policy.
        </p>
    </div>
</div>