@{
    ViewData["Title"] = "SmartEdu RAG System";
}

<style>
    :root {
        --brand-blue: #0d6efd;
        --brand-purple: #6610f2;
        --ink-navy: #0b1120;
        --amber: #ffb648;
        --paper: #f7f8fc;
        --slate: #5a6072;
        --slate-light: #9aa0b4;
        --success: #1fae63;
        --danger: #e5484d;
    }

    @@keyframes fadeUp {
        from {
            opacity: 0;
            transform: translateY(16px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @@keyframes floatBadge {
        0%, 100% {
            transform: translateY(0);
        }

        50% {
            transform: translateY(-4px);
        }
    }

    /* ===== Hero ===== */
    .hero-section {
        position: relative;
        text-align: center;
        padding: 4.5rem 1rem 3rem;
        overflow: hidden;
        border-radius: 24px;
        background: radial-gradient(circle at 20% 15%, rgba(13, 110, 253, 0.08), transparent 45%), radial-gradient(circle at 80% 85%, rgba(102, 16, 242, 0.08), transparent 45%), var(--paper);
        margin-bottom: 1rem;
    }

    .hero-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        background: rgba(13, 110, 253, 0.08);
        color: var(--brand-blue);
        border: 1px solid rgba(13, 110, 253, 0.18);
        border-radius: 999px;
        padding: 0.45rem 1rem;
        font-size: 0.82rem;
        font-weight: 600;
        margin-bottom: 1.4rem;
        opacity: 0;
        animation: fadeUp 0.5s ease forwards, floatBadge 3.5s ease-in-out 0.5s infinite;
    }

    .hero-section h1 {
        font-family: 'Sora', sans-serif;
        font-weight: 800;
        font-size: 2.6rem;
        line-height: 1.28;
        color: #12162b;
        margin-bottom: 1rem;
        opacity: 0;
        animation: fadeUp 0.55s ease forwards;
        animation-delay: 0.08s;
    }

        .hero-section h1 .gradient-text {
            background: linear-gradient(120deg, var(--brand-blue), var(--brand-purple));
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
        }

    .hero-section .lead {
        font-size: 1.05rem;
        color: var(--slate);
        max-width: 560px;
        margin: 0 auto 2rem;
        opacity: 0;
        animation: fadeUp 0.55s ease forwards;
        animation-delay: 0.16s;
    }

    .hero-cta {
        opacity: 0;
        animation: fadeUp 0.55s ease forwards;
        animation-delay: 0.24s;
    }

        .hero-cta .btn-primary {
            border: none;
            border-radius: 999px;
            background: linear-gradient(120deg, var(--brand-blue), var(--brand-purple), var(--brand-blue));
            background-size: 200% 200%;
            font-weight: 700;
            padding: 0.75rem 1.6rem;
            box-shadow: 0 12px 28px -10px rgba(13, 110, 253, 0.5);
            transition: background-position 0.5s ease, transform 0.15s ease;
        }

            .hero-cta .btn-primary:hover {
                background-position: 100% 50%;
                transform: translateY(-2px);
            }

        .hero-cta .btn-outline-secondary {
            border-radius: 999px;
            border: 1.5px solid #d7dbe8;
            color: #33384f;
            font-weight: 600;
            padding: 0.75rem 1.6rem;
            transition: transform 0.15s ease, border-color 0.15s ease, background 0.15s ease;
        }

            .hero-cta .btn-outline-secondary:hover {
                transform: translateY(-2px);
                border-color: var(--brand-blue);
                background: rgba(13, 110, 253, 0.04);
                color: var(--brand-blue);
            }

    /* ===== Section headings ===== */
    .section-title {
        font-family: 'Sora', sans-serif;
        font-weight: 700;
        font-size: 1.7rem;
        color: #12162b;
        text-align: center;
        margin-bottom: 2rem;
        opacity: 0;
        animation: fadeUp 0.5s ease forwards;
    }

    /* ===== Feature cards ===== */
    .feature-card {
        border: 1px solid #edeef5 !important;
        border-radius: 16px !important;
        box-shadow: 0 6px 20px -14px rgba(11, 17, 32, 0.15);
        transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
        opacity: 0;
        animation: fadeUp 0.5s ease forwards;
    }

        .feature-card:nth-of-type(1) {
            animation-delay: 0.05s;
        }

        .feature-card:nth-of-type(2) {
            animation-delay: 0.1s;
        }

        .feature-card:nth-of-type(3) {
            animation-delay: 0.15s;
        }

        .feature-card:nth-of-type(4) {
            animation-delay: 0.2s;
        }

        .feature-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 16px 32px -14px rgba(11, 17, 32, 0.22);
            border-color: rgba(13, 110, 253, 0.25) !important;
        }

    .feature-icon {
        width: 46px;
        height: 46px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border-radius: 12px !important;
        transition: transform 0.2s ease;
    }

    .feature-card:hover .feature-icon {
        transform: scale(1.08) rotate(-4deg);
    }

    .feature-card .card-title {
        font-family: 'Sora', sans-serif;
        font-weight: 700;
        font-size: 1.02rem;
        color: #12162b;
    }

    .feature-card .card-text {
        color: var(--slate);
        font-size: 0.88rem;
        line-height: 1.55;
    }

    hr.section-divider {
        border: none;
        height: 1px;
        background: linear-gradient(90deg, transparent, #e3e5ef, transparent);
        margin: 3rem 0;
    }

    /* ===== Steps ===== */
    .step-block {
        opacity: 0;
        animation: fadeUp 0.5s ease forwards;
    }

        .step-block:nth-of-type(1) {
            animation-delay: 0.05s;
        }

        .step-block:nth-of-type(2) {
            animation-delay: 0.15s;
        }

        .step-block:nth-of-type(3) {
            animation-delay: 0.25s;
        }

    .step-number {
        width: 52px;
        height: 52px;
        border-radius: 50%;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-family: 'Sora', sans-serif;
        font-weight: 700;
        font-size: 1.15rem;
        color: #fff;
        background: linear-gradient(135deg, var(--brand-blue), var(--brand-purple));
        box-shadow: 0 10px 22px -10px rgba(13, 110, 253, 0.55);
        margin-bottom: 1rem;
        position: relative;
    }

        .step-number::after {
            content: "";
            position: absolute;
            inset: -6px;
            border-radius: 50%;
            border: 1.5px dashed rgba(13, 110, 253, 0.25);
        }

    .step-block h5 {
        font-family: 'Sora', sans-serif;
        font-weight: 700;
        font-size: 1.05rem;
        color: #12162b;
    }

    .step-block p {
        color: var(--slate);
        font-size: 0.88rem;
    }

    @@media (prefers-reduced-motion: reduce) {
        *, *::before, *::after {
            animation-duration: 0.01ms !important;
            transition-duration: 0.01ms !important;
        }
    }
</style>

<div class="hero-section">
    <span class="hero-badge">
        ✨ RAG-powered learning
    </span>
    <h1>
        Học thông minh hơn với<br>
        <span class="gradient-text">SmartEdu AI</span>
    </h1>
    <p class="lead">
        Hệ thống hỏi đáp dựa trên tài liệu học tập của bạn.
        Upload PDF/DOCX, đặt câu hỏi, nhận câu trả lời chính xác có trích dẫn nguồn.
    </p>
    <div class="hero-cta d-flex gap-2 justify-content-center flex-wrap">
        <a asp-controller="Chat" asp-action="Index" class="btn btn-primary px-4">
            🤖 Bắt đầu Chat RAG
        </a>
        <a asp-controller="Document" asp-action="Upload" class="btn btn-outline-secondary px-4">
            ⬆️ Upload tài liệu
        </a>
    </div>
</div>

@* Features *@
<div class="container mb-5 mt-5">
    <h2 class="section-title">Tính năng chính</h2>
    <div class="row g-3">
        <div class="col-md-3 col-sm-6">
            <div class="card feature-card h-100 shadow-none">
                <div class="card-body">
                    <div class="feature-icon bg-primary bg-opacity-10 mb-3">
                        <span style="font-size:22px">📄</span>
                    </div>
                    <h5 class="card-title">Quản lý tài liệu</h5>
                    <p class="card-text">
                        Upload PDF/DOCX, tự động chunking và embedding theo môn học.
                    </p>
                    <a asp-controller="Document" asp-action="Index" class="stretched-link"></a>
                </div>
            </div>
        </div>
        <div class="col-md-3 col-sm-6">
            <div class="card feature-card h-100 shadow-none">
                <div class="card-body">
                    <div class="feature-icon bg-success bg-opacity-10 mb-3">
                        <span style="font-size:22px">🤖</span>
                    </div>
                    <h5 class="card-title">Chatbot RAG</h5>
                    <p class="card-text">
                        Hỏi đáp thông minh, trích dẫn nguồn, lưu lịch sử theo phiên.
                    </p>
                    <a asp-controller="Chat" asp-action="Index" class="stretched-link"></a>
                </div>
            </div>
        </div>
        <div class="col-md-3 col-sm-6">
            <div class="card feature-card h-100 shadow-none">
                <div class="card-body">
                    <div class="feature-icon bg-warning bg-opacity-10 mb-3">
                        <span style="font-size:22px">📊</span>
                    </div>
                    <h5 class="card-title">Nghiên cứu RBL</h5>
                    <p class="card-text">
                        So sánh RAG vs Fine-tuning, benchmark chunking strategies.
                    </p>
                </div>
            </div>
        </div>
        <div class="col-md-3 col-sm-6">
            <div class="card feature-card h-100 shadow-none">
                <div class="card-body">
                    <div class="feature-icon bg-danger bg-opacity-10 mb-3">
                        <span style="font-size:22px">🎓</span>
                    </div>
                    <h5 class="card-title">Quản lý môn học</h5>
                    <p class="card-text">
                        Tổ chức tài liệu theo môn học, chương và chủ đề.
                    </p>
                    <a asp-controller="Subject" asp-action="Index" class="stretched-link"></a>
                </div>
            </div>
        </div>
    </div>
</div>

<hr class="section-divider" />

@* Steps *@
<div class="container pb-5">
    <h2 class="section-title">Bắt đầu trong 3 bước</h2>
    <div class="row g-3 text-center">
        <div class="col-md-4 step-block">
            <div class="step-number">1</div>
            <h5>Tạo môn học</h5>
            <p>Thêm môn học và mô tả nội dung cần học</p>
        </div>
        <div class="col-md-4 step-block">
            <div class="step-number">2</div>
            <h5>Upload tài liệu</h5>
            <p>Upload file PDF/DOCX, hệ thống tự động xử lý</p>
        </div>
        <div class="col-md-4 step-block">
            <div class="step-number">3</div>
            <h5>Hỏi đáp AI</h5>
            <p>Đặt câu hỏi, nhận câu trả lời từ tài liệu của bạn</p>
        </div>
    </div>
</div>