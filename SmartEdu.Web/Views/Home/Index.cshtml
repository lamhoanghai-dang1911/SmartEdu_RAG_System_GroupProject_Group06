@{
    ViewData["Title"] = User.Identity?.IsAuthenticated == true ? "Dashboard" : "SmartEdu — AI learning, grounded in your documents";
    Layout = "_Layout";
    var isAuth = User.Identity?.IsAuthenticated ?? false;
}
@if (isAuth)
{
    @await Html.PartialAsync("Partial/_Dashboard")
}
else
{
    @await Html.PartialAsync("Partial/_Landing")
}